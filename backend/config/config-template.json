{
    "FILE_CLASSIFICATION_CONFIG": {
        "allowed_extensions": [
            "txt",
            "csv",
            "json",
            "pdf",
            "docx",
            "xlsx",
            "pptx",
            "md",
            "jpg",
            "jpeg",
            "png",
            "gif",
            "bmp",
            "svg"
        ],
        "rules": {
            "sow_document": {
                "label": "SOW Document",
                "description": "Statement of Work - Project scope and requirements",
                "keywords": [
                    "sow",
                    "statement of work",
                    "scope",
                    "proposal"
                ],
                "priority_keywords": [
                    "poc",
                    "proof of concept",
                    "tfc aws poc",
                    "aws poc",
                    "tfc poc"
                ],
                "extensions": [
                    ".pdf",
                    ".docx",
                    ".doc"
                ],
                "icon": "file-content",
                "required": true,
                "priority": 1
            },
            "architecture_diagram": {
                "label": "Architecture Diagram",
                "description": "System design, technical diagram, or network topology",
                "keywords": [
                    "architecture",
                    "diagram",
                    "design",
                    "network",
                    "topology"
                ],
                "extensions": [
                    ".png",
                    ".jpg",
                    ".jpeg",
                    ".gif",
                    ".bmp",
                    ".svg"
                ],
                "icon": "share",
                "required": true,
                "priority": 1
            },
            "pricing_calculator_csv": {
                "label": "Pricing Calculator",
                "description": "AWS cost estimates and pricing information",
                "keywords": [
                    "pricing",
                    "cost",
                    "calculator",
                    "financial",
                    "budget"
                ],
                "extensions": [
                    ".csv",
                    ".xlsx"
                ],
                "icon": "calculator",
                "required": false,
                "priority": 2
            },
            "funding_document": {
                "label": "Funding Document",
                "description": "Funding analysis, eligibility, or program documentation",
                "keywords": [
                    "funding",
                    "eligibility",
                    "program",
                    "grant"
                ],
                "extensions": [
                    ".pdf",
                    ".docx",
                    ".doc",
                    ".md"
                ],
                "icon": "file-content",
                "required": false,
                "priority": 2
            },
            "technical_document": {
                "label": "Technical Document",
                "description": "Technical specifications, requirements, or documentation",
                "keywords": [
                    "technical",
                    "spec",
                    "requirement",
                    "documentation"
                ],
                "extensions": [
                    ".pdf",
                    ".docx",
                    ".doc",
                    ".md",
                    ".txt"
                ],
                "icon": "file",
                "required": false,
                "priority": 3
            },
            "contract": {
                "label": "Contract",
                "description": "Legal contracts, agreements, or terms",
                "keywords": [
                    "contract",
                    "agreement",
                    "terms",
                    "legal"
                ],
                "extensions": [
                    ".pdf",
                    ".docx",
                    ".doc"
                ],
                "icon": "file-content",
                "required": false,
                "priority": 4
            },
            "presentation": {
                "label": "Presentation",
                "description": "Presentation slides or pitch decks",
                "keywords": [
                    "presentation",
                    "slides",
                    "pitch",
                    "deck"
                ],
                "extensions": [
                    ".pptx",
                    ".ppt",
                    ".pdf"
                ],
                "icon": "file",
                "required": false
            },
            "other": {
                "label": "Other Document",
                "description": "General document or reference material",
                "keywords": [],
                "extensions": [],
                "icon": "file",
                "required": false
            }
        },
        "assistant_configs": {
            "apn_funding_assistant": {
                "enabled": true,
                "required_types": [
                    "sow_document",
                    "architecture_diagram"
                ],
                "optional_types": [
                    "pricing_calculator_csv",
                    "funding_document"
                ],
                "auto_classify": true,
                "show_classification_modal": true
            },
            "aws_solutions_assistant": {
                "enabled": true,
                "required_types": [
                    "architecture_diagram"
                ],
                "optional_types": [
                    "sow_document",
                    "technical_document",
                    "pricing_calculator_csv"
                ],
                "auto_classify": true,
                "show_classification_modal": false
            },
            "default": {
                "enabled": false,
                "required_types": [],
                "optional_types": [
                    "other"
                ],
                "auto_classify": false,
                "show_classification_modal": false
            }
        },
        "document_type_mapping": {
            "sow_document": "sow_document",
            "architecture_diagram": "diagram",
            "pricing_calculator_csv": "pricing_report",
            "funding_document": "funding_document",
            "technical_document": "user_upload",
            "contract": "user_upload",
            "presentation": "user_upload",
            "other": "user_upload"
        }
    },

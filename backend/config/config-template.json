        "template_types": {
            "aws_map": {
                "name": "AWS MAP Assessment SOW",
                "description": "Template for AWS Migration Acceleration Program assessments - ONLY TO BE USED FOR MIGRATIONS WHEN MAP OR MAP-LITE IS THE RECOMMENDED FUNDING",
                "default_duration_weeks": 12
            },
            "aws_modernization": {
                "name": "AWS Modernization SOW", 
                "description": "Template for AWS application modernization and cloud-native transformation projects. This is the default template for NON-MAP projects.",
                "default_duration_weeks": 12
            },
            "standard_migration": {
                "name": "AWS Migration SoW",
                "description": "Flexible template for non-complex migrations or consulting engagements",
                "default_duration_weeks": 4
            }
        },
        "terms_and_conditions": {
            "payment_and_execution": "Payment for services outlined in this Statement of Work shall be made according to the agreed-upon schedule, with invoices due within thirty (30) days of receipt unless otherwise specified. All work performed under this SOW shall be conducted in accordance with industry best practices and applicable regulatory requirements. The Client agrees to provide timely access to necessary systems, environments, and personnel required for project completion. Any changes to the scope of work must be documented through a formal change request process and approved in writing by both parties before implementation. The Service Provider reserves the right to suspend work in the event of non-payment exceeding thirty (30) days past due date.",
            "liability_and_confidentiality": "The Service Provider's liability for any claims arising from this engagement shall be limited to the total amount paid under this Statement of Work, excluding any indirect, consequential, or punitive damages. Both parties acknowledge that confidential information may be exchanged during the course of this engagement and agree to maintain strict confidentiality of all proprietary data, with such obligations surviving termination of this agreement. All intellectual property developed specifically for the Client under this SOW shall become the property of the Client upon full payment, while pre-existing intellectual property and general methodologies shall remain the property of the Service Provider. Either party may terminate this engagement with thirty (30) days written notice, with the Client responsible for payment of all work completed up to the termination date. This Statement of Work shall be governed by the laws of [Jurisdiction] and any disputes shall be resolved through binding arbitration."
        },
        "pdf_settings": {
            "page_size": "Letter",
            "margin": "1in",
            "include_header_footer": true,
            "font_family": "Arial, sans-serif"
        },
        "s3_settings": {
            "file_name": "ScopeOfWork.pdf",
            "metadata_file_name": "ScopeOfWork.metadata.json",
            "folder_structure": "{chat_id}/",
            "content_type": "application/pdf"
        },
        "review_settings": {
            "require_review": true,
            "auto_approve": false,
            "review_roles": ["sera_solutions_architect", "sera_sa_manager"],
            "notification_enabled": true
        },
        "default_assumptions": [
            "Customer will provide timely access to environment resources and documentation",
            "Key subject matter experts will participate in scheduled workshops and review sessions",
            "Appropriate access will be provided to complete the assessment",
            "Migration execution and application modernization are out of scope"
        ],
        "default_exclusions": [
            "Migration execution of workloads, data, or environments",
            "Application-level refactoring and code changes", 
            "Ongoing operations and post-assessment support",
            "Procurement of licenses, AWS services, or third-party tools"
        ]
    },

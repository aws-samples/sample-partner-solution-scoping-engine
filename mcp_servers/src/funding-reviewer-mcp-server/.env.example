# Example configuration for POC Funding Reviewer MCP Server
# This file shows example values for development/testing

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock Configuration
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_TEMPERATURE=0.1
BEDROCK_MAX_TOKENS=4000
BEDROCK_TIMEOUT=300

# MCP Server Configuration
MCP_SERVER_NAME=funding-reviewer
MCP_SERVER_VERSION=1.0.0
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080

# File Processing Configuration
MAX_FILE_SIZE_MB=50
SUPPORTED_IMAGE_FORMATS=png,jpg,jpeg
SUPPORTED_DOCUMENT_FORMATS=pdf
SUPPORTED_CSV_FORMATS=csv
TEMP_DIR=/tmp/funding-reviewer

# Reference Documents
REFERENCE_DOCS_PATH=awslabs/funding_reviewer_mcp_server/docs/poc_general_guidance.md
PROJECT_TEMPLATE_PATH=awslabs/funding_reviewer_mcp_server/docs/PoC_Project_Plan_Template.docx

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_CORRELATION_IDS=true

# Performance Configuration
REQUEST_TIMEOUT=600
MAX_CONCURRENT_REQUESTS=10
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0

# Health Check Configuration
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_INTERVAL=30

# Security Configuration
ENABLE_REQUEST_VALIDATION=true
MAX_REQUEST_SIZE_MB=100
ENABLE_FILE_SCANNING=true

# Development Configuration
DEBUG_MODE=false
DEV_MODE=false
MOCK_BEDROCK=false

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_INTERVAL=60
ENABLE_PERFORMANCE_MONITORING=true
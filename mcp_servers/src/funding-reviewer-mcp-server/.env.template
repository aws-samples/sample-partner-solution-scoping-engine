# POC Funding Reviewer MCP Server Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# AWS Configuration
# ============================================================================
# AWS region for Bedrock and other AWS services
AWS_REGION=us-east-1

# AWS credentials (optional if using IAM roles or AWS CLI profiles)
# These are handled directly by boto3 - no need to configure in this file
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_SESSION_TOKEN=your_session_token_here
# AWS_PROFILE=default

# ============================================================================
# AWS Bedrock Configuration
# ============================================================================
# Bedrock model ID for analysis
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Model parameters
BEDROCK_TEMPERATURE=0.1
BEDROCK_MAX_TOKENS=4000

# Request timeout in seconds
BEDROCK_TIMEOUT=300

# Retry configuration
BEDROCK_MAX_RETRIES=3
BEDROCK_RETRY_BACKOFF_FACTOR=2.0

# ============================================================================
# MCP Server Configuration
# ============================================================================
# Server identification
MCP_SERVER_NAME=funding-reviewer
MCP_SERVER_VERSION=1.0.0

# Performance settings
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=600

# ============================================================================
# File Processing Configuration
# ============================================================================
# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# Supported file formats (comma-separated)
SUPPORTED_IMAGE_FORMATS=png,jpg,jpeg
SUPPORTED_DOCUMENT_FORMATS=pdf,docx

# Temporary file storage directory
TEMP_DIR=/tmp/funding-reviewer

# Clean up temporary files after processing
CLEANUP_TEMP_FILES=true

# ============================================================================
# Reference Documents Configuration
# ============================================================================
# Path to reference documents (relative to project root)
REFERENCE_DOCS_PATH=awslabs/funding_reviewer_mcp_server/docs/poc_general_guidance.md
PROJECT_TEMPLATE_PATH=awslabs/funding_reviewer_mcp_server/docs/PoC_Project_Plan_Template.docx

# Require reference documents to be present (set to false for graceful degradation)
REQUIRE_REFERENCE_DOCS=false

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=text

# Log file path (optional, logs to stdout if not specified)
# LOG_FILE=/var/log/poc-funding-reviewer.log

# Enable request correlation IDs for tracing
ENABLE_CORRELATION_IDS=true

# Enable debug mode (more verbose logging, detailed error messages, stack traces)
DEBUG_MODE=false

# ============================================================================
# Environment Variables with POC_FUNDING_ Prefix (Alternative)
# ============================================================================
# You can also use the POC_FUNDING_ prefix for any of the above variables
# Example:
# POC_FUNDING_AWS_REGION=us-west-2
# POC_FUNDING_DEBUG_MODE=true
# POC_FUNDING_LOG_LEVEL=DEBUG

# ============================================================================
# Notes
# ============================================================================
# - Standard AWS environment variables (AWS_REGION, AWS_PROFILE, etc.) are supported
# - Variables can be used with or without the POC_FUNDING_ prefix
# - DEBUG_MODE automatically sets LOG_LEVEL to DEBUG and enables detailed error reporting
# - AWS credentials are handled by boto3 - use IAM roles, profiles, or environment variables
# - File size limits apply to both S3 downloads and direct uploads
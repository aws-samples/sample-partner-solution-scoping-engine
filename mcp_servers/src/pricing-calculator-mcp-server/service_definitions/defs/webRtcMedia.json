            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of attendees",
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100000000000000000
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter number of attendees",
                "id": "attendees"
              },
              {
                "type": "input",
                "subType": "durationInput",
                "label": "Duration of average session",
                "id": "durationMins",

                    "Memory"
                  ]
                },
                "secondaryKey": [],
                "row": [
                  {
                    "label": "Quantity",
                    "type": "textInput",
                    "selectorId": "Quantity",
                    "description": "Enter the number of instances in your cluster including replica instances",
                    "validations": {
                      "allowDecimals": false,
                      "minValue": 0,
                      "maxValue": 10000000000000,
                      "required": true

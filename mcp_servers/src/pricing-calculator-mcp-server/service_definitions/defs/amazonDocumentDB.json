            "$LINK": {
              "type": "pricing",
              "path": "/documentdb/pricing/",
              "overrides": {
                "aws": "https://docs.aws.amazon.com/documentdb/latest/developerguide/db-cluster-storage-configs.html",
                "aws-us-gov": "https://docs.aws.amazon.com/documentdb/latest/developerguide/db-cluster-storage-configs.html"
              }
            }
          },
          "description": "Staring from Amazon DocumentDB 5.0, instance-based clusters support two storage configurations types: Amazon DocumentDB Standard and Amazon DocumentDB I/O-Optimized.",

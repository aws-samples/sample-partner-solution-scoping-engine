              {
                "displayIf": {
                  "==": [
                    {
                      "type": "component",
                      "id": "edition"
                    },
                    "docdbStandard"
                  ]
                },
                "type": "input",
                "subType": "alert",
                "header": "",
                "content": "Cost effective pricing for many applications with moderate I/O usage (I/O costs <25% of total database costs). <br>Pay-per-request I/O charges apply. DB instance and storage prices don't include I/O usage.",
                "alertType": "info",
                "partitions": [
                  "aws",
                  "aws-cn",
                  "aws-us-gov"
                ],
                "isDismissable": true,
                "id": "userTypeInfoDocdbStandard"
              },
              {
                "displayIf": {

                "type": "input",
                "subType": "alert",
                "header": "",
                "content": "Predictable pricing for all applications. Improved price-performance for I/O-intensive applications (I/O costs >25% of total database costs). <br>No additional charges for read/write I/O operations. DB instance and storage prices includes I/O usage.",
                "alertType": "info",
                "isDismissable": true,
                "id": "userTypeInfoDocdbIOoptimized"
              },
              {
                "type": "pricing",
                "label": "Price for storage",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "docdbstorage-calc",
                "meteredUnit": {
                  "allRegions": "Database Storage"
                },
                "id": "standardStoragePrice"
              }
            ]
          }
        },

{
  "version": "0.0.23",
  "serviceName": "SageMaker Code Editor",
  "serviceCode": "sageMakerCodeEditor",
  "type": "AWSService",
  "subType": "subService",
  "regions": [
    "af-south-1",
    "ap-east-1",
    "ap-south-1",
    "ap-northeast-1",
    "ap-northeast-2",
    "ap-northeast-3",
    "ap-southeast-1",
    "ap-southeast-2",
    "ca-central-1",
    "eu-central-1",
    "eu-west-1",
    "eu-west-2",
    "eu-south-1",
    "eu-west-3",
    "eu-north-1",
    "me-south-1",
    "sa-east-1",
    "us-east-1",
    "us-east-2",
    "us-west-1",
    "us-west-2"
  ],
  "searchKeywords": [
    "Sagemaker",
    "Model",
    "ML",
    "Machine Learning",
    "EI",
    "data scientist"
  ],
  "serviceDescription": "With Amazon SageMaker, you pay only for what you use. Building, training, and deploying ML models is billed by the second, with no minimum fees and no upfront commitments.",
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "sagemaker-instances-studio-codeeditor-calc",
      "mappingDefinitionVersion": "PLC_2.0",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/sagemaker/[currency]/current/sagemaker-instances-studio-codeeditor-calc/metadata.json"
    }
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/sagemaker"
    }
  },
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "SageMaker Code Editor",
      "description": "",
      "id": "sageMakerCodeEditor",
      "helpText": "Studio notebooks are one-click Jupyter notebooks that can be spun up quickly. The underlying compute resources are fully elastic. These notebooks can be easily shared with others enabling seamless collaboration.",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/sagemaker/"
        }
      },
      "cards": [
        {
          "title": "SageMaker Code Editor",
          "helpText": "",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/sagemaker/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "id": "DataScientistsPerMonth",
                "label": "Number of data scientist(s)/ ML engineer(s)",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 10000000000000
                },
                "placeholder": "Enter the number of data scientist(s) per month",
                "description": "Number of data scientist(s)/ ML engineer(s)"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "codeeditorsPerMonth",
                "label": "Number of Code editor private spaces per data scientist/ ML engineer",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 10000000000000
                },
                "placeholder": "Enter the number of Code editor private spaces per data scientist/ ML engineer per month",
                "description": "Number of Code editor private spaces"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "codeeditorHrsPerDay",
                "label": "Number of Code Editor IDE usage hours per day",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0.01,
                  "maxValue": 24
                },
                "placeholder": "Enter the number of Code Editor IDE usage hours per day",
                "description": "Number of Code Editor IDE usage hours per day"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "codeeditorDaysPerMonth",
                "label": "Code Editor day(s) per month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 31
                },
                "placeholder": "Enter the number of days Code Editot IDE are used per month",
                "description": "Number of days Code Editot IDE are being used per month"
              },
              {
                "label": "SageMaker Code Editor",
                "id": "columnFormIPM",
                "type": "input",
                "subType": "columnFormIPM",
                "disableCalculation": true,
                "mappingDefinitionName": "sagemaker-instances-studio-codeeditor-calc",
                "calculationId": {
                  "hourly": "monthly_ipm"
                },
                "pricingUnitModel": {
                  "riPaymentOptions": {
                    "hourly": "*"
                  }
                },
                "primaryKey": {
                  "Instance Name": [
                    "Compute Type",
                    "V CPU",
                    "Memory",
                    "Clock Speed",
                    "GPU",
                    "Network Performance",
                    "Storage",
                    "GPU Memory"
                  ]
                },
                "secondaryKey": [
                  "Component"
                ],
                "row": [
                  {
                    "label": "Instance name",
                    "type": "autoSuggest",
                    "selectorId": "Instance Name",
                    "withTags": [
                      "Compute Type",
                      "V CPU",
                      "Memory",
                      "Clock Speed",
                      "GPU",
                      "Network Performance",
                      "Storage",
                      "GPU Memory"
                    ]
                  }
                ]
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "DataScientistsPerMonth",
                      "variableLabel": "Number of data scientist(s)/ ML engineer(s)",
                      "variableUnitLabel": "data scientist(s)/ ML engineer(s) ",
                      "required": true
                    },
                    {
                      "variableId": "codeeditorsPerMonth",
                      "variableLabel": "Number of Code editor private spaces per data scientist/ ML engineer",
                      "variableUnitLabel": "Code Editor instance(s)",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "Code Editor instance(s) per month",
                  "decimalPlaces": 6,
                  "id": "sageMakerCodeeditor_instance_1"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "sageMakerCodeeditor_instance_1",
                      "variableLabel": "Code Editor instance(s) per month",
                      "variableUnitLabel": "Code Editor instance(s)",
                      "required": true
                    },
                    {
                      "variableId": "codeeditorHrsPerDay",
                      "variableLabel": "Number of Code Editor IDE usage hours per day",
                      "variableUnitLabel": "hours per day",
                      "required": true
                    },
                    {
                      "variableId": "codeeditorDaysPerMonth",
                      "variableLabel": "Code Editor day(s) per month",
                      "variableUnitLabel": "days per month",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "Code Editor hours per month",
                  "decimalPlaces": 6,
                  "id": "sageMakerCodeeditor_instance_2"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Code Editor hours per month",
                      "variableUnitLabel": "hours per month",
                      "required": true,
                      "variableId": "sageMakerCodeeditor_instance_2"
                    },
                    {
                      "variableLabel": "SageMaker Code Editor",
                      "variableUnitLabel": "[currency] per hour instance cost",
                      "required": true,
                      "variableId": "monthly_ipm",
                      "IPMSupported": true
                    }
                  ],
                  "outputUnitLabel": "[currency](monthly On-Demand cost)",
                  "decimalPlaces": 2,
                  "id": "sageMakerCodeeditor_instance_3"
                },
                {
                  "type": "display",
                  "refer": [
                    "DataScientistsPerMonth",
                    "codeeditorsPerMonth",
                    "codeeditorHrsPerDay",
                    "codeeditorDaysPerMonth",
                    "columnFormIPM",
                    "sageMakerCodeeditor_instance_1",
                    "sageMakerCodeeditor_instance_2",
                    "sageMakerCodeeditor_instance_3"
                  ],
                  "required": true,
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Total cost for Code Editor",
                  "decimalPlaces": 2,
                  "id": "sageMakerCodeeditor_instance_4",
                  "subTotalRefer": "sageMakerCodeeditor_instance_3"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws"
  ]
}
  "serviceDescription": "Amazon Translate is a neural machine translation service that delivers fast, high-quality, and affordable language translation. Neural machine translation is a form of language translation automation that uses deep learning models to deliver more accurate and more natural sounding translation than traditional statistical and rule-based translation algorithms.",
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "translate",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/translate/[currency]/current/translate.json"
    }
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/translate/"
    }
  },
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "Active Custom Translation Batch",
      "description": "Amazon Translate delivers fast, high-quality, and affordable language translation. This is a neural machine translation service, which is a form of language translation automation that uses deep learning models to deliver more accurate and more natural sounding translation than traditional statistical and rule-based translation algorithms.",
      "id": "amazonTranslate_Activebatch",
      "helpText": "",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/translate/pricing/",
          "overrides": {
            "aws": "https://docs.aws.amazon.com/translate/latest/dg/customizing-translations-parallel-data.html"
          }
        }
      },
      "cards": [
        {
          "title": "Active Custom Translation Batch",
          "helpText": "Use Active Custom Translation to take greater control over your machine translation output using your data to customize the translation.<a href='https://aws.amazon.com/contact-us/'target='_blank'> For consistent usage greater than 1 billion characters per month, please contact us.</a>",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/translate/pricing/",
              "overrides": {
                "aws": "https://docs.aws.amazon.com/translate/latest/dg/customizing-translations-parallel-data.html"
              }
            }
          },
          "bodyText": "The calculations below exclude free tier discounts.",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Translate_chars_ActiveBatch",
                "label": "Number of characters including white spaces and punctuations (Active Custom Batch Translation)",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 100000000000000000000
                },
                "placeholder": "Enter average number of characters to be translated per month",
                "description": "Average number of characters translated per month"
              },
              {
                "type": "pricing",
                "label": "price for active batch translate",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "translate",
                "meteredUnit": {
                  "allRegions": "ActiveCustomTranslationJob"
                },
                "id": "translateActivebatchPricing"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "ActiveBatchTranslatecost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Translate_chars_ActiveBatch",
                      "variableLabel": "Number of characters including white spaces and punctuations (Active Custom Batch Translation)",
                      "variableUnitLabel": "characters",
                      "required": true
                    },
                    {
                      "variableId": "translateActivebatchPricing",
                      "variableLabel": "price for active batch translate",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (cost for Active Custom Batch Translation)",
                  "decimalPlaces": 6
                },
                {
                  "type": "display",
                  "id": "ActiveBatch_Translation_Disp",
                  "refer": [
                    "Translate_chars_ActiveBatch",
                    "translateActivebatchPricing",
                    "ActiveBatchTranslatecost"
                  ],
                  "subTotalRefer": "ActiveBatchTranslatecost",
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Active Custom Batch Translation cost",
                  "decimalPlaces": 6
                }
              ]
            }
          ]
        }
      ]
    }

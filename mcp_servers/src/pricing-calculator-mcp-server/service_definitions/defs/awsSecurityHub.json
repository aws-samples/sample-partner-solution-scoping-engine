                      "endOfTier": -1,
                      "meteredUnit": "QaiWtpMeQZCnPeG5Hyp4vJ5FGEJS22q66gtx7IXqNqw"
                    }
                  ]
                }
              },
              {
                "type": "pricing",
                "subType": "tieredPricing",
                "label": "Tiered Finding Ingestion Price",
                "id": "ingestionTieredPrice",
                "mappingDefinitionName": "securityhub",
                "tiers": {
                  "allRegions": [
                    {
                      "startOfTier": 0,
                      "endOfTier": 10000,
                      "meteredUnit": "ACmHNE8Z_O3SZWPWL74SGpZIbdNCOaG95Y2jLHTSr64"

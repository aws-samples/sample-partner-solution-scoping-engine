                    {
                      "startOfTier": 10001,
                      "endOfTier": -1,
                      "meteredUnit": "VqFxkJhmGty2kx-7xc1nRSlBuOV1BPKOFbm-IzQ41lE"
                    }
                  ]
                }
              },
              {
                "type": "pricing",
                "subType": "tieredPricing",
                "label": "Tiered Rule Evaluation checks Price",
                "id": "ruleevaluationTieredPrice",
                "mappingDefinitionName": "securityhub",
                "tiers": {
                  "allRegions": [
                    {
                      "startOfTier": 0,
                      "endOfTier": 1000000,
                      "meteredUnit": "GfkmsI9dby31zSpMsqgt0pbPgLWM21wcZ6VxKFzjoxM"
                    },
                    {
                      "startOfTier": 1000001,
                      "endOfTier": 100000000,
                      "meteredUnit": "Sp5SzsBCYpZxBYfnFk1-1l_L2EYHR5LlSLAs7rSluw0"
                    },
                    {
                      "startOfTier": 100000001,
                      "endOfTier": 1000000000,
                      "meteredUnit": "P1Mkst34kz3xoQrGdPqMbVGio6JSsMvmbhbAHmYtMGU"
                    },
                    {
                      "startOfTier": 1000000001,
                      "endOfTier": -1,
                      "meteredUnit": "WKmFrmbAhAVu32izCNEcsgplBGumZC6BFX-mScWu6nE"
                    }
                  ]
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "freeTierAlert",
                    "noOfAccounts",
                    "noOfSecurityChecks",
                    "noOfIngestion",
                    "noOfautomationrules",
                    "noOfcriteria",
                    "secCheckTieredPrice",
                    "ingestionTieredPrice",
                    "ruleevaluationTieredPrice"
                  ],
                  "subTotalRefer": "",
                  "id": "serviceSettingUnitConversion"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Total tiered price for security checks",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] for security check",
                  "id": "SubTotalRequestSecCheck",
                  "refer": "securityCheckCost"
                },
                {
                  "type": "maths",
                  "subType": "tieredPricingMath",
                  "inputRefer": "noOfSecurityChecks",
                  "inputReferLabel": "Number of Security Checks per Account",
                  "tieredPricingRefer": "secCheckTieredPrice",
                  "tieredPricingReferLabel": "Tiered Security Check Price",
                  "inputUnitLabel": "Security Checks",
                  "decimalPlaces": 6,
                  "id": "securityCheckCost",
                  "outputUnitLabel": "[currency] for security check"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Total tiered price for security checks per account",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] per Month for security check",
                  "id": "SubTotalRequestSecCheckPerAccount",
                  "refer": "secCheckMonthlyCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "secCheckMonthlyCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "noOfAccounts",
                      "variableLabel": "Number of Accounts",
                      "variableUnitLabel": "accounts",
                      "required": true
                    },
                    {
                      "variableId": "securityCheckCost",
                      "variableLabel": "[currency] for security check",
                      "variableUnitLabel": "[currency] per month",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] per Month for security check",
                  "decimalPlaces": 4
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Total tiered price for finding ingestion",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] per month for finding ingestion",
                  "id": "SubTotalRequestFindingIngestion",
                  "refer": "ingestionCost"
                },
                {
                  "type": "maths",
                  "subType": "tieredPricingMath",
                  "inputRefer": "noOfIngestion",
                  "inputReferLabel": "Number of Finding Ingested per Account",
                  "tieredPricingRefer": "ingestionTieredPrice",
                  "tieredPricingReferLabel": "Tiered Finding Ingestion Price",
                  "inputUnitLabel": "finding ingestion",
                  "decimalPlaces": 6,
                  "id": "ingestionCost",
                  "outputUnitLabel": "[currency] per month for finding ingestion"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Total tiered price for finding ingestion per account",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] per Month for finding ingestion",
                  "id": "SubTotalRequestFndingIngestionPerAccount",
                  "refer": "ingestionMonthlyCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "ingestionMonthlyCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "noOfAccounts",
                      "variableLabel": "Number of Accounts",
                      "variableUnitLabel": "accounts",
                      "required": true
                    },
                    {
                      "variableId": "ingestionCost",
                      "variableLabel": "[currency] per month for finding ingestion",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] per Month for finding ingestion",
                  "decimalPlaces": 4
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "securitychecksplusfindingingested",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "noOfSecurityChecks",
                      "variableLabel": "Number of Security Checks per Account",
                      "variableUnitLabel": "",
                      "required": true
                    },
                    {
                      "variableId": "noOfIngestion",
                      "variableLabel": "Number of Finding Ingested per Account",
                      "variableUnitLabel": " ",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "per month",
                  "decimalPlaces": 4
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "numberofruleevaluations",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "securitychecksplusfindingingested",
                      "variableLabel": "per month",
                      "variableUnitLabel": "",
                      "required": true
                    },
                    {
                      "variableId": "noOfautomationrules",
                      "variableLabel": "Number of Automation Rules",
                      "variableUnitLabel": "",
                      "required": true
                    },
                    {
                      "variableId": "noOfcriteria",
                      "variableLabel": "Number of criteria in each automation rule",
                      "variableUnitLabel": "",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "rule evaluations"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Total tiered price for rule evaluation",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] per month for rule evaluations",
                  "id": "SubTotalRequestruleevaluationchecks",
                  "refer": "ruleevaluationcost"
                },
                {
                  "type": "maths",
                  "subType": "tieredPricingMath",
                  "inputRefer": "numberofruleevaluations",
                  "inputReferLabel": "rule evaluations",
                  "tieredPricingRefer": "ruleevaluationTieredPrice",
                  "tieredPricingReferLabel": "Tiered Rule Evaluation checks Price",
                  "inputUnitLabel": "rule evaluations",
                  "decimalPlaces": 6,
                  "id": "ruleevaluationcost",
                  "outputUnitLabel": "[currency] per month for rule evaluations"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "ruleevaluationMonthlyCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "noOfAccounts",
                      "variableLabel": "Number of Accounts",
                      "variableUnitLabel": "accounts",
                      "required": true
                    },
                    {
                      "variableId": "ruleevaluationcost",
                      "variableLabel": "[currency] per month for rule evaluations",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] per Month for rule evaluations",
                  "decimalPlaces": 4
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "totalMonthlyCost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "secCheckMonthlyCost",
                      "variableLabel": "[currency] per Month for security check",
                      "variableUnitLabel": "total [currency] for security check",
                      "required": true
                    },
                    {
                      "variableId": "ingestionMonthlyCost",
                      "variableLabel": "[currency] per Month for finding ingestion",
                      "variableUnitLabel": "total [currency] for finding ingestion",
                      "required": false
                    },
                    {
                      "variableId": "ruleevaluationMonthlyCost",
                      "variableLabel": "[currency] per Month for rule evaluations",
                      "variableUnitLabel": "[currency] per month for rule evaluations",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency] per month",
                  "decimalPlaces": 4
                },
                {
                  "type": "display",
                  "refer": [
                    "SubTotalRequestSecCheck",
                    "securityCheckCost",
                    "SubTotalRequestSecCheckPerAccount",
                    "secCheckMonthlyCost",
                    "SubTotalRequestFindingIngestion",
                    "ingestionCost",
                    "SubTotalRequestFndingIngestionPerAccount",
                    "ingestionMonthlyCost",
                    "securitychecksplusfindingingested",
                    "numberofruleevaluations",
                    "SubTotalRequestruleevaluationchecks",
                    "ruleevaluationcost",
                    "ruleevaluationMonthlyCost",
                    "totalMonthlyCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Total Cost",
                  "decimalPlaces": 2,
                  "id": "configTotalPrice",
                  "subTotalRefer": "totalMonthlyCost"
                }
              ]
            }
          ]
        }
      ],
      "id": "template_securityhub"
    }
  ],
  "partitions": [
    "aws",
    "aws-cn",
    "aws-us-gov",

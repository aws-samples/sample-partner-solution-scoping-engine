{
  "version": "0.0.52",
  "serviceName": {
    "aws": "AWS Security Hub",
    "aws-cn": "Amazon Security Hub"
  },
  "slug": "securityHub",
  "serviceCode": "awsSecurityHub",
  "type": "AWSService",
  "displayAutomation": true,
  "excludeZeroSubTotals": true,
  "searchKeywords": [
    "security",
    "hub"
  ],
  "serviceDescription": {
    "aws": "AWS Security Hub performs security best practice checks and ingests security findings from AWS security services and partners.",
    "aws-cn": "Amazon Security Hub performs security best practice checks and ingests security findings from Amazon security services and partners.",
    "aws-us-gov": "AWS Security Hub performs security best practice checks and ingests security findings from AWS security services and partners."
  },
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/security-hub/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "securityhub",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/securityhub/[currency]/current/securityhub.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "cards": [
        {
          "title": "Service Settings",
          "helpText": {
            "aws": "AWS Security combines the results of the security checks with findings from other services and partner security tools to give you a comprehensive view of your security posture, dashboards that aggregate security findings, and remediation recommendations for identified issues. ",
            "aws-cn": "Amazon Security combines the results of the security checks with findings from other services and partner security tools to give you a comprehensive view of your security posture, dashboards that aggregate security findings, and remediation recommendations for identified issues. ",
            "aws-us-gov": "AWS Security combines the results of the security checks with findings from other services and partner security tools to give you a comprehensive view of your security posture, dashboards that aggregate security findings, and remediation recommendations for identified issues. "
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/security-hub/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "alert",
                "header": "Free 30-day trial period",
                "label": "info alert",
                "content": {
                  "aws": "<p style='padding: 20'>You can try AWS Security Hub at no charge with a 30-day free trial. The trial includes the complete Security Hub feature set and security best practice checks. The free trial will provide you an estimate of your monthly bill if you continue using Security Hub across the same accounts and regions.</p>",
                  "aws-cn": "<p style='padding: 20'>You can try Amazon Security Hub at no charge with a 30-day free trial. The trial includes the complete Security Hub feature set and security best practice checks. The free trial will provide you an estimate of your monthly bill if you continue using Security Hub across the same accounts and regions.</p>",
                  "aws-us-gov": "<p style='padding: 20'>You can try AWS Security Hub at no charge with a 30-day free trial. The trial includes the complete Security Hub feature set and security best practice checks. The free trial will provide you an estimate of your monthly bill if you continue using Security Hub across the same accounts and regions.</p>"
                },
                "alertType": "info",
                "isDismissable": true,
                "id": "freeTierAlert"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "noOfAccounts",
                "label": "Number of Accounts",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1e+22
                },
                "placeholder": "Enter Number of Accounts",
                "description": ""
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "noOfSecurityChecks",
                "label": "Number of Security Checks per Account",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1e+22
                },
                "placeholder": "Enter Number of Security Checks per Account",
                "description": ""
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "noOfIngestion",
                "label": "Number of Finding Ingested per Account",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1e+22
                },
                "placeholder": "Enter Number of Finding Ingestions per Account",
                "description": ""
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "noOfautomationrules",
                "label": "Number of Automation Rules",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1e+22
                },
                "placeholder": "Enter the number of automation rules per Account",
                "description": ""
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "noOfcriteria",
                "label": "Number of criteria in each automation rule",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1e+22
                },
                "placeholder": "Enter the number of criteria in each automation rule",
                "description": ""
              },
              {
                "type": "pricing",
                "subType": "tieredPricing",
                "label": "Tiered Security Check Price",
                "id": "secCheckTieredPrice",
                "mappingDefinitionName": "securityhub",
                "tiers": {

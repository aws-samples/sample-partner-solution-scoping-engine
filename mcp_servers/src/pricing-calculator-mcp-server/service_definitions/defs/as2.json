  "mappingDefinitions": [
    {
      "mappingDefinitionName": "transfer",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/transfer/[currency]/current/transfer.json"
    }
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/aws-transfer-family/",
      "overrides": {
        "aws-cn": "https://www.amazonaws.cn/en/amazon-transfer-family/"
      }
    }
  },
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "AS2 Transfer",
      "id": "awsTransferForAS2",
      "description": "",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/aws-transfer-family/pricing/",
          "overrides": {
            "aws-cn": "https://www.amazonaws.cn/en/amazon-transfer-family/pricing/"
          }
        }
      },
      "cards": [
        {
          "title": "AS2 monthly service usage",
          "helpText": {
            "aws": "AWS Transfer Family simplifies migration of SFTP, FTPS, FTP, and AS2 based workloads to AWS. To learn more about our pricing, please reference our pricing page or contact an AWS specialist for pricing assistance.",
            "aws-cn": "Amazon Transfer Family simplifies migration of SFTP, FTPS, FTP, and AS2 based workloads to Amazon Web Services. To learn more about our pricing, please reference our pricing page or contact an Amazon Web Services specialist for pricing assistance.",
            "aws-us-gov": "AWS Transfer Family simplifies migration of SFTP, FTPS, FTP, and AS2 based workloads to AWS. To learn more about our pricing, please reference our pricing page or contact an AWS specialist for pricing assistance."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/aws-transfer-family/pricing/",
              "overrides": {
                "aws-cn": "https://www.amazonaws.cn/en/amazon-transfer-family/pricing/"
              }
            }
          },
          "inputSection": {
            "components": [
              {
                "partitions": [
                  "aws",
                  "aws-us-gov"
                ],
                "type": "input",
                "subType": "bodyText",
                "text": "AWS Transfer Family has predictable, usage-based pricing. You only pay for the protocols enabled on your server endpoint(s), the amount of data (gigabytes) uploaded and downloaded over SFTP/FTPS/FTP, or the number of messages sent or received over AS2, or the amount of data processed using AWS Transfer Family Workflows. When using SFTP connectors to connect to remote SFTP servers, you pay for the number of connector calls and the amount of data sent or retrieved.",
                "id": "commercialText"
              },
              {
                "partitions": [
                  "aws-cn"
                ],
                "type": "input",
                "subType": "bodyText",
                "text": "Amazon Transfer Family has predictable, usage-based pricing. You only pay for the protocols enabled on your server endpoint(s), the amount of data (gigabytes) uploaded and downloaded over SFTP/FTPS/FTP, or the number of messages sent or received over AS2, or the amount of data processed using Amazon Transfer Family Workflows. When using SFTP connectors to connect to remote SFTP servers, you pay for the number of connector calls and the amount of data sent or retrieved.",
                "id": "chinaText"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "numberOfResources",
                "label": "Total number of endpoints with AS2 enabled",
                "displayInConfigSummary": true,
                "defaultValue": 0,
                "validations": {
                  "required": false,
                  "allowDecimal": false,
                  "minValue": 0,
                  "maxValue": 100000000
                },
                "placeholder": "Enter the total number of endpoints with AS2 enabled"
              },
              {
                "type": "pricing",
                "subType": "singlePricePoint",
                "id": "transferEndpointPrice",
                "label": "price for Amazon endpoint transfer",
                "mappingDefinitionName": "transfer",
                "meteredUnit": {
                  "allRegions": "Transfer AS2 per Hourly"
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "msgSentUnder",
                "label": "Number of AS2 messages sent per month",
                "displayInConfigSummary": true,
                "defaultValue": "",
                "validations": {
                  "required": true,
                  "allowDecimal": false,
                  "minValue": 0,
                  "maxValue": 10000000000
                },
                "placeholder": "Enter the number of messages sent"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "msgReceivedUnder",
                "label": "Number of AS2 messages received per month",
                "displayInConfigSummary": true,
                "defaultValue": "",
                "validations": {
                  "required": true,
                  "allowDecimal": false,
                  "minValue": 0,
                  "maxValue": 10000000000
                },
                "placeholder": "Enter the number of messages received"
              },
              {
                "type": "pricing",
                "subType": "singlePricePoint",
                "id": "msgSentUnderPrice",
                "label": "price for AS2 messages up to 50MB sent",
                "mappingDefinitionName": "transfer",
                "meteredUnit": {
                  "allRegions": "Transfer AS2 Outbound per Message"
                }
              },
              {
                "type": "pricing",
                "subType": "singlePricePoint",
                "id": "msgReceivedUnderPrice",
                "label": "price for AS2 messages up to 50MB received",
                "mappingDefinitionName": "transfer",
                "meteredUnit": {
                  "allRegions": "Transfer AS2 Inbound per Message"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "id": "as2Transfer_generated_0",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "commercialText",
                    "chinaText",
                    "numberOfResources",
                    "transferEndpointPrice",
                    "msgSentUnder",
                    "msgReceivedUnder",
                    "msgSentUnderPrice",
                    "msgReceivedUnderPrice"
                  ],
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "id": "transferFamilyProtocolCostOld",
                  "operands": [
                    {
                      "variableId": "numberOfResources",
                      "variableLabel": "Total number of endpoints with AS2 enabled",
                      "variableUnitLabel": "resource(s)",
                      "required": true
                    },
                    {
                      "constant": 730,
                      "constantUnitLabel": "hours per month"
                    },
                    {
                      "variableId": "transferEndpointPrice",
                      "variableLabel": "price for Amazon endpoint transfer",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (cost for protocols)",
                  "decimalPlaces": 4
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "id": "sentCost",
                  "operands": [
                    {
                      "variableId": "msgSentUnder",
                      "variableLabel": "Number of AS2 messages sent per month",
                      "variableUnitLabel": "messages sent",
                      "required": true
                    },
                    {
                      "variableId": "msgSentUnderPrice",
                      "variableLabel": "price for AS2 messages up to 50MB sent",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (cost for sent messages)",
                  "decimalPlaces": 4
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "id": "receivedCost",
                  "operands": [
                    {
                      "variableId": "msgReceivedUnder",
                      "variableLabel": "Number of AS2 messages received per month",
                      "variableUnitLabel": "messages received",
                      "required": true
                    },
                    {
                      "variableId": "msgReceivedUnderPrice",
                      "variableLabel": "price for AS2 messages up to 50MB received",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (cost for received messages)",
                  "decimalPlaces": 4
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "addition",
                  "id": "totalTransferCost",
                  "operands": [
                    {
                      "variableId": "transferFamilyProtocolCostOld",
                      "variableLabel": "[currency] (cost for protocols)",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableId": "sentCost",
                      "variableLabel": "[currency] (cost for sent messages)",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableId": "receivedCost",
                      "variableLabel": "[currency] (cost for received messages)",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 4
                },
                {
                  "type": "display",
                  "id": "totalTransferCostDisplay",
                  "refer": [
                    "transferFamilyProtocolCostOld",
                    "sentCost",
                    "receivedCost",
                    "totalTransferCost"
                  ],
                  "required": true,
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Transfer Pricing",
                  "decimalPlaces": 2,
                  "subTotalRefer": "totalTransferCost"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
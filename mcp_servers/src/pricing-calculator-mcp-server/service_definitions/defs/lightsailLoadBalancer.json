            "$LINK": {
              "type": "pricing",
              "path": "/lightsail/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "",
                "id": "lightsailLoadBalancerText"
              },
              {
                "type": "input",
                "subType": "frequency",
                "id": "loadBalancerUsage",
                "label": "Load Balancer usage",
                "options": [
                  {
                    "label": "hours per day",
                    "id": "perDay"
                  },
                  {
                    "label": "hours per week",
                    "id": "perWeek"
                  },
                  {
                    "label": "hours per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perMonth",
                "defaultValue": 730,
                "lookupValue": "",
                "outputFrequency": {
                  "label": "hours per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 730
                },
                "placeholder": "",
                "description": ""
              },
              {
                "type": "pricing",
                "id": "lightsailLoadBalancerPrice",
                "label": "Price lightsail load balancer",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "lightsail",
                "meteredUnit": {
                  "allRegions": "Lightsail Load Balancer per Hrs"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",
                  "label": "Unit conversions",
                  "refer": [
                    "lightsailLoadBalancerText",
                    "loadBalancerUsage",
                    "lightsailLoadBalancerPrice"
                  ],
                  "id": "unitConvertBlockStorage",
                  "decimalPlaces": 2,
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "lightsailLoadBalancerCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "loadBalancerUsage",
                      "variableLabel": "Load Balancer usage",
                      "variableUnitLabel": "hours",
                      "required": true
                    },
                    {
                      "variableId": "lightsailLoadBalancerPrice",
                      "variableLabel": "Price lightsail load balancer",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] Lightsail load balancer",
                  "decimalPlaces": 0
                },
                {
                  "type": "display",
                  "refer": [
                    "lightsailLoadBalancerCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Lightsail Load Balancer cost",
                  "decimalPlaces": 2,
                  "id": "lightsailLoadBalancerCostDisplay",
                  "subTotalRefer": "lightsailLoadBalancerCost"
                }
              ]
            }
          ]
        }
      ]

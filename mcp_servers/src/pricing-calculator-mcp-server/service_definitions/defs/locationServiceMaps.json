          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",
                  "label": "Unit conversions",
                  "refer": [
                    "alertLocationService",
                    "MapsText",
                    "numberOfDynamicMapTiles",
                    "numberOfStaticMapTiles",
                    "numberOfOpenMapTiles",
                    "DynamicMapsPrice",
                    "StaticMapsPrice",
                    "OpenDataMapsPrice",
                    "RegionText"
                  ],
                  "id": "MapTilesConvert",
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "DynamicMapsMult",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "numberOfDynamicMapTiles",
                      "variableLabel": "Dynamic Maps",
                      "variableUnitLabel": "Dynamic Map tiles retrieved per month",
                      "required": true
                    },
                    {
                      "variableId": "DynamicMapsPrice",
                      "variableLabel": "Price per Dynamic Map tiles retrieved",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] Dynamic Maps cost per month",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "StaticMapsMult",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "numberOfStaticMapTiles",
                      "variableLabel": "Static Maps",
                      "variableUnitLabel": "Static Map tiles retrieved per month",
                      "required": true
                    },
                    {
                      "variableId": "StaticMapsPrice",
                      "variableLabel": "Price per Static Map tiles retrieved",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] Static Maps cost per month",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "OpenDataMapsMult",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "numberOfOpenMapTiles",
                      "variableLabel": "Open Data Dynamic Maps",
                      "variableUnitLabel": "Open Data Dynamic Map tiles retrieved per month",
                      "required": true
                    },
                    {
                      "variableId": "OpenDataMapsPrice",
                      "variableLabel": "Price per Open Data Dynamic Map tiles retrieved",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] Open Data Dynamic Maps cost per month",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "MapsTotal",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "DynamicMapsMult",
                      "variableLabel": "[currency] Dynamic Maps cost per month",
                      "variableUnitLabel": "[currency] Dynamic Maps Total Cost",
                      "required": false
                    },
                    {
                      "variableId": "StaticMapsMult",
                      "variableLabel": "[currency] Static Maps cost per month",
                      "variableUnitLabel": "[currency] Static Maps Total Cost",
                      "required": false
                    },
                    {
                      "variableId": "OpenDataMapsMult",
                      "variableLabel": "[currency] Open Data Dynamic Maps cost per month",
                      "variableUnitLabel": "[currency] Open Data Dynamic Maps total cost",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency] Total Maps Cost",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "subType": "priceDisplay",
                  "id": "MapsDisplay",
                  "label": "Total Maps Cost",
                  "refer": [
                    "DynamicMapsMult",
                    "StaticMapsMult",
                    "OpenDataMapsMult",
                    "MapsTotal"
                  ],
                  "costType": "Monthly",
                  "decimalPlaces": 2,
                  "subTotalRefer": "MapsTotal"
                }
              ]
            }
          ]

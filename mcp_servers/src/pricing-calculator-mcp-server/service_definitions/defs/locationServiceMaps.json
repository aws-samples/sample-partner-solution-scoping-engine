                  },
                  {
                    "label": "billion per month",
                    "id": "billionPerMonth"
                  }
                ],
                "defaultFrequency": "thousandPerMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0
                },
                "placeholder": "Enter number of Dynamic Map tiles retrieved"
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": "Static Maps",
                "id": "numberOfStaticMapTiles",

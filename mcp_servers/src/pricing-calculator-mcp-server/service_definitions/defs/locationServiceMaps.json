      "cards": [
        {
          "title": "Maps",
          "helpText": {
            "aws": "A request to retrieve a piece, or “tile,” of a larger digital map. When your application displays a map, it is showing a collection of map tiles. Amazon Location Service uses two types of map tiles: raster tiles, which are 256 x 256 pixel map images; and vector tiles, which represent the geographical features of a small map area.",
            "aws-cn": "A request to retrieve a piece, or “tile,” of a larger digital map. When your application displays a map, it is showing a collection of map tiles. Amazon Location Service uses two types of map tiles: raster tiles, which are 256 x 256 pixel map images; and vector tiles, which represent the geographical features of a small map area."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/location/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",

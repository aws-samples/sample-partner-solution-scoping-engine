                  },
                  {
                    "label": "billion per month",
                    "id": "billionPerMonth"
                  }
                ],
                "defaultFrequency": "thousandPerMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0

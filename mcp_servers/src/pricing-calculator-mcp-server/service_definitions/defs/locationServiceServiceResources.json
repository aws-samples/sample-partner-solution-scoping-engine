{
  "version": "0.0.7",
  "serviceName": "Service Resources",
  "serviceCode": "locationServiceServiceResources",
  "type": "AWSService",
  "subType": "subService",
  "excludeZeroSubTotals": false,
  "partitions": [
    "aws"
  ],
  "regions": [
    "ap-southeast-1",
    "ap-southeast-2",
    "ap-northeast-1",
    "eu-central-1",
    "eu-west-1",
    "eu-north-1",
    "us-east-1",
    "us-east-2",
    "us-west-2"
  ],
  "searchKeywords": [
    "Location Service",
    "compromising data security",
    "user privacy",
    "asset tracking",
    "location-based marketing",
    "maps",
    "places",
    "routing",
    "tracking",
    "geofencing",
    "Service Resources"
  ],
  "serviceDescription": "Amazon Location Service provides affordable data, tracking and geofencing capabilities, and native integrations with AWS services, so you can create sophisticated location-enabled applications quickly, without the high cost of custom development.",
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/location/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "locationservice",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/locationservice/[currency]/current/locationservice.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "Location - Service Resources",
      "id": "ServiceResourcesgService",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/location/pricing/"
        }
      },
      "cards": [
        {
          "title": "Service Resources",
          "helpText": "Requests to create, read, update, delete, or list the Amazon Location Service resources, such as a Map resources (used to retrieve map tiles in a specific style), Place Index resources (used to perform geocoding, reverse geocoding, and point-of-interest searches), Route Calculator resources (used to request route calculations), Geofence Collection resources (used to store geofences and evaluate positions against them), and Tracker resources (used to store and retrieve device positions). Requests to link and unlinking resources, such as trackers and geofences, is also considered a resource update.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/location/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "alert",
                "header": "",
                "content": "Volume discounts are available for customers with a monthly usage exceeding $5,000. For more info <a href='https://aws.amazon.com/contact-us/'>Contact us</a>",
                "alertType": "info",
                "isDismissable": true,
                "id": "alertLocationService"
              },
              {
                "type": "input",
                "subType": "bodyText",
                "text": "Select the number of Service Resources. Calculations below exclude free tier discounts.",
                "id": "ServiceResourcesText"
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": "Resource create, read, update, delete, or list requests",
                "id": "numberOfServiceResource",
                "options": [
                  {
                    "label": "per hour",
                    "id": "perHour"
                  },
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "thousand per month",
                    "id": "thousandPerMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  }
                ],
                "defaultFrequency": "thousandPerMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0
                },
                "placeholder": "Enter number of resource create, read, update, delete, or list requests"
              },
              {
                "type": "pricing",
                "subType": "singlePricePoint",
                "label": "Price per resource create, read, update, delete, or list requests",
                "id": "ServiceResourcePrice",
                "mappingDefinitionName": "locationservice",
                "meteredUnit": {
                  "allRegions": "AmazonLocationService None RequestBasedUsage Service Resources Resources created read updated or deleted per API Request"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",
                  "label": "Unit conversions",
                  "refer": [
                    "alertLocationService",
                    "ServiceResourcesText",
                    "numberOfServiceResource",
                    "ServiceResourcePrice"
                  ],
                  "id": "ServiceResourceConvert",
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "ServiceResourceMult",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "numberOfServiceResource",
                      "variableLabel": "Resource create, read, update, delete, or list requests",
                      "variableUnitLabel": "Resource create, read, update, delete, or list requests per month",
                      "required": true
                    },
                    {
                      "variableId": "ServiceResourcePrice",
                      "variableLabel": "Price per resource create, read, update, delete, or list requests",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] per month",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "ServiceResourceMult"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Resource create, read, update, delete, or list requests cost",
                  "decimalPlaces": 2,
                  "id": "Resource create, read, update, delete, or list requestsTotalPrice",
                  "subTotalRefer": "ServiceResourceMult"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
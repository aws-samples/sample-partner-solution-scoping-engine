                  },
                  {
                    "label": "seconds",
                    "value": "sec"
                  },
                  {
                    "label": "hour",
                    "value": "hr"
                  }
                ],
                "outputDurationUnit": "hr",
                "outputDurationLabel": "hours",
                "defaultValue": 0,
                "validations": {
                  "required": true,
                  "minValue": 0.0166,
                  "maxValue": 730,
                  "allowDecimal": false
                },
                "placeholder": "Enter amount",
                "description": {
                  "aws": "Minimum billing duration for each Ray job is 1-minute. AWS bills for Ray jobs in increments of 1 second.",
                  "aws-us-gov": "Minimum billing duration for each Ray job is 1-minute. AWS bills for Ray jobs in increments of 1 second."
                }
              },
              {
                "type": "pricing",

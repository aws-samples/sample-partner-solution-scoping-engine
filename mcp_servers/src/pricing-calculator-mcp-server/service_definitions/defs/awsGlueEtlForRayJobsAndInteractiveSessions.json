                  "subTotalRefer": "",
                  "id": "etlRayJobsRunConversion"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of M-DPUs for Ray ETL job",
                      "variableUnitLabel": "M-DPUs",
                      "required": true,
                      "variableId": "numberOfMDPUsForRayETLJob"
                    },
                    {
                      "variableLabel": "Duration for which Ray ETL job runs",

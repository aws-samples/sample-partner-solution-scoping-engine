            "aws": "AgentCore Runtime is a secure, serverless runtime purpose-built for deploying and scaling dynamic AI agents and tools."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/bedrock/agentcore/"
            }

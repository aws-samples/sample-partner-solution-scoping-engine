{
  "version": "0.0.8",
  "serviceName": {
    "aws": "Amazon Q Business"
  },
  "serviceCode": "amazonQBusiness",
  "type": "AWSService",
  "regions": [],
  "searchKeywords": [
    "Amazon Q Business",
    "Q"
  ],
  "serviceDescription": {
    "aws": "Amazon Q Business is a generative AI–powered assistant that can answer questions, provide summaries, generate content, and securely complete tasks based on data and information in your enterprise systems. It empowers employees to be more creative, data-driven, efficient, prepared, and productive."
  },
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/q/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "q",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/q/[currency]/current/q.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/q/business/pricing/"
        }
      },
      "cards": [
        {
          "title": "Service settings",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "The calculations below exclude Free Tier discounts.",
                "id": "free_tier"
              },
              {
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "q",
                    "meteredUnit": "Amazon Q Lite Subscription Number of Amazon Q Business Lite subscriptions in the service"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_Lite_licences",
                "label": "Number of Lite subscriptions",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1e+25
                },
                "placeholder": "Input number of Lite subscriptions per month.",
                "description": "The Amazon Q Business Lite subscription provides users access to basic functionality such as asking questions and receiving permission-aware responses."
              },
              {
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "q",
                    "meteredUnit": "Amazon Q Pro Subscription Number of Amazon Q Business Pro subscriptions in the service"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_Pro_licences",
                "label": "Number of Pro subscriptions",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1e+25
                },
                "placeholder": "Input number of Pro subscriptions per month.",
                "description": "The Amazon Q Business Pro subscription provides users access to the full suite of Amazon Q Business capabilities, including access to Amazon Q Apps (Preview), and Amazon Q in QuickSight (Reader Pro)."
              },
              {
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "q",
                    "meteredUnit": "Amazon Q Index-Enterprise Enterprise Index"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_documents_(Enterprise)",
                "label": "Number of Indexes (Enterprise)",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1e+25
                },
                "placeholder": "Input number of Enterprise Indexes per month.",
                "description": "The Enterprise Index is deployed across three Availability Zones, making it best for production workloads.The Enterprise Index is deployed across three Availability Zones, making it best for production workloads."
              },
              {
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "q",
                    "meteredUnit": "Amazon Q Index Index"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_documents_(Starter)",
                "label": "Number of Indexes (Starter)",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1e+25
                },
                "placeholder": "Input number of Starter Indexes per month.",
                "description": "The Starter Index is deployed in a single Availability Zone, making it ideal for PoCs and developer workloads."
              },
              {
                "type": "pricing",
                "id": "price_for_Lite_subscription",
                "label": "price for Lite subscription",
                "subType": "singlePricePoint",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "mappingDefinitionName": "q",
                "meteredUnit": {
                  "allRegions": "Amazon Q Lite Subscription Number of Amazon Q Business Lite subscriptions in the service"
                }
              },
              {
                "type": "pricing",
                "id": "price_for_Pro_subscription",
                "label": "price for Pro subscription",
                "subType": "singlePricePoint",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "mappingDefinitionName": "q",
                "meteredUnit": {
                  "allRegions": "Amazon Q Pro Subscription Number of Amazon Q Business Pro subscriptions in the service"
                }
              },
              {
                "type": "pricing",
                "id": "price_for_enterprise_index",
                "label": "price for enterprise index",
                "subType": "singlePricePoint",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "mappingDefinitionName": "q",
                "meteredUnit": {
                  "allRegions": "Amazon Q Index-Enterprise Enterprise Index"
                }
              },
              {
                "type": "pricing",
                "id": "price_for_starter_index",
                "label": "price for starter index",
                "subType": "singlePricePoint",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "mappingDefinitionName": "q",
                "meteredUnit": {
                  "allRegions": "Amazon Q Index Index"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "id": "conv_q",
                  "refer": [
                    "free_tier",
                    "Number_of_Lite_licences",
                    "Number_of_Pro_licences",
                    "Number_of_documents_(Enterprise)",
                    "Number_of_documents_(Starter)",
                    "price_for_Lite_subscription",
                    "price_for_Pro_subscription",
                    "price_for_enterprise_index",
                    "price_for_starter_index"
                  ],
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "Lite_Cost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Number_of_Lite_licences",
                      "variableLabel": "Number of Lite subscriptions",
                      "variableUnitLabel": "subscription(s)",
                      "required": true
                    },
                    {
                      "variableId": "price_for_Lite_subscription",
                      "variableLabel": "price for Lite subscription",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for Lite subscription",
                  "decimalPlaces": 2
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "q",
                      "meteredUnit": "Amazon Q Lite Subscription Number of Amazon Q Business Lite subscriptions in the service"
                    }
                  },
                  "type": "maths",
                  "subType": "variable",
                  "label": "[currency] for Lite subscription ",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] for Lite subscription",
                  "id": "LiteVar",
                  "refer": "Lite_Cost",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "Pro_Cost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Number_of_Pro_licences",
                      "variableLabel": "Number of Pro subscriptions",
                      "variableUnitLabel": "subscription(s)",
                      "required": true
                    },
                    {
                      "variableId": "price_for_Pro_subscription",
                      "variableLabel": "price for Pro subscription",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for Pro subscription",
                  "decimalPlaces": 2
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "q",
                      "meteredUnit": "Amazon Q Pro Subscription Number of Amazon Q Business Pro subscriptions in the service"
                    }
                  },
                  "type": "maths",
                  "subType": "variable",
                  "label": "[currency] for Pro subscription ",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] for Pro subscription",
                  "id": "ProVar",
                  "refer": "Pro_Cost",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "Enterprise_indexes_unrounded",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Number_of_documents_(Enterprise)",
                      "variableLabel": "Number of Indexes (Enterprise)",
                      "variableUnitLabel": "Indexes",
                      "required": true
                    },
                    {
                      "variableId": "price_for_enterprise_index",
                      "variableLabel": "price for enterprise index",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    },
                    {
                      "constant": 24,
                      "constantUnitLabel": "hours in a day"
                    },
                    {
                      "constant": 30,
                      "constantUnitLabel": "days in a month"
                    }
                  ],
                  "outputUnitLabel": "[currency] for Enterprise Index",
                  "decimalPlaces": 5
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "q",
                      "meteredUnit": "Amazon Q Index-Enterprise Enterprise Index"
                    }
                  },
                  "type": "maths",
                  "subType": "variable",
                  "label": "[currency] for Enterprise Index ",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] for Enterprise Index",
                  "id": "ent_ind_Var",
                  "refer": "Enterprise_indexes_unrounded",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "starter_doc_cost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Number_of_documents_(Starter)",
                      "variableLabel": "Number of Indexes (Starter)",
                      "variableUnitLabel": "indexes",
                      "required": true
                    },
                    {
                      "variableId": "price_for_starter_index",
                      "variableLabel": "price for starter index",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    },
                    {
                      "constant": 24,
                      "constantUnitLabel": "hours in a day"
                    },
                    {
                      "constant": 30,
                      "constantUnitLabel": "days in a month"
                    }
                  ],
                  "outputUnitLabel": "[currency] for Starter Index",
                  "decimalPlaces": 2
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "q",
                      "meteredUnit": "Amazon Q Index Index"
                    }
                  },
                  "type": "maths",
                  "subType": "variable",
                  "label": "[currency] for Starter Index ",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] for Starter Index",
                  "id": "start_ind_Var",
                  "refer": "starter_doc_cost",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "total_q_business_Cost",
                  "allowZero": false,
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "Lite_Cost",
                      "variableLabel": "[currency] for Lite subscription",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableId": "Pro_Cost",
                      "variableLabel": "[currency] for Pro subscription",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableId": "Enterprise_indexes_unrounded",
                      "variableLabel": "[currency] for Enterprise Index",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableId": "starter_doc_cost",
                      "variableLabel": "[currency] for Starter Index",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "Lite_Cost",
                    "LiteVar",
                    "Pro_Cost",
                    "ProVar",
                    "Enterprise_indexes_unrounded",
                    "ent_ind_Var",
                    "starter_doc_cost",
                    "start_ind_Var",
                    "total_q_business_Cost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Total cost",
                  "decimalPlaces": 2,
                  "id": "serviceTotalPrice",
                  "subTotalRefer": "total_q_business_Cost"
                }
              ]
            }
          ]
        }
      ],
      "id": "template"
    }
  ],
  "slug": "q",
  "partitions": [
    "aws"
  ]
}
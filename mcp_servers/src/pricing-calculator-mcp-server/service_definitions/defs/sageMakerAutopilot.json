          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "alert",
                "content": "<b>Note:</b> Autopilot takes a usage-based billing approach. The exact cost for an Autopilot job is calculated based on the utilization of the compute resources, i.e. the number of instances used by Autopilot for the duration of the AutoML training job. The resource usage largely depends on your training dataset (such as number of rows and columns) and job attributes (such as problem type, training mode, max runtime, etc.). The estimation logic provided below is derived based on the costs associated with historical Autopilot job runs, and does not accurately reflect the actual bill amount for your Autopilot jobs.",
                "alertType": "info",
                "isDismissable": true,
                "id": "apAlert"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_Autopilot_Jobs_per_month",
                "label": "Number of Autopilot Jobs per month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1e+22
                },
                "placeholder": "Enter Number of Autopilot Jobs per month",
                "description": ""
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_training_hours_per_autopilot_job",
                "label": "Number of training hours per Autopilot job",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 1e-18,
                  "maxValue": 730
                },
                "placeholder": "Enter Number of training hours per autopilot job",
                "description": ""
              },
              {
                "type": "pricing",
                "label": "price for sagemaker autopilot",

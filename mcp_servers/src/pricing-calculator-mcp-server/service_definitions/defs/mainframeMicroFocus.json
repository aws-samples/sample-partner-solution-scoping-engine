{
  "version": "0.0.49",
  "serviceName": "Micro Focus replatforming",
  "serviceCode": "mainframeMicroFocus",
  "type": "AWSService",
  "subType": "subService",
  "regions": [
    "ap-southeast-2",
    "ca-central-1",
    "eu-central-1",
    "eu-west-1",
    "sa-east-1",
    "us-east-1",
    "us-west-2"
  ],
  "serviceDescription": "For AWS M2 Blu Age managed runtime, you can choose on-demand instances and pay for the runtime by the hour with no long-term commitments or upfront fees, or choose committed plans for additional savings.",
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/mainframe-modernization/pricing/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "m2-calc",
      "mappingDefinitionVersion": "PLC_2.0",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/m2/[currency]/current/m2-calc/metadata.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "Micro Focus runtime - Production Environment(s)",
      "description": "Quick estimate: Use the quick estimate for a fast route to a rough estimate. ",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/mainframe-modernization/pricing/"
        }
      },
      "id": "template_microFocus",
      "cards": [
        {
          "title": "Info",
          "bodyText": "",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "alert",
                "header": "Committed plans",
                "label": "Committed plans",
                "content": "<p> AWS Mainframe Modernization service, various components have different prices. You only pay for what you use with no upfront commitment or minimum fee. Alternatively, you can select committed plans for additional savings.Committed plans are appropriate for steady-state workloads and offer significant savings over on-demand pricing.</p>",
                "alertType": "info",
                "isDismissable": true,
                "id": "microFocus_infoAlert"
              }
            ]
          }
        },
        {
          "title": "Micro Focus Production Environment",
          "helpText": "For the AWS Mainframe Modernization Micro Focus managed runtime, you can choose on-demand instances and pay for the runtime by the hour with no long-term commitments or upfront fees, or choose committed plans for additional savings.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/mainframe-modernization/pricing/"
            }
          },
          "bodyText": "",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "columnFormIPM",
                "mappingDefinitionName": "m2-calc",
                "disableCalculation": true,
                "id": "columnFormIPM_microProd",
                "calculationId": {
                  "hourly": "microFocusProd_ipmPrice"
                },
                "remap": {
                  "constant": {
                    "Product Name": "Enterprise Server"
                  }
                },
                "primaryKey": "Product Name",
                "secondaryKey": [
                  "Instance Type"
                ],
                "row": [
                  {
                    "type": "textInput",
                    "label": "Number of instances",
                    "selectorId": "Number of Instances",
                    "validations": {
                      "required": true,
                      "allowDecimals": false,
                      "minValue": 1,
                      "maxValue": 10000000000
                    },
                    "exportValueAs": "microFocusProd_count"
                  },
                  {
                    "label": "Instance type",
                    "type": "dropDown",
                    "selectorId": "Instance Type",
                    "defaultValue": "m5.large"
                  }
                ]
              },
              {
                "type": "input",
                "subType": "utilization",
                "label": "Monthly utilization",
                "id": "utilized_microFocusProd",
                "placeholder": "Enter number",
                "displayInConfigSummary": true,
                "defaultValue": 160,
                "defaultDuration": "hoursPerMonth",
                "roundUpToHours": true,
                "validations": {
                  "required": true
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",
                  "label": "Unit conversions",
                  "refer": [
                    "columnFormIPM_microProd",
                    "utilized_microFocusProd"
                  ],
                  "id": "unitConvertMicroFocusProd",
                  "decimalPlaces": 2,
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Total Number of Instances",
                      "variableUnitLabel": "instance(s)",
                      "required": true,
                      "variableId": "microFocusProd_count",
                      "IPMSupported": true
                    },
                    {
                      "variableLabel": "Micro Focus Production Price",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "microFocusProd_ipmPrice",
                      "IPMSupported": true
                    },
                    {
                      "variableUnitLabel": "hours per month",
                      "required": true,
                      "variableId": "utilized_microFocusProd"
                    }
                  ],
                  "refer": [
                    "microFocusProd_count",
                    "microFocusProd_ipmPrice"
                  ],
                  "outputUnitLabel": "[currency] (Micro Focus runtime production environment(s) cost)",
                  "decimalPlaces": 2,
                  "id": "microFocusProdCost"
                },
                {
                  "type": "display",
                  "subType": "priceDisplay",
                  "refer": [
                    "microFocusProdCost"
                  ],
                  "costType": "Monthly",
                  "label": "Micro Focus runtime production environment(s) cost",
                  "decimalPlaces": 2,
                  "subTotalRefer": "microFocusProdCost",
                  "id": "microFocus_Prod"
                }
              ]
            }
          ]
        },
        {

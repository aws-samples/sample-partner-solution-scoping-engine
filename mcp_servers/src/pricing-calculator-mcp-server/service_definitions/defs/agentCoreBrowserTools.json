        }
      },
      "cards": [
        {
          "title": "Browser Tools",
          "helpText": {
            "aws": "AgentCore Browser Tools enable agents to interact with web content."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/bedrock/agentcore/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_agentsessions_per_month",
                "label": "Number of agent sessions per month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 100000000000000000
                },
                "description": "The total number of agent sessions expected to run per month"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Average_session_duration_seconds",
                "label": "Average Session Duration (seconds)",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 100000000000000000
                },
                "description": "The average length of each agent session, measured in seconds."
              },
              {
                "type": "input",
                "subType": "percentInput",
                "id": "IO_wait_time_percentage",
                "label": "I/O Wait Time (%)",
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100
                },
                "placeholder": "Enter %",
                "displayInConfigSummary": true,
                "description": "The percentage of time your agent spends waiting for a tool or foundational model to respond. This idle time is not factored into your compute cost."
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "vCPU_per_browser_session",
                "label": "vCPU per Browser Session",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0.1,
                  "maxValue": 64
                },
                "description": "Total number of vCPU allocated to a single browser session"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Memory_per_browser_session_GB",
                "label": "Memory per Browser Session (GB)",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0.1,
                  "maxValue": 256
                },
                "description": "The amount of memory (in GB) allocated for each browser session"
              },
              {
                "type": "pricing",
                "id": "cpusession",
                "label": "Price for cpu per session",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "bedrockagentcore",

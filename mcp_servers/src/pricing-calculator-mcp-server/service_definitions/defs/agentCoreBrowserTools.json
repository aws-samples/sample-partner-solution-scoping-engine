                  "allRegions": "kDAyGksfgGqO7sejjw-Rn6hmsqe788WtiO6O6x_1njo"
                }
              },
              {
                "type": "pricing",
                "id": "memorysession",
                "label": "Price for memory per session",
                "subType": "singlePricePoint",

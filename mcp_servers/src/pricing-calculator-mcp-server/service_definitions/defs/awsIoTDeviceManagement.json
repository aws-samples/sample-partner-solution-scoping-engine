      "cards": [
        {
          "title": "Fleet Indexing - Updates",
          "expandable": true,
          "defaultExpansion": false,
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "id": "indexUpdates",
                "label": "Number of Fleet Index updates",
                "description": "Enter the average number of index updates a device makes per month.",
                "displayInConfigSummary": true,
                "defaultValue": 0,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100000000
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "deviceUpdates",
                "label": "Number of devices",
                "description": "Enter the number of devices that execute an index update per month.",
                "displayInConfigSummary": true,
                "defaultValue": 0,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1000000000
                }
              },
              {
                "type": "input",
                "subType": "fileSize",
                "label": "Average size of each index update",
                "id": "dataPerIndexUpdate",
                "dropDownSize": [
                  {
                    "label": "Bytes",
                    "id": "bytes"
                  },
                  {
                    "label": "KB",
                    "id": "kb"
                  }
                ],
                "defaultOption": {
                  "size": "kb",
                  "frequency": "NA"
                },
                "outputSize": "kb",
                "defaultValue": 1,
                "outputSizeLabel": "KB",
                "outputFrequency": "NA",
                "outputFrequencyLabel": "NA",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 10240
                },
                "placeholder": "Enter amount",
                "description": "Index updates are metered in 1 KB increments; an 1.5 KB index update is metered as two index updates."
              },
              {
                "type": "pricing",
                "id": "indexUpdatePricing",
                "label": "Price per index update",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "iotdevicemanagement",
                "meteredUnit": {
                  "allRegions": "Index Updates"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "indexUpdateSizeDiv",
                  "operation": "division",
                  "outputUnitLabel": "update(s)",
                  "decimalPlaces": 0,
                  "operands": [
                    {
                      "variableId": "dataPerIndexUpdate",
                      "variableLabel": "Average size of each index update",
                      "variableUnitLabel": "KB per index update",
                      "required": true
                    },
                    {
                      "constant": 1,
                      "constantUnitLabel": "KB update increment"
                    }
                  ]
                },
                {
                  "type": "maths",
                  "subType": "rounding",
                  "method": "roundUp",
                  "factor": 1,
                  "operationLabel": "Round Up",
                  "operands": [
                    {
                      "variableId": "indexUpdateSizeDiv",
                      "variableLabel": "update(s)",
                      "variableUnitLabel": "update(s)",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "index update(s)",
                  "id": "indexUpdateRounded"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "indexUpdateMonthlyCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "indexUpdates",
                      "variableLabel": "Number of Fleet Index updates",
                      "variableUnitLabel": "index updates per month",
                      "required": true
                    },
                    {
                      "variableId": "indexUpdateRounded",
                      "variableLabel": "index update(s)",
                      "variableUnitLabel": "index update(s)",
                      "required": true
                    },
                    {
                      "variableId": "deviceUpdates",
                      "variableLabel": "Number of devices",
                      "variableUnitLabel": "devices",
                      "required": true
                    },
                    {
                      "variableId": "indexUpdatePricing",
                      "variableLabel": "Price per index update",
                      "variableUnitLabel": "[currency] per index update",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] per month",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "indexUpdates",
                    "deviceUpdates",
                    "dataPerIndexUpdate",
                    "indexUpdatePricing",
                    "indexUpdateSizeDiv",
                    "indexUpdateRounded",
                    "indexUpdateMonthlyCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Fleet Index update cost",
                  "decimalPlaces": 2,
                  "id": "indexUpdateTotalPrice",
                  "subTotalRefer": "indexUpdateMonthlyCost"
                }
              ]
            }
          ]
        },

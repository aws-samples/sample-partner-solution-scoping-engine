  "serviceDescription": {
    "aws": "Amazon Q Developer is the most capable generative AI-powered assistant for building, operating, and transforming software, with advanced capabilities for managing data and AI/ML. Amazon Q Developer goes beyond coding to help developers and IT professionals with all of their tasks— from coding, testing, and deploying, to troubleshooting, performing security scanning and fixes, modernizing applications, optimizing AWS resources, and creating data engineering pipelines. Data scientists can get guidance to quickly and easily build analytics, AI/ML, and generative AI applications."
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "codewhisperer",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/codewhisperer/[currency]/current/codewhisperer.json"
    }
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/q/developer/"
    }
  },
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/q/developer/"
        }
      },
      "cards": [
        {
          "title": "Amazon Q Developer",
          "helpText": {
            "aws": "Amazon Q Developer reimagines the experience across the entire software development lifecycle (SDLC), making it faster and easier to build, secure, manage, and optimize applications on or off of AWS. Amazon Q Developer offers two pricing tiers."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/codewhisperer/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_users_per_month",
                "label": "Number of users per month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 100000000000000000000
                }
              },
              {
                "type": "pricing",
                "label": "Price per user",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "codewhisperer",
                "meteredUnit": {
                  "allRegions": "codewhisperer Professional UsersPerMonth"
                },
                "id": "Price_per_user"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "Number_of_users_per_month",
                    "Price_per_user"
                  ],
                  "subTotalRefer": "",
                  "id": "UnitConvCodeCommit"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "prof_mnthly_price",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of users per month",
                      "variableUnitLabel": "users",
                      "required": true,
                      "variableId": "Number_of_users_per_month"
                    },
                    {
                      "variableLabel": "Price per user",
                      "variableUnitLabel": "[currency]/user/month",
                      "required": true,
                      "variableId": "Price_per_user"
                    }
                  ],
                  "outputUnitLabel": "[currency] per month",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "prof_mnthly_price"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Amazon Q Developer cost",
                  "decimalPlaces": 2,
                  "id": "CodeWhispererTot",
                  "subTotalRefer": "prof_mnthly_price"
                }
              ]
            }
          ]
        }
      ],
      "id": "template_0"
    }

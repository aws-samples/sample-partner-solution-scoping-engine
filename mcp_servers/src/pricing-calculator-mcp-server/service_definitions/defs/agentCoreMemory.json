                  "outputUnitLabel": "Short-term memory events"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "Short_term_memory_cost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Short_term_memory_events",
                      "variableLabel": "Short-term memory events",
                      "variableUnitLabel": "events",
                      "required": true
                    },
                    {
                      "variableId": "shortterm_memory_price",
                      "variableLabel": "Price for short-term memory",
                      "variableUnitLabel": "[currency] per event",
                      "required": true

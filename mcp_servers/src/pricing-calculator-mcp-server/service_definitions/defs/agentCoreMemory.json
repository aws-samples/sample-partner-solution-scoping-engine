      "cards": [
        {
          "title": "Memory",
          "helpText": {
            "aws": "AgentCore Memory service for managing short-term and long-term memory for AI agents"
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_agentsessions_per_month",
                "label": "Number of agent sessions per month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 100000000000000000
                },
                "description": "The total number of agent sessions expected to run per month"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Average_turns_per_session",
                "label": "Average number of turns per session (real time)",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1000000000000
                },
                "description": "Average number of conversational exchanges between a user and an AI agent within a single session"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Average_session_duration_seconds",
                "label": "Average Session Duration (seconds)",

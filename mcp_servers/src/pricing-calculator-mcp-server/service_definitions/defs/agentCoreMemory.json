            {
              "components": [
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "Short_term_memory_events",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Number_of_agentsessions_per_month",
                      "variableLabel": "Number of agent sessions per month",
                      "variableUnitLabel": "sessions",
                      "required": true
                    },
                    {
                      "variableId": "Average_turns_per_session",
                      "variableLabel": "Average number of turns per session (real time)",
                      "variableUnitLabel": "turns",
                      "required": true
                    }

                  "subType": "basicMaths",
                  "id": "Long_term_storage_cost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "Built_in_storage_cost",
                      "variableLabel": "Built-in long-term storage cost",
                      "variableUnitLabel": "[currency] Built-in long term storage",
                      "required": true
                    },
                    {
                      "variableId": "Custom_storage_cost",
                      "variableLabel": "Custom long-term storage cost",
                      "variableUnitLabel": "[currency] Custom long-term storage",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "Long-term storage cost"
                },

                    {
                      "variableId": "Short_term_memory_events",
                      "variableLabel": "Short-term memory events",
                      "variableUnitLabel": "events",
                      "required": true
                    },
                    {
                      "constant": 2,
                      "constantUnitLabel": "strategies"
                    },
                    {
                      "constant": 0.03,
                      "constantUnitLabel": "extraction rate (estimated 2 strategies x 3% extraction rate from short term events)"
                    }
                  ],
                  "outputUnitLabel": "Built-in long-term memory extracted"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "Custom_memory_extraction",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Short_term_memory_events",
                      "variableLabel": "Short-term memory events",
                      "variableUnitLabel": "events",
                      "required": true
                    },
                    {
                      "constant": 3,
                      "constantUnitLabel": "strategies"
                    },
                    {
                      "constant": 0.01,
                      "constantUnitLabel": "extraction rate (estimated 3 strategies x 1% extraction rate)"
                    }
                  ],
                  "outputUnitLabel": "Custom long-term memory extracted"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "Built_in_storage_cost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Built_in_memory_extraction",
                      "variableLabel": "Built-in long-term memory extracted",
                      "variableUnitLabel": "events",
                      "required": true
                    },
                    {
                      "variableId": "builtin_storage_price",
                      "variableLabel": "Price for built-in long-term storage",
                      "variableUnitLabel": "[currency] per event",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "Built-in long-term storage cost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "Custom_storage_cost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Custom_memory_extraction",
                      "variableLabel": "Custom long-term memory extracted",
                      "variableUnitLabel": "events",
                      "required": true
                    },
                    {
                      "variableId": "custom_storage_price",
                      "variableLabel": "Price for custom long-term storage",
                      "variableUnitLabel": "[currency] per event",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "Custom long-term storage cost"

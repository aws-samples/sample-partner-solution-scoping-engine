                    {
                      "variableId": "Average_session_duration_seconds",
                      "variableLabel": "Average Session Duration (seconds)",
                      "variableUnitLabel": "seconds",
                      "required": true
                    },
                    {
                      "constant": 120,
                      "constantUnitLabel": "seconds per retrieval"
                    }
                  ],
                  "outputUnitLabel": "Memory Retrievals per session"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "Memory_retrievals",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Retrieval_rate",
                      "variableLabel": "Memory Retrievals per session",
                      "variableUnitLabel": "retrievals",
                      "required": true

                  "subType": "basicMaths",
                  "id": "Total_monthly_cost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "Short_term_memory_cost",
                      "variableLabel": "Short-term memory cost",
                      "variableUnitLabel": "[currency] Short-term memory",
                      "required": true
                    },
                    {
                      "variableId": "Long_term_storage_cost",
                      "variableLabel": "Long-term storage cost",
                      "variableUnitLabel": "[currency] Long-term storage",
                      "required": true
                    },
                    {
                      "variableId": "Memory_retrieval_cost",
                      "variableLabel": "Long-term Memory retrieval cost",
                      "variableUnitLabel": "[currency] Long-term Memory retrieval",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "Memory Monthly Cost"
                },
                {
                  "type": "display",
                  "refer": [
                    "Number_of_agentsessions_per_month",
                    "Average_turns_per_session",
                    "Average_session_duration_seconds",
                    "shortterm_memory_price",
                    "builtin_storage_price",
                    "custom_storage_price",
                    "retrieval_price",
                    "Short_term_memory_events",
                    "Short_term_memory_cost",
                    "Built_in_memory_extraction",
                    "Custom_memory_extraction",
                    "Built_in_storage_cost",
                    "Custom_storage_cost",
                    "Retrieval_rate",
                    "Memory_retrievals",
                    "Memory_retrieval_cost",
                    "Long_term_storage_cost",
                    "Total_monthly_cost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Memory Cost",
                  "decimalPlaces": 2,
                  "id": "tot_cost_memory",
                  "subTotalRefer": "Total_monthly_cost"
                }
              ]
            }
          ]
        }

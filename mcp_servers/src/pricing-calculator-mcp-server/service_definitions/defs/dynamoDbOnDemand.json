                            "mappingDefinitionName": "dynamodb",
                            "meteredUnit": "PayPerRequest Write Request Units IA"
                          }
                        },
                        {
                          "exists": {
                            "type": "meteredUnit",
                            "mappingDefinitionName": "dynamodb",
                            "meteredUnit": "PayPerRequest Read Request Units IA"
                          }
                        }
                      ]
                    },
                    "label": "Standard-Infrequent Access",
                    "id": "IA"
                  }
                ],

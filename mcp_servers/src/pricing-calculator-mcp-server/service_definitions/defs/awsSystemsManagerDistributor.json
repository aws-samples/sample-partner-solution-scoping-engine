{
  "version": "0.0.21",
  "serviceName": "Distributor",
  "serviceCode": "awsSystemsManagerDistributor",
  "type": "AWSService",
  "subType": "subService",
  "displayAutomation": true,
  "regions": [],
  "searchKeywords": [
    "System Manager",
    "Distributor",
    "distriubte and maintain software packages"
  ],
  "serviceDescription": {
    "aws": "AWS Systems Manager Distributor feature",
    "aws-cn": "Amazon Systems Manager Distributor feature"
  },
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/systems-manager/"
    }
  },
  "hasDataTransfer": false,
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "systemsmanager",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/systemsmanager/[currency]/current/systemsmanager.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": {
        "aws": "AWS Systems Manager Distributor feature",
        "aws-cn": "Amazon Systems Manager Distributor feature"
      },
      "id": "smDistributor",
      "description": "",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/systems-manager/"
        }
      },
      "cards": [
        {
          "displayIf": {
            "and": [
              {
                "exists": {
                  "type": "meteredUnit",
                  "mappingDefinitionName": "systemsmanager",
                  "meteredUnit": "Storage per GB Mo"
                }
              },
              {
                "exists": {
                  "type": "meteredUnit",
                  "mappingDefinitionName": "systemsmanager",
                  "meteredUnit": "Get or Describe per API Requests"
                }
              },
              {
                "exists": {
                  "type": "meteredUnit",
                  "mappingDefinitionName": "systemsmanager",
                  "meteredUnit": "DataTransfer per GB"
                }
              }
            ]
          },
          "title": "Distributor",
          "helpText": {
            "aws": "Distributor, a Systems Manager feature, helps you distribute and maintain software packages, such as software agents, on your instances. These packages can be AWS service agents, third party owned, or your own agents imported into Systems Manager. Distribution and update checks of AWS agents and third party owned agents are provided at no additional charge. For your own packages, you pay only for what you use. Upon transferring a package into Distributor, you will be charged based on the size and duration of storage for that package, the number of Get and Describe API requests made, and the amount of out-of-Region and on-premises data transfer out of Distributor for those packages.",
            "aws-cn": "Distributor, a Systems Manager feature, helps you distribute and maintain software packages, such as software agents, on your instances. These packages can be Amazon service agents, third party owned, or your own agents imported into Systems Manager. Distribution and update checks of Amazon agents and third party owned agents are provided at no additional charge. For your own packages, you pay only for what you use. Upon transferring a package into Distributor, you will be charged based on the size and duration of storage for that package, the number of Get and Describe API requests made, and the amount of out-of-Region and on-premises data transfer out of Distributor for those packages."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/systems-manager/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "",
                "id": "sysManagerDist_Text"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": {
                  "aws": "Non-AWS/third-party software packages stored",
                  "aws-cn": "Non-Amazon/third-party software packages stored"
                },
                "id": "sysManagerDist_numberOfNonAWSPackages",
                "placeholder": {
                  "aws": "Enter number of non-AWS/third-party software packages",
                  "aws-cn": "Enter number of non-Amazon/third-party software packages"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1000000000
                }
              },
              {
                "type": "input",
                "subType": "fileSize",
                "label": {
                  "aws": "Average size of non-AWS/third-party software packages",
                  "aws-cn": "Average size of non-Amazon/third-party software packages"
                },
                "id": "sysManagerDist_nonAWSPackSize",
                "dropDownSize": [
                  {
                    "label": "KB",
                    "id": "kb"
                  },
                  {
                    "label": "MB",
                    "id": "mb"
                  },
                  {
                    "label": "GB",
                    "id": "gb"
                  }
                ],
                "defaultOption": {
                  "size": "mb",
                  "frequency": "NA"
                },
                "outputSize": "gb",
                "defaultValue": 100,
                "outputSizeLabel": "GB",
                "outputFrequency": "NA",
                "outputFrequencyLabel": "NA",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 1e-08,
                  "maxValue": 10000000
                },
                "placeholder": {
                  "aws": "Enter average size for non-AWS/third-party software packages",
                  "aws-cn": "Enter average size for non-Amazon/third-party software packages"
                },
                "description": "",
                "help": ""
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": {
                  "aws": "Frequency of Get/Describe API requests for non-AWS/third-party software packages",
                  "aws-cn": "Frequency of Get/Describe API requests for non-Amazon/third-party software packages"
                },
                "id": "sysManagerDist_numberOfGetDescAPIRequests",
                "options": [
                  {
                    "label": "per second",
                    "id": "perSecond"
                  },
                  {
                    "label": "per minute",
                    "id": "perMinute"
                  },
                  {
                    "label": "per hour",
                    "id": "perHour"
                  },
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perDay",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true
                },
                "placeholder": "Enter number of Get/Describe API requests"
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": "Frequency of out of region or on-premises installs",
                "id": "sysManagerDist_numberOfInstalls",
                "options": [
                  {
                    "label": "per second",
                    "id": "perSecond"
                  },
                  {
                    "label": "per minute",
                    "id": "perMinute"
                  },
                  {
                    "label": "per hour",
                    "id": "perHour"
                  },
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true
                },
                "placeholder": "Enter number of out of region/on-premises instance installs",
                "description": "You are only charged for data transfer for installations that occur in a different region from where the package is stored or on-premises."
              },
              {
                "type": "pricing",
                "id": "sysManagerDist_NonAWSStoragePrice",
                "label": {
                  "aws": "Price for storing non-AWS packages",
                  "aws-cn": "Price for storing non-Amazon packages"
                },
                "subType": "singlePricePoint",
                "mappingDefinitionName": "systemsmanager",
                "meteredUnit": {
                  "allRegions": "Storage per GB Mo"
                }
              },
              {
                "type": "pricing",
                "id": "sysManagerDist_GetDescAPIPrice",
                "label": "Price for Get or Describe API requests",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "systemsmanager",
                "meteredUnit": {
                  "allRegions": "Get or Describe per API Requests"
                }
              },
              {
                "type": "pricing",
                "id": "sysManagerDist_dataTransferPrice",
                "label": "Price for distributor data transfer per GB",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "systemsmanager",
                "meteredUnit": {
                  "allRegions": "DataTransfer per GB"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",
                  "label": "Unit conversions systems manager distributor",
                  "refer": [
                    "sysManagerDist_Text",
                    "sysManagerDist_numberOfNonAWSPackages",
                    "sysManagerDist_nonAWSPackSize",
                    "sysManagerDist_numberOfGetDescAPIRequests",
                    "sysManagerDist_numberOfInstalls",
                    "sysManagerDist_NonAWSStoragePrice",
                    "sysManagerDist_GetDescAPIPrice",
                    "sysManagerDist_dataTransferPrice"
                  ],
                  "id": "sysManagerDist_unitConvert",
                  "decimalPlaces": 2,
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "sysManagerDist_nonAWSPackageStore",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "sysManagerDist_numberOfNonAWSPackages",
                      "variableLabel": {
                        "aws": "Non-AWS/third-party software packages stored",
                        "aws-cn": "Non-Amazon/third-party software packages stored"
                      },
                      "variableUnitLabel": "packages",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerDist_nonAWSPackSize",
                      "variableLabel": {
                        "aws": "Average size of non-AWS/third-party software packages",
                        "aws-cn": "Average size of non-Amazon/third-party software packages"
                      },
                      "variableUnitLabel": "GB",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerDist_NonAWSStoragePrice",
                      "variableLabel": {
                        "aws": "Price for storing non-AWS packages",
                        "aws-cn": "Price for storing non-Amazon packages"
                      },
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": {
                    "aws": "[currency] for non-AWS/third-party software package storage",
                    "aws-cn": "[currency] for non-Amazon/third-party software package storage"
                  },
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "rounding",
                  "method": "roundUp",
                  "factor": 1,
                  "operationLabel": "RoundUp",
                  "operands": [
                    {
                      "variableLabel": {
                        "aws": "Frequency of Get/Describe API requests for non-AWS/third-party software packages",
                        "aws-cn": "Frequency of Get/Describe API requests for non-Amazon/third-party software packages"
                      },
                      "variableUnitLabel": "requests",
                      "required": true,
                      "variableId": "sysManagerDist_numberOfGetDescAPIRequests"
                    }
                  ],
                  "outputUnitLabel": "API requests (rounded)",
                  "id": "sysManagerDist_roundAPIRequests"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "sysManagerDist_totalGetDescAPICost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "sysManagerDist_roundAPIRequests",
                      "variableLabel": "API requests (rounded)",
                      "variableUnitLabel": "API requests",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerDist_GetDescAPIPrice",
                      "variableLabel": "Price for Get or Describe API requests",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for Get/Describe API requests",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "sysManagerDist_dataTransferCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "sysManagerDist_numberOfNonAWSPackages",
                      "variableLabel": {
                        "aws": "Non-AWS/third-party software packages stored",
                        "aws-cn": "Non-Amazon/third-party software packages stored"
                      },
                      "variableUnitLabel": "packages",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerDist_nonAWSPackSize",
                      "variableLabel": {
                        "aws": "Average size of non-AWS/third-party software packages",
                        "aws-cn": "Average size of non-Amazon/third-party software packages"
                      },
                      "variableUnitLabel": "GB",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerDist_numberOfInstalls",
                      "variableLabel": "Frequency of out of region or on-premises installs",
                      "variableUnitLabel": "installs",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerDist_dataTransferPrice",
                      "variableLabel": "Price for distributor data transfer per GB",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for on-premises/out of region data transfer",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "sysManagerDist_totalDistCost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "sysManagerDist_nonAWSPackageStore",
                      "variableLabel": {
                        "aws": "[currency] for non-AWS/third-party software package storage",
                        "aws-cn": "[currency] for non-Amazon/third-party software package storage"
                      },
                      "variableUnitLabel": "[currency]",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerDist_totalGetDescAPICost",
                      "variableLabel": "[currency] for Get/Describe API requests",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableId": "sysManagerDist_dataTransferCost",
                      "variableLabel": "[currency] for on-premises/out of region data transfer",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "sysManagerDist_nonAWSPackageStore",
                    "sysManagerDist_roundAPIRequests",
                    "sysManagerDist_totalGetDescAPICost",
                    "sysManagerDist_dataTransferCost",
                    "sysManagerDist_totalDistCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Distributor cost",
                  "decimalPlaces": 2,
                  "id": "sysManagerDist_TotalPrice",
                  "subTotalRefer": "sysManagerDist_totalDistCost"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws",
    "aws-cn",
    "aws-us-gov"
  ]
}
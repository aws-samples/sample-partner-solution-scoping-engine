  "searchKeywords": [
    "System Manager",
    "OpsCenter",
    "operational issues",
    "OpsItems"
  ],
  "serviceDescription": {
    "aws": "AWS Systems Manager OpsCenter feature",
    "aws-cn": "Amazon Systems Manager OpsCenter feature"
  },
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/systems-manager/"
    }
  },
  "hasDataTransfer": false,
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "systemsmanager",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/systemsmanager/[currency]/current/systemsmanager.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": {
        "aws": "AWS Systems Manager Automation feature",
        "aws-cn": "Amazon Systems Manager Automation feature"
      },
      "id": "smOpsCenter",
      "description": "",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/systems-manager/"
        }
      },
      "cards": [
        {
          "title": "OpsCenter",
          "helpText": {
            "aws": "OpsCenter provides a central location where operations engineers and IT professionals can view, investigate, and resolve operational work items (OpsItems) related to AWS resources. Operational issues, referred to as OpsItems, are aggregated and standardized in a consolidated view, providing contextually relevant data that helps with diagnosis and remediation.",
            "aws-cn": "OpsCenter provides a central location where operations engineers and IT professionals can view, investigate, and resolve operational work items (OpsItems) related to Amazon resources. Operational issues, referred to as OpsItems, are aggregated and standardized in a consolidated view, providing contextually relevant data that helps with diagnosis and remediation."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/systems-manager/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "OpsCenter is priced on a pay per use model. You’ll be charged based on the number of OpsItems created in your account per month, as well as the number of Get, Describe, Update, and GetOpsSummary API calls made. Additionally, the service calls other public APIs in order to surface relevant diagnostic information, which will be included in the bill from each respective service.",
                "id": "sysManagerOpsCenter_Text"
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": "Frequency of OpsItems (operational work items)",
                "id": "sysManagerOpsCenter_numberOfOpsItems",
                "options": [
                  {
                    "label": "per second",
                    "id": "perSecond"
                  },
                  {
                    "label": "per minute",
                    "id": "perMinute"
                  },
                  {
                    "label": "per hour",
                    "id": "perHour"
                  },
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perSecond",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false
                },
                "placeholder": "Enter number of OpsItems",
                "description": "OpsItems have a limit of 10,000 OpsItems per account per month."
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": "Frequency of Get, Describe, Update, and GetOpsSummary API requests",
                "id": "sysManagerOpsCenter_numberOfOpsItemAPIRequests",
                "options": [
                  {
                    "label": "per second",
                    "id": "perSecond"
                  },
                  {
                    "label": "per minute",
                    "id": "perMinute"
                  },
                  {
                    "label": "per hour",
                    "id": "perHour"
                  },
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perSecond",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false
                },
                "placeholder": "Enter number of API requests for your OpsItems",
                "description": ""
              },
              {
                "type": "pricing",
                "id": "sysManagerOpsCenter_opsItemPrice",
                "label": "Price per OpsItem",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "systemsmanager",
                "meteredUnit": {
                  "allRegions": "Ops Item"
                }
              },
              {
                "type": "pricing",
                "id": "sysManagerOpsCenter_opsItemAPIPrice",
                "label": "Price per OpsItem API request",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "systemsmanager",
                "meteredUnit": {
                  "allRegions": "OpsItem API Request"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",
                  "label": "Unit conversions OpsCenter",
                  "refer": [
                    "sysManagerOpsCenter_Text",
                    "sysManagerOpsCenter_numberOfOpsItems",
                    "sysManagerOpsCenter_numberOfOpsItemAPIRequests",
                    "sysManagerOpsCenter_opsItemPrice",
                    "sysManagerOpsCenter_opsItemAPIPrice"
                  ],
                  "id": "sysManagerOpsCenter_unitConvert",
                  "decimalPlaces": 2,
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "sysManagerOpsCenter_totalOpsItemCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "sysManagerOpsCenter_numberOfOpsItems",
                      "variableLabel": "Frequency of OpsItems (operational work items)",
                      "variableUnitLabel": "OpsItems created",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerOpsCenter_opsItemPrice",
                      "variableLabel": "Price per OpsItem",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for OpsItems",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "sysManagerOpsCenter_totalOpsItemAPICost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "sysManagerOpsCenter_numberOfOpsItemAPIRequests",
                      "variableLabel": "Frequency of Get, Describe, Update, and GetOpsSummary API requests",
                      "variableUnitLabel": "API requests",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerOpsCenter_opsItemAPIPrice",
                      "variableLabel": "Price per OpsItem API request",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for OpsItem API requests",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "sysManagerOpsCenter_totalCost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "sysManagerOpsCenter_totalOpsItemCost",
                      "variableLabel": "[currency] for OpsItems",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerOpsCenter_totalOpsItemAPICost",
                      "variableLabel": "[currency] for OpsItem API requests",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "sysManagerOpsCenter_totalOpsItemCost",
                    "sysManagerOpsCenter_totalOpsItemAPICost",
                    "sysManagerOpsCenter_totalCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "OpsCenter cost",
                  "decimalPlaces": 2,
                  "id": "sysManagerOpsCenter_totalPrice",
                  "subTotalRefer": "sysManagerOpsCenter_totalCost"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws",
    "aws-cn",
    "aws-us-gov"
  ]
}
{
  "version": "0.0.17",
  "serviceName": "Incident Manager",
  "serviceCode": "awsSystemsManagerIncidentManager",
  "type": "AWSService",
  "subType": "subService",
  "regions": [
    "us-east-1",
    "us-east-2",
    "us-west-2",

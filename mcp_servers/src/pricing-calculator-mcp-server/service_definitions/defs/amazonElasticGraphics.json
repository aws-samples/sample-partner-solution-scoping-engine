{
  "version": "0.0.12",
  "serviceName": "Amazon Elastic Graphics",
  "serviceCode": "amazonElasticGraphics",
  "type": "AWSService",
  "regions": [
    "ap-southeast-1",
    "ap-southeast-2",
    "ap-northeast-1",
    "eu-central-1",
    "eu-west-1",
    "us-east-1",
    "us-east-2",
    "us-west-2"
  ],
  "searchKeywords": [
    "Compute",
    "Elastic Compute Cloud",
    "spot instance",
    "load balancing",
    "elb",
    "elastic load balancer",
    "auto scaling",
    "auto scaling groups",
    "application load balancer",
    "ALB",
    "spot requests",
    "reserved instances",
    "scheduled instances",
    "dedicated hosts",
    "AMIs",
    "Bundle tasks",
    "Volumes",
    "Snapshots",
    "Images",
    "Elastic Block Store",
    "block storage",
    "Security groups",
    "Elastic IP",
    "placement groups",
    "key pairs",
    "network interfaces",
    "load balancers",
    "target groups",
    "auto scaler",
    "launch configurations",
    "EBS",
    "ASG",
    "commands",
    "Elastic Graphics",
    "command history",
    "managed instances",
    "activations"
  ],
  "serviceDescription": "Amazon Elastic Graphics allows you to easily attach low-cost graphics acceleration to a wide range of EC2 instances over the network.",
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "elasticgraphics",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/ec2/[currency]/current/elasticgraphics.json"
    },
    {
      "mappingDefinitionVersion": "PLC_2.0",
      "mappingDefinitionName": "elasticgraphics-calc",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/ec2/[currency]/current/elasticgraphics-calc/metadata.json"
    }
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/ec2/elastic-graphics/"
    }
  },
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "Configure Elastic Graphics",
      "description": "",
      "id": "elasticGraphics",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/ec2/elastic-graphics/pricing/"
        }
      },
      "cards": [
        {
          "title": "Data Instances",
          "inputSection": {
            "components": [
              {
                "label": "data Instances",
                "id": "columnFormIPM",
                "type": "input",
                "subType": "columnFormIPM",
                "mappingDefinitionName": "elasticgraphics-calc",
                "calculationId": {
                  "monthly": "monthly_ipm"
                },
                "prioritizedKey": {
                  "Elastic Graphics Type": 49,
                  "GPU Memory": 7
                },
                "primaryKey": {
                  "Elastic Graphics Type": [
                    "GPU Memory"
                  ]
                },
                "secondaryKey": [
                  "Product Family",
                  "TermType"
                ],
                "row": [
                  {
                    "label": "Number of nodes",
                    "type": "textInput",
                    "selectorId": "Number of Nodes",
                    "description": "",
                    "validations": {
                      "allowDecimals": false,
                      "minValue": 0,
                      "maxValue": 1000000,
                      "required": true
                    },
                    "exportValueAs": "count"
                  },
                  {
                    "label": "Instance type",
                    "type": "autoSuggest",
                    "selectorId": "Elastic Graphics Type",
                    "withTags": [
                      "GPU Memory"
                    ],
                    "defaultValue": "eg1.2xlarge",
                    "exportValueAs": "instanceType"
                  },
                  {
                    "label": "Utilization (On-Demand only)",
                    "type": "utilization",
                    "exportValueAs": "utilizationOut",
                    "description": "With utilization, you still have to stop the instance to get the cost benefit. Utilization only affects OnDemand pricing for instances and not the storage, backups, etc."
                  }
                ]
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "refer": [
                    "monthly_ipm"
                  ],
                  "IPMSupported": true,
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Elastic Graphics cost",
                  "decimalPlaces": 2,
                  "subTotalRefer": "monthly_ipm",
                  "id": "elasticGraphicsTotalCost"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "slug": "ElasticGraphics",
  "partitions": [
    "aws"
  ]
}
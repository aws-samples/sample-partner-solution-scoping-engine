                    },
                    {
                      "variableLabel": "[currency] total memory monthly cost",
                      "variableId": "EMRServerless_MemoryCost",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableLabel": "[currency] total storage monthly cost",
                      "variableId": "EMRServerless_StorageCost",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency] total monthly cost",
                  "decimalPlaces": 4
                },
                {
                  "type": "display",
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "EMR Serverless cost",
                  "decimalPlaces": 4,

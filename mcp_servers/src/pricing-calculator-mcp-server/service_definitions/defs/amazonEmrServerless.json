                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "placeholder": "Enter ephemeral storage (GB) per job run",
                "displayInConfigSummary": true
              },
              {
                "type": "input",
                "subType": "durationInput",
                "id": "EMR_Serverless_jobRuntime",
                "label": "Job runtime",

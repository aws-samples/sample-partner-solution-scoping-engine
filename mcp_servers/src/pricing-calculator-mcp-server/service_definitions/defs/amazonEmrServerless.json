            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of vCPUs per job run",
                "id": "totalvCPUHours",
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "placeholder": "Enter number of vCPUs per job run",
                "displayInConfigSummary": true
              },
              {
                "type": "pricing",
                "label": "price per vCPU hour",
                "id": "EMRServerless_vCPU_price",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "elasticmapreduce-serverless",
                "meteredUnit": {
                  "allRegions": "EMR-Serverless-vCPUHours"
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Amount of memory per job run (GB)",
                "id": "totalMemoryHours",
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "placeholder": "Enter memory (GB) per job run",
                "displayInConfigSummary": true
              },
              {
                "type": "pricing",
                "label": "price per memory hour",
                "id": "EMRServerless_memory_price",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "elasticmapreduce-serverless",
                "meteredUnit": {
                  "allRegions": "EMR-Serverless-MemoryGBHours"
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Total ephemeral storage per job run (GB)",
                "id": "totalStorageGB",
                "description": "20 GB of ephemeral storage is available for all workers by default—you pay only for any additional storage that you configure per worker.",

                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "id": "EMRServerless_StorageCost",
                  "operands": [
                    {
                      "variableLabel": "billable storage GB",
                      "variableId": "EMRServerless_billableStorage",
                      "variableUnitLabel": "storage hours",

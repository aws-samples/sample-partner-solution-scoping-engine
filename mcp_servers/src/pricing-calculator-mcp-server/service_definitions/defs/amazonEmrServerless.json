                {
                  "type": "maths",
                  "subType": "maxMin",
                  "operation": "Maximum",
                  "operands": [
                    {
                      "variableLabel": "additional storage GB",
                      "variableUnitLabel": "GB",
                      "required": true,
                      "variableId": "EMRServerless_billableStorage_cal"
                    },
                    {
                      "constant": 0,
                      "constantUnitLabel": ""
                    }
                  ],
                  "outputUnitLabel": "billable storage GB",
                  "decimalPlaces": 2,
                  "id": "EMRServerless_billableStorage"

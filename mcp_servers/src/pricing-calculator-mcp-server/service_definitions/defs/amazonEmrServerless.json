          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/emr/pricing/#Amazon_EMR_Serverless"
            }
          },
          "helpText": "With EMR Serverless, there are no upfront costs, and you pay for only the resources you use. You pay for the amount of vCPU, memory, and storage resources consumed by your applications.",
          "description": "",

                  "refer": [
                    "lightsailBlockStorageText",
                    "blockStorageAmount",
                    "numberofBlockStorageSnapshots",
                    "snapshotBlockStorageAmount",
                    "lightsailStoragePrice",
                    "lightsailSnapshotPrice"
                  ],
                  "id": "unitConvertBlockStorage",
                  "decimalPlaces": 2,
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "lightsailStorageCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "blockStorageAmount",
                      "variableLabel": "Block storage amount",
                      "variableUnitLabel": "GB",
                      "required": true
                    },
                    {
                      "variableId": "lightsailStoragePrice",
                      "variableLabel": "Price lightsail storage",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] Lightsail storage",
                  "decimalPlaces": 0
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "lightsailBlockStorageSnapshotCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "numberofBlockStorageSnapshots",
                      "variableLabel": "Number of snapshots",
                      "variableUnitLabel": "snapshots",
                      "required": true
                    },
                    {
                      "variableId": "snapshotBlockStorageAmount",
                      "variableLabel": "Data stored per snapshot",
                      "variableUnitLabel": "GB",
                      "required": true
                    },
                    {
                      "variableId": "lightsailSnapshotPrice",
                      "variableLabel": "Price lightsail snapshot",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] Lightsail block storage snapshots",
                  "decimalPlaces": 0
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "lightsailBlockStorageTotalCost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "lightsailStorageCost",
                      "variableLabel": "[currency] Lightsail storage",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableId": "lightsailBlockStorageSnapshotCost",
                      "variableLabel": "[currency] Lightsail block storage snapshots",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency] Lightsail block storage",
                  "decimalPlaces": 0
                },
                {
                  "type": "display",
                  "refer": [
                    "lightsailStorageCost",
                    "lightsailBlockStorageSnapshotCost",
                    "lightsailBlockStorageTotalCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Lightsail Block Storage cost",
                  "decimalPlaces": 2,
                  "id": "lightsailStorageCostDisplay",
                  "subTotalRefer": "lightsailBlockStorageTotalCost"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws"
  ]

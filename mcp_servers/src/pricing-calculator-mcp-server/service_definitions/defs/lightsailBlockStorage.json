  "layout": "simple",
  "templates": [
    {
      "title": "Block Storage",
      "id": "lightsailBlockStorage",
      "cards": [
        {
          "title": "Block storage",
          "helpText": "Scale your storage quickly and easily with highly available SSD-backed storage for your Linux or Windows virtual server. Block storage starts at 8 GB and costs 0.10 [currency] per allocated GB, per month.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/lightsail/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "",
                "id": "lightsailBlockStorageText"
              },
              {
                "type": "input",
                "subType": "fileSize",
                "label": "Block storage amount",
                "id": "blockStorageAmount",
                "dropDownSize": [
                  {
                    "label": "GB",
                    "id": "gb"
                  },
                  {
                    "label": "TB",
                    "id": "tb"
                  }
                ],
                "defaultOption": {
                  "size": "gb",
                  "frequency": "NA"
                },
                "outputSize": "gb",
                "outputSizeLabel": "GB",
                "outputFrequency": "NA",
                "outputFrequencyLabel": "NA",
                "displayInConfigSummary": true,
                "defaultValue": 8,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 8,
                  "maxValue": 10240
                },
                "placeholder": "Enter amount",
                "description": "",
                "help": ""
              },
              {
                "type": "input",
                "subType": "frequency",
                "id": "numberofBlockStorageSnapshots",
                "label": "Number of snapshots",
                "options": [
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per week",
                    "id": "perWeek"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perDay",
                "defaultValue": 2,
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 10000000
                },
                "placeholder": "",
                "description": ""
              },
              {
                "type": "input",
                "subType": "fileSize",
                "label": "Data stored per snapshot",
                "id": "snapshotBlockStorageAmount",
                "dropDownSize": [
                  {
                    "label": "GB",
                    "id": "gb"
                  },
                  {
                    "label": "TB",
                    "id": "tb"
                  }
                ],
                "defaultOption": {
                  "size": "gb",
                  "frequency": "NA"
                },
                "outputSize": "gb",
                "outputSizeLabel": "GB",
                "outputFrequency": "NA",
                "outputFrequencyLabel": "NA",
                "displayInConfigSummary": true,
                "defaultValue": 8,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 8,
                  "maxValue": 10240
                },
                "placeholder": "Enter amount",
                "description": "",
                "help": ""
              },
              {
                "type": "pricing",
                "id": "lightsailStoragePrice",
                "label": "Price lightsail storage",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "lightsail",
                "meteredUnit": {
                  "allRegions": "Lightsail Block Storage per GB-Mo"
                }
              },
              {
                "type": "pricing",
                "id": "lightsailSnapshotPrice",
                "label": "Price lightsail snapshot",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "lightsail",
                "meteredUnit": {
                  "allRegions": "Lightsail Snapshot per GB-Mo"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",

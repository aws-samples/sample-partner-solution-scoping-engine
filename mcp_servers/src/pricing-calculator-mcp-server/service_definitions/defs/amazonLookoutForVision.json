                  "type": "display",
                  "id": "trainingdisp",
                  "label": "Training cost",
                  "refer": [
                    "totalModels",
                    "modelRetrainingTime",
                    "totalModelTrainTime",
                    "totalTrainingCharges"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "decimalPlaces": 2,
                  "subTotalRefer": "totalTrainingCharges"
                }
              ]
            }
          ]
        },
        {
          "displayIf": {

                    {
                      "variableId": "totalModels",
                      "variableLabel": "models",
                      "variableUnitLabel": "models",
                      "required": true
                    },
                    {
                      "variableId": "totalModelTrainTime",
                      "variableLabel": "total hours to train/retrain each model",
                      "variableUnitLabel": "hours",
                      "required": true

                      "constant": 60,
                      "constantUnitLabel": "minutes"
                    },
                    {
                      "variableId": "trainingRate",
                      "variableLabel": "Price for Training usage per minute",
                      "variableUnitLabel": "[currency] per minute",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2,
                  "allowDecimals": true
                },

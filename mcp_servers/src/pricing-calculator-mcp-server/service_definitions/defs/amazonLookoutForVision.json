{
  "version": "0.0.8",
  "serviceName": "Amazon Lookout for Vision",
  "serviceCode": "amazonLookoutForVision",
  "type": "AWSService",
  "slug": "LookoutVision",
  "regions": [
    "ap-northeast-2",
    "ap-northeast-1",
    "eu-central-1",
    "eu-west-1",
    "us-east-1",
    "us-east-2",
    "us-west-2"
  ],
  "searchKeywords": [
    "lookout",
    "vision"
  ],
  "serviceDescription": "Amazon Lookout for Vision is a machine learning (ML) service that spots defects and anomalies in visual representations using computer vision (CV). With Amazon Lookout for Vision, manufacturing companies can increase quality and reduce operational costs by quickly identifying differences in images of objects at scale.",
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/lookout-for-vision/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "lookoutvision",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/lookoutvision/[currency]/current/lookoutvision.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "id": "amazonLookoutVision",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/lookout-for-vision/"
        }
      },
      "cards": [
        {
          "title": "Production Process Inputs",
          "helpText": "With Amazon Lookout for Vision, you only pay for what you use. There is no up-front commitment or minimum fee. After you create a project and upload baseline images, Amazon Lookout for Vision enables you to train and detect anomalies with your customized defect detection model on your manufacturing lines. There are two components that determine your bill: charges for training the model and the charges for detecting anomalies.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/lookout-for-vision/pricing/"
            }
          },
          "description": "This calculator and estimated costs should be used as guide only as it will depend on your specific use case requirements. As needed, please contact your AWS Account Manager to discuss further.",
          "expandable": true,
          "defaultExpansion": true,
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of plants",
                "id": "numberOfPlants",
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1000000000
                },
                "defaultValue": 2,
                "displayInConfigSummary": true
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of production lines per plant",
                "id": "numberOfProdLines",
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1000000000
                },
                "defaultValue": 2,
                "displayInConfigSummary": true
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of inspection points per production line",
                "id": "numberOfInspectionPoints",
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1000000000
                },
                "defaultValue": 2,
                "displayInConfigSummary": true
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of cameras per inspection point",
                "id": "numberOfCameras",
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1000000000
                },
                "defaultValue": 2,
                "displayInConfigSummary": true
              }
            ]
          },
          "mathsSection": []
        },
        {
          "title": "Training inputs",
          "helpText": "You pay for the number of hours it takes to train your model. Amazon Lookout for Vision can provision multiple compute resources in parallel to quickly train your model. For example, Lookout for Vision might provision three compute resources in parallel, for 30 minutes each, to train your model using three different algorithms, and then pick the best algorithm for your model. This means that you will have a trained model ready for use within 30 minutes, but the number of hours billed will be 1.5 hours. Learn more here",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/lookout-for-vision/pricing/#Training_Hours"
            }
          },
          "description": "You pay for the number of hours it takes to train your model. Amazon Lookout for Vision can provision multiple compute resources in parallel to quickly train your model. For example, Lookout for Vision might provision three compute resources in parallel, for 30 minutes each, to train your model using three different algorithms, and then pick the best algorithm for your model. This means that you will have a trained model ready for use within 30 minutes, but the number of hours billed will be 1.5 hours. Learn more here.",
          "expandable": true,
          "defaultExpansion": true,
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Time to train initial model (hours)",
                "description": "The time to train a model can be as little as 30 minutes, but can increase based on the size of each image and size of the overall dataset. After 24 hours, model training will time out.",
                "id": "durationTraining",
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "defaultValue": 2.5,
                "displayInConfigSummary": true
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Average number of model retrains per model per month",
                "description": "If you want to verify, maintain, or improve the quality of your model, you can run a trial detection task or add new training images to your dataset. A trial detection task detects anomalies in new images that you supply. You can verify the detection results, add the verified images to your dataset, and train a new version of the model.",
                "id": "numberOfRetrains",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "defaultValue": 0,
                "displayInConfigSummary": true
              },
              {
                "type": "pricing",
                "id": "trainingRate",
                "label": "Price for Training usage per minute",
                "subType": "singlePricePoint",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "mappingDefinitionName": "lookoutvision",
                "meteredUnit": {
                  "allRegions": "Machine Learning Training per minutes"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "id": "textractUnitConv2",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "durationTraining",
                    "numberOfRetrains",
                    "trainingRate"
                  ],
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "totalModels",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "numberOfPlants",
                      "variableLabel": "Number of plants",
                      "variableUnitLabel": "plants",
                      "required": true
                    },
                    {
                      "variableId": "numberOfProdLines",
                      "variableLabel": "Number of production lines per plant",
                      "variableUnitLabel": "production lines",
                      "required": true
                    },
                    {
                      "variableId": "numberOfInspectionPoints",
                      "variableLabel": "Number of inspection points per production line",
                      "variableUnitLabel": "inspection points",
                      "required": true
                    },
                    {
                      "variableId": "numberOfCameras",
                      "variableLabel": "Number of cameras per inspection point",
                      "variableUnitLabel": "cameras",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "models",
                  "allowDecimals": false
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "modelRetrainingTime",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "durationTraining",
                      "variableLabel": "Time to train initial model (hours)",
                      "variableUnitLabel": "hours",
                      "required": true
                    },
                    {
                      "variableId": "numberOfRetrains",
                      "variableLabel": "Average number of model retrains per model per month",
                      "variableUnitLabel": "retrains",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "model retraining hours",
                  "allowDecimals": true
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "totalModelTrainTime",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "durationTraining",
                      "variableLabel": "Time to train initial model (hours)",
                      "variableUnitLabel": "initial training hours",
                      "required": true
                    },
                    {
                      "variableId": "modelRetrainingTime",
                      "variableLabel": "model retraining hours",
                      "variableUnitLabel": "retraining hours",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "total hours to train/retrain each model",
                  "decimalPlaces": 2,
                  "allowzero": true,
                  "allowDecimals": true

      "cards": [
        {
          "title": "Parameter Store",
          "helpText": {
            "aws": "AWS Systems Manager Parameter Store consists of standard and advanced parameters. Standard parameters are available at no additional charge. When you create advanced parameters, you are charged based on the number of advanced parameters stored each month and per API interaction. Charges for parameters stored for less than a month are prorated on an hourly basis.Higher throughput limit settings are applied per account per region. After a higher throughput is enabled, you will be charged per Parameter Store API interaction for standard and advanced parameters. A Parameter Store API interaction is defined as an interaction between an API request and an individual parameter. For example, if a Get request returns ten parameters, that counts as ten Parameter Store API interactions.",
            "aws-cn": "Amazon Systems Manager Parameter Store consists of standard and advanced parameters. Standard parameters are available at no additional charge. When you create advanced parameters, you are charged based on the number of advanced parameters stored each month and per API interaction. Charges for parameters stored for less than a month are prorated on an hourly basis.Higher throughput limit settings are applied per account per region. After a higher throughput is enabled, you will be charged per Parameter Store API interaction for standard and advanced parameters. A Parameter Store API interaction is defined as an interaction between an API request and an individual parameter. For example, if a Get request returns ten parameters, that counts as ten Parameter Store API interactions."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/systems-manager/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "Advanced parameter cost is prorated when stored for less than 1 month. Calculations below assume a full month of parameter storage.",
                "id": "sysManagerParamStore_Text"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Standard parameters",
                "id": "sysManagerParamStore_numberOfStandardParameters",
                "placeholder": "Enter number of standard parameters",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 1000000000
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Advanced parameters",
                "id": "sysManagerParamStore_numberOfAdvParameters",
                "placeholder": "Enter number of advanced parameters",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 1000000000
                }
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": "Frequency of API interactions per parameter",
                "id": "sysManagerParamStore_numberOfAPIInteractions",
                "options": [
                  {
                    "label": "per second",
                    "id": "perSecond"
                  },
                  {
                    "label": "per minute",
                    "id": "perMinute"
                  },
                  {
                    "label": "per hour",
                    "id": "perHour"
                  },
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perMinute",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 999000000000
                },
                "placeholder": "Enter number of API interactions per parameter",
                "description": "Average number of API interactions with each parameter"
              },
              {
                "type": "pricing",
                "id": "sysManagerParamStore_standardThroughputPrice",
                "label": "Price for standard throughput API interaction",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "systemsmanager",
                "meteredUnit": {
                  "allRegions": "Advanced Parameter Standard Throughput per API Request",
                  "cn-north-1": "Advanced Parameter Standard Throughput per Units",
                  "cn-northwest-1": "Advanced Parameter Standard Throughput per Units"
                }
              },
              {

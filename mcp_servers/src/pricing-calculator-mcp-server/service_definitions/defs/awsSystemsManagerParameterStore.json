                  "operands": [
                    {
                      "variableId": "sysManagerParamStore_numberAdvParamAPIs",
                      "variableLabel": "advanced parameter API interactions",
                      "variableUnitLabel": "API interactions",
                      "required": true
                    },
                    {
                      "variableId": "sysManagerParamStore_standardThroughputPrice",
                      "variableLabel": "Price for standard throughput API interaction",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for advanced parameter API interactions",
                  "decimalPlaces": 2

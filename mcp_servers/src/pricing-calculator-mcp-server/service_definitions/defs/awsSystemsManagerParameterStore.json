                    {
                      "variableId": "sysManagerParamStore_AdvParamStoreCost",
                      "variableLabel": "[currency] for advanced parameter storage",
                      "variableUnitLabel": "[currency] for parameter storage",
                      "required": false
                    },
                    {
                      "variableId": "sysManagerParamStore_costAdvParamAPIs",
                      "variableLabel": "[currency] for advanced parameter API interactions",
                      "variableUnitLabel": "[currency] API interactions",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",

                "description": "System messages are sent when channels are created or deleted, and when users are added or removed from channels",
                "id": "systemMessagesSent"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of messages deliveries over active connection per month",
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100000000000000000
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter number of messages deliveries over active connection per month",
                "description": "Messages delivered immediately on send to channel members connected through an active websocket",
                "id": "messageDeliveryOverActive"
              },

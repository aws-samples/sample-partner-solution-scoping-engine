            "$LINK": {
              "type": "pricing",
              "path": "/chime/chime-sdk/pricing/"
            }
          },
          "bodyText": "Messaging is pay-per-use with rates for sending messages, message delivery, and message storage. The Amazon Chime SDK only charges you for what you use, allowing you to scale as needed.",
          "inputSection": {
            "components": [
              {
                "type": "display",
                "subType": "bodyText",
                "id": "textfor1month",
                "text": "This calculation assumes stored resources are present throughout the entire month. As new messages and messaging resources are added, storage cost will increase. To keep message storage costs down, you can implement a retention policy and delete unused resources."
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of persisted standard messages sent per month",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 100000000000000000
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter number of persisted standard messages sent per month",
                "description": "Persisted messages add 4kb to your storage cost",
                "id": "standardMessagesPersisted"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of non-persisted standard messages sent per month",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 100000000000000000
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter number of non-persisted standard messages sent per month",
                "description": "These messages do not add to your storage cost",
                "id": "standardMessagesNonPersisted"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of persisted control messages sent per month",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 100000000000000000
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter number of persisted control messages sent per month",
                "description": "Persisted control messages add 30 bytes to your total storage cost",
                "id": "controlMessagesPersisted"
              },

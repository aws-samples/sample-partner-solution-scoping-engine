                "placeholder": "Enter the number of Batch Transform jobs per month",
                "description": "Number of Batch Transform jobs"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "instancesPerJob",
                "label": "Number of instances per job",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 10000000000000

      "cards": [
        {
          "title": "Bucket evaluation",
          "expandable": true,
          "defaultExpansion": true,
          "helpText": "When you enable Macie, the service will gather detail on all of your S3 buckets, including bucket names, size, object count, resource tags, encryption status, access controls, and region placement. Macie will then automatically and continually evaluate all of your buckets for security and access control, alerting you to any unencrypted buckets, publicly accessible buckets, or buckets shared with an AWS account outside of your organization. You are charged based on the total number of buckets in your account after the 30-day free trial and charges are pro-rated per day.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/macie/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "alert",
                "header": "Free 30-day trial",
                "content": "You can quickly get started with Macie leveraging the 30-day free trial. During the 30-day free trial, there’s no charge for preventative control monitoring for each account in your organization. After the free trial ends, you’re charged based on the number of buckets for each account. The charges are prorated per day.",
                "alertType": "info",
                "partitions": [
                  "aws"
                ],
                "isDismissable": true,
                "id": "alertFreeTrialInfo"
              },
              {
                "type": "input",
                "subType": "bodyText",
                "text": "The calculations below exclude free tier discounts.",
                "id": "NoFreeTierText"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "NumberofS3bucketsEvaluated",
                "label": "Number of S3 buckets",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "placeholder": "",
                "description": "Buckets evaluated for security and access controls.",
                "defaultValue": 0
              },
              {

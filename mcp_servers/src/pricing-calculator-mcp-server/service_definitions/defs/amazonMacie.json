                "id": "s3BucketPrice",
                "label": "Price for s3 bucket",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "macie",
                "meteredUnit": {
                  "allRegions": "Security Services Amazon Macie Paid Data Inventory Evaluation per buckets per month"
                },
                "decimalPlaces": 5
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",

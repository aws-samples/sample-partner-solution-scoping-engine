    "monitoring"
  ],
  "serviceDescription": {
    "aws": "AWS AppConfig enables you to provide validation logic to ensure your configuration data is syntactically and semantically correct according to your definitions before making it available to your application. AWS AppConfig also gives you the ability to roll out configuration changes over a defined time period while monitoring your application so that you can catch errors and roll back the changes if needed, to help you minimize the impact to the users.",
    "aws-cn": "Amazon AppConfig enables you to provide validation logic to ensure your configuration data is syntactically and semantically correct according to your definitions before making it available to your application. Amazon AppConfig also gives you the ability to roll out configuration changes over a defined time period while monitoring your application so that you can catch errors and roll back the changes if needed, to help you minimize the impact to the users."
  },
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/systems-manager/"
    }
  },
  "hasDataTransfer": false,

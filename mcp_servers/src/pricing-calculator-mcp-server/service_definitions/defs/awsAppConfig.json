{
  "version": "0.0.33",
  "serviceName": {
    "aws": "AWS AppConfig",
    "aws-cn": "Amazon AppConfig"
  },
  "serviceCode": "awsAppConfig",
  "type": "AWSService",
  "displayAutomation": true,

  "type": "AWSService",
  "regions": [],
  "serviceDescription": "AWS Audit Manager helps you continuously audit your AWS usage to simplify how you assess risk and compliance. When you define and launch an assessment based on an assessment framework, Audit Manager will execute a resource assessment for each individual resource, such as your Amazon EC2 instances, Amazon RDS instances, Amazon S3 buckets, or Amazon VPC subnets.",
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/audit-manager/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "auditmanager",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/auditmanager/[currency]/current/auditmanager.json"
    }
  ],
  "searchKeywords": [
    "security",
    "lake"
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",

                "isDismissable": true,
                "id": "video_infoAlert"
              },
              {
                "type": "input",
                "subType": "bodyText",
                "text": "<b>Stored video analysis</b>",
                "id": "storedVideoAnalysisInput"
              },
              {
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "rekognition",
                    "meteredUnit": "Archived Content per Minutes Processed"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "label": "Minutes of video processed with label detection API per month",
                "id": "labelDetectionMin",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "defaultValue": 0,
                "placeholder": "Enter the amount",
                "displayInConfigSummary": true
              },
              {
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "rekognition",

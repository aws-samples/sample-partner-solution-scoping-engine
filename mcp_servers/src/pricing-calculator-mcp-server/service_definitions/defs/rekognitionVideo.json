                    "type": "meteredUnit",
                    "mappingDefinitionName": "rekognition",
                    "meteredUnit": "Number of minutes of Archived Video processed for shot detection"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "label": "Minutes of video processed with shot detection API per month",

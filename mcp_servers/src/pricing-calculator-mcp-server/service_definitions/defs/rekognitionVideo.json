          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "id": "ImageUnitConv",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "video_infoAlert",
                    "storedVideoAnalysisInput",
                    "labelDetectionMin",
                    "contentModerationMin",
                    "textDetectionMin",
                    "faceDetectionMin",
                    "celebrityRecognitionMin",
                    "faceSearchMin",
                    "personPathingMin",
                    "mediaAnalysisInput",
                    "shotDetectionMin",
                    "techCuesDetectionMin",
                    "storedVideoRate",
                    "shotDetectionRate",
                    "techCuesDetectionRate"
                  ],
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "totalStoredVideoAnalysisMin",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "labelDetectionMin",
                      "variableLabel": "Minutes of video processed with label detection API per month",
                      "variableUnitLabel": "labels",
                      "required": false
                    },
                    {
                      "variableId": "contentModerationMin",
                      "variableLabel": "Minutes of video processed with content moderation API per month",
                      "variableUnitLabel": "content moderation",
                      "required": false
                    },
                    {
                      "variableId": "textDetectionMin",
                      "variableLabel": "Minutes of video processed with text detection API per month",
                      "variableUnitLabel": "text",
                      "required": false
                    },
                    {
                      "variableId": "faceDetectionMin",
                      "variableLabel": "Minutes of video processed with face detection API per month",
                      "variableUnitLabel": "face",
                      "required": false
                    },
                    {
                      "variableId": "celebrityRecognitionMin",
                      "variableLabel": "Minutes of video processed with celebrity recognition API per month",
                      "variableUnitLabel": "celebrity",
                      "required": false
                    },
                    {
                      "variableId": "personPathingMin",
                      "variableLabel": "Minutes of video processed with person pathing API per month",
                      "variableUnitLabel": "person pathing",
                      "required": false
                    },
                    {
                      "variableId": "faceSearchMin",
                      "variableLabel": "Minutes of video processed with face search API per month",
                      "variableUnitLabel": "face search",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "total stored video analysis minutes",
                  "allowDecimals": false
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "storedVideoCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "totalStoredVideoAnalysisMin",
                      "variableLabel": "total stored video analysis minutes",
                      "variableUnitLabel": "minutes",
                      "required": true
                    },
                    {
                      "variableId": "storedVideoRate",
                      "variableLabel": "Stored video price",
                      "variableUnitLabel": "[currency] per minute",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2,
                  "allowDecimals": true
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "id": "storedVideoCostVar",
                  "label": "Stored video cost (monthly)",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency]",
                  "refer": "storedVideoCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "shotDetectionCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "shotDetectionMin",
                      "variableLabel": "Minutes of video processed with shot detection API per month",
                      "variableUnitLabel": "minutes",
                      "required": true
                    },
                    {
                      "variableId": "shotDetectionRate",
                      "variableLabel": "Shot detection price",
                      "variableUnitLabel": "[currency] per minute",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for shot detection",
                  "decimalPlaces": 2,
                  "allowDecimals": true
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "techCuesDetectionCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "techCuesDetectionMin",
                      "variableLabel": "Minutes of video processed with technical cues detection API per month",
                      "variableUnitLabel": "minutes",
                      "required": true
                    },
                    {
                      "variableId": "techCuesDetectionRate",
                      "variableLabel": "Technical cues detection price",
                      "variableUnitLabel": "[currency] per minute",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for technical cues detection",
                  "decimalPlaces": 2,
                  "allowDecimals": true
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "totalMediaAnalysisCost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "shotDetectionCost",
                      "variableLabel": "[currency] for shot detection",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableId": "techCuesDetectionCost",
                      "variableLabel": "[currency] for technical cues detection",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "allowDecimals": true
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "id": "mediaAnalysisCostVar",
                  "label": "Media analysis cost (monthly)",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency]",
                  "refer": "totalMediaAnalysisCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "totalVideoCost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "storedVideoCostVar",
                      "variableLabel": "Stored video cost (monthly)",
                      "variableUnitLabel": "[currency] Stored video",
                      "required": false
                    },
                    {
                      "variableId": "mediaAnalysisCostVar",
                      "variableLabel": "Media analysis cost (monthly)",
                      "variableUnitLabel": "[currency] Media",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "allowDecimals": true,
                  "displayInCalculationString": true,
                  "allowzero": true
                },
                {
                  "type": "display",
                  "id": "videoCostDisp",
                  "label": "Video pricing",
                  "refer": [
                    "totalStoredVideoAnalysisMin",
                    "storedVideoCost",
                    "storedVideoCostVar",
                    "shotDetectionCost",
                    "techCuesDetectionCost",
                    "totalMediaAnalysisCost",
                    "mediaAnalysisCostVar",
                    "totalVideoCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "decimalPlaces": 2,
                  "subTotalRefer": "totalVideoCost"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws",
    "aws-us-gov"
  ]

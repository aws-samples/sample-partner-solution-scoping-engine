          "displayIf": {
            "or": [
              {
                "exists": {
                  "type": "meteredUnit",
                  "mappingDefinitionName": "rekognition",
                  "meteredUnit": "Archived Content per Minutes Processed"
                }
              },
              {
                "exists": {
                  "type": "meteredUnit",
                  "mappingDefinitionName": "rekognition",
                  "meteredUnit": "Number of minutes of Archived Video processed for shot detection"
                }
              },
              {
                "exists": {
                  "type": "meteredUnit",
                  "mappingDefinitionName": "rekognition",
                  "meteredUnit": "Number of minutes of Archived Video processed using Technical Cues detection"
                }
              }
            ]
          },
          "title": "Video Pricing",
          "helpText": "Amazon Rekognition Video charges you for video analysis performed using our APIs. When running multiple API calls against the same section of video, you will get charged separately for each API. Amazon Rekognition can analyze videos stored in Amazon S3 or live streaming video from Kinesis Video Streams.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/rekognition/pricing/"
            }
          },
          "expandable": true,
          "defaultExpansion": true,
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "alert",
                "label": "info alert",
                "content": "Amazon Rekognition Video is priced per min of video processed for each API. Prices may vary based on the API used. Please see <a href='https://aws.amazon.com/rekognition/pricing'>Amazon Rekognition Video</a> pricing page for more details.<br></br>Minutes of video per month = Number of videos analyzed using the API  per month x Average length of the videos in minutes",

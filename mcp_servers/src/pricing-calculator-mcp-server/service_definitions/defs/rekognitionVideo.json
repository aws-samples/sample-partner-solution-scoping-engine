                  }
                },
                "type": "input",
                "subType": "numericInput",
                "label": "Minutes of video processed with text detection API per month",
                "id": "textDetectionMin",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "placeholder": "Enter the amount",
                "defaultValue": 0,
                "displayInConfigSummary": true
              },
              {

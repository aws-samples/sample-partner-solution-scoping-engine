  "regions": [],
  "searchKeywords": [],
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "rekognition",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/rekognition/[currency]/current/rekognition.json"
    }

                    "meteredUnit": "Archived Content per Minutes Processed"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "label": "Minutes of video processed with celebrity recognition API per month",
                "id": "celebrityRecognitionMin",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "placeholder": "Enter the amount",
                "defaultValue": 0,
                "displayInConfigSummary": true
              },
              {
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "rekognition",
                    "meteredUnit": "Archived Content per Minutes Processed"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "label": "Minutes of video processed with face search API per month",
                "description": "Compare faces detected in video to faces stored in a collection",
                "id": "faceSearchMin",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "placeholder": "Enter the amount",
                "defaultValue": 0,
                "displayInConfigSummary": true
              },

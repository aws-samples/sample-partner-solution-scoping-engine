                    "numberOfEmails",
                    "numberOfPushNotifications",
                    "numberInAppMessageRequests",
                    "alertSMSVoice",
                    "emailMessagesPrice",
                    "pushNotificationsPrice",
                    "inAppPrice"
                  ],
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "emailCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of emails",
                      "variableUnitLabel": "emails per month",
                      "required": true,
                      "variableId": "numberOfEmails"
                    },
                    {
                      "variableLabel": "Price for email messages",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "emailMessagesPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency] (Email messages)",
                  "decimalPlaces": 2
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "pinpoint",
                      "meteredUnit": "Email Messages"
                    }
                  },
                  "type": "maths",
                  "subType": "variable",
                  "label": "Email messages cost (monthly)",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] (Email messages)",
                  "id": "emailCostSubtotal",
                  "refer": "emailCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "subtractFreePushNotifications",
                  "operation": "subtraction",
                  "operands": [
                    {
                      "variableLabel": "Number of push notifications",
                      "variableUnitLabel": "push notifications per month",
                      "required": true,
                      "variableId": "numberOfPushNotifications"
                    },
                    {
                      "constant": 1000000,
                      "constantUnitLabel": "free notifications per month"
                    }
                  ],
                  "outputUnitLabel": "push notifications",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "maxMin",
                  "id": "billablePushNotifications",
                  "operation": "Maximum",
                  "displayInConfigSummary": false,
                  "operands": [
                    {
                      "variableUnitLabel": "push notifications",
                      "variableId": "subtractFreePushNotifications",
                      "required": true
                    },
                    {
                      "constant": 0,
                      "constantUnitLabel": "min billable push notifications"
                    }
                  ],
                  "outputUnitLabel": "billable push notifications"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "pushCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "billable push notifications",
                      "variableUnitLabel": "push notifications per month",
                      "required": true,
                      "variableId": "billablePushNotifications"
                    },
                    {
                      "variableLabel": "Price for push notifications",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "pushNotificationsPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency] (Push notifications)",
                  "decimalPlaces": 2
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "pinpoint",
                      "meteredUnit": "Google Push Notification Messages per Messages"
                    }
                  },
                  "type": "maths",
                  "subType": "variable",
                  "label": "Push notifications cost (monthly)",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] (Push notifications)",
                  "id": "pushCostSubtotal",
                  "refer": "pushCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "subtractFreeInAppMessages",
                  "operation": "subtraction",
                  "operands": [
                    {
                      "variableLabel": "Number of in-app message requests",
                      "variableUnitLabel": "in-app message requests per month",
                      "required": true,
                      "variableId": "numberInAppMessageRequests"
                    },
                    {
                      "constant": 15000,
                      "constantUnitLabel": "free in-app messages per month"
                    }
                  ],
                  "outputUnitLabel": "in-app messages",
                  "decimalPlaces": 2
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "pinpoint",
                      "meteredUnit": "In app Message Requests per Requests"
                    }
                  },
                  "type": "maths",
                  "subType": "maxMin",
                  "id": "billableInAppMessages",
                  "operation": "Maximum",
                  "displayInConfigSummary": false,
                  "operands": [
                    {
                      "variableUnitLabel": "in-app messages",
                      "variableId": "subtractFreeInAppMessages",
                      "required": true
                    },
                    {
                      "constant": 0,
                      "constantUnitLabel": "min billable in-app messages"
                    }
                  ],
                  "outputUnitLabel": "billable in-app messages"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "inAppCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "billable in-app messages",
                      "variableUnitLabel": "in-app message requests per month",
                      "required": true,
                      "variableId": "billableInAppMessages"
                    },
                    {
                      "variableLabel": "Price for in app message requests",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "inAppPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency] (In-app message requests)",
                  "decimalPlaces": 2
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "pinpoint",
                      "meteredUnit": "In app Message Requests per Requests"
                    }
                  },
                  "type": "maths",
                  "subType": "variable",
                  "label": "In-app message cost (monthly)",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] (In-app message requests)",
                  "id": "inAppCostSubtotal",
                  "refer": "inAppCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "totalChannelCost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableLabel": "[currency] (Email messages)",
                      "variableUnitLabel": "[currency]",
                      "required": false,
                      "variableId": "emailCost"
                    },
                    {
                      "variableLabel": "[currency] (Push notifications)",
                      "variableUnitLabel": "[currency]",
                      "required": false,
                      "variableId": "pushCost"
                    },
                    {
                      "variableLabel": "[currency] (In-app message requests)",
                      "variableUnitLabel": "[currency]",
                      "required": false,
                      "variableId": "inAppCost"
                    }
                  ],
                  "outputUnitLabel": "[currency] (Total channels)",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "emailCost",
                    "emailCostSubtotal",
                    "subtractFreePushNotifications",
                    "billablePushNotifications",
                    "pushCost",
                    "pushCostSubtotal",
                    "subtractFreeInAppMessages",
                    "billableInAppMessages",
                    "inAppCost",
                    "inAppCostSubtotal",
                    "totalChannelCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Pinpoint channels",
                  "decimalPlaces": 2,
                  "id": "totalChannelCostDisplay",
                  "subTotalRefer": "totalChannelCost"
                }
              ]
            }
          ]
        },
        {
          "title": "Campaigns",
          "helpText": "Monthly Targeted Audience (MTA)<br/><br/> If you send messages from an Amazon Pinpoint campaign or journey, the endpoints you contact are known as a monthly targeted audience (MTA). You are charged on the number of MTAs targeted in a calendar month.<br/><br/> Events<br/><br/>To collect mobile or web application data with Amazon Pinpoint, you will use the AWS SDK to collect application usage data. You are charged for the number of application events that you collect each month. Application events include campaign events (like following a link in a push notification) and events recorded from regular usage of the mobile app (like opening the app).",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/pinpoint/pricing/"
            }
          },
          "bodyText": "With Amazon Pinpoint, you pay only for what you use. There are no contract negotiations and no minimum charges.",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "frequency",
                "label": "Monthly Targeted Audiences (MTA)",
                "options": [
                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  },
                  {
                    "label": "billion per month",
                    "id": "billionPerMonth"
                  }
                ],
                "defaultFrequency": "perMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100000000000
                },
                "placeholder": "Enter number of unique endpoints targeted",
                "description": "If you send messages from an Amazon Pinpoint campaign or journey, the endpoints you contact are known as a monthly targeted audience (MTA). You are charged on the number of MTAs targeted in a calendar month.",
                "id": "numberMTAs"
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": "Number of events",
                "options": [
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per week",
                    "id": "perWeek"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  },
                  {
                    "label": "billion per month",
                    "id": "billionPerMonth"
                  }
                ],
                "defaultFrequency": "perDay",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100000000000
                },
                "placeholder": "Enter amount",
                "description": "To collect mobile or web application data with Amazon Pinpoint, you will use the AWS SDK to collect application usage data. You are charged for the number of application events that you collect each month. Application events include campaign events (like following a link in a push notification) and events recorded from regular usage of the mobile app (like opening the app).",
                "id": "numberOfEvents"
              },
              {
                "type": "pricing",
                "label": "Price for MTA",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "pinpoint",
                "meteredUnit": {
                  "allRegions": "MTA per Users"
                },
                "id": "MTAPrice"
              },
              {
                "type": "pricing",
                "label": "Price for events",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "pinpoint",
                "meteredUnit": {
                  "allRegions": "Events Recorded per Events"
                },
                "id": "eventPrice"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "id": "pinpointUnitConvertCampaign",
                  "refer": [
                    "numberMTAs",
                    "numberOfEvents",
                    "MTAPrice",
                    "eventPrice"
                  ],
                  "subTotalRefer": "totalChannelCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "subtractFreeMTAs",
                  "operation": "subtraction",
                  "operands": [
                    {
                      "variableLabel": "Monthly Targeted Audiences (MTA)",
                      "variableUnitLabel": "MTAs",
                      "required": true,
                      "variableId": "numberMTAs"
                    },
                    {
                      "constant": 5000,
                      "constantUnitLabel": "free unique endpoints per month"
                    }
                  ],
                  "outputUnitLabel": "MTAs",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "maxMin",
                  "id": "billableMTAs",

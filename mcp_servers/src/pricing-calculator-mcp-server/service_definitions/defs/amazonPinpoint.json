                  }
                },
                "type": "input",
                "subType": "frequency",
                "label": "Number of push notifications",
                "options": [
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per week",
                    "id": "perWeek"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  },
                  {
                    "label": "billion per month",
                    "id": "billionPerMonth"
                  }
                ],
                "defaultFrequency": "perDay",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100000000000
                },
                "placeholder": "Enter amount",
                "description": "",
                "id": "numberOfPushNotifications"
              },
              {
                "type": "input",
                "subType": "frequency",
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "pinpoint",
                    "meteredUnit": "In app Message Requests per Requests"
                  }
                },
                "label": "Number of in-app message requests",
                "options": [
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per week",
                    "id": "perWeek"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  },
                  {
                    "label": "billion per month",
                    "id": "billionPerMonth"
                  }
                ],
                "defaultFrequency": "perDay",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"

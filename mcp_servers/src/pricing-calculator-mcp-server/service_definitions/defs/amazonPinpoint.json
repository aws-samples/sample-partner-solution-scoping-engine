                },
                "mappingDefinitionName": "pinpoint",
                "meteredUnit": {
                  "allRegions": "In app Message Requests per Requests"
                },
                "id": "inAppPrice"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "id": "pinpointUnitConvert",

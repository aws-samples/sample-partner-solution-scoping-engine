                      "variableLabel": "Price for MTA",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "MTAPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency] (MTAs)",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "subtractFreeEvents",
                  "operation": "subtraction",
                  "operands": [
                    {
                      "variableLabel": "Number of events",
                      "variableUnitLabel": "events per month",
                      "required": true,
                      "variableId": "numberOfEvents"
                    },
                    {
                      "constant": 100000000,

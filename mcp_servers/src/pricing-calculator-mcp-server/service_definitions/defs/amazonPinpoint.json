  "serviceDescription": "Amazon Pinpoint is a flexible and scalable outbound and inbound marketing communications service. You can connect with customers over channels like email, SMS, push, or voice. Amazon Pinpoint is easy to set up, easy to use, and is flexible for all marketing communication scenarios. ",
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/pinpoint/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "pinpoint",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/pinpoint/[currency]/current/pinpoint.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "description": "",

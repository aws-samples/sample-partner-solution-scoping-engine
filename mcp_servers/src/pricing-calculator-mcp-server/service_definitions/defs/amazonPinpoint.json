            "$LINK": {
              "type": "pricing",
              "path": "/pinpoint/pricing/"
            }
          },
          "bodyText": "With Amazon Pinpoint, you pay only for what you use. There are no contract negotiations and no minimum charges.",
          "inputSection": {
            "components": [

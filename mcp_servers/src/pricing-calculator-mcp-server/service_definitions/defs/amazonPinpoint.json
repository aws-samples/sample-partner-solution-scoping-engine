                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100000000000
                },
                "placeholder": "Enter amount",
                "description": "",
                "id": "numberInAppMessageRequests"
              },
              {
                "type": "input",
                "subType": "alert",
                "header": "SMS and voice messages",
                "content": "SMS<br/><br/>You pay for each message you send. The price you pay for each message varies based on the country or region where the recipient is located. See the <a href='https://aws.amazon.com/pinpoint/pricing/#SMS_text_messages' target='_blank'> SMS pricing tool</a> for more information.<br/><br/>Voice<br/><br/>You pay for each message you send. The price you pay is based on the length of each message that you deliver, the type of phone number, and on the recipient's country or region. You must also lease at least one dedicated long code to get started. For more information, see <a href='https://aws.amazon.com/pinpoint/pricing/#Voice_messages' target='_blank'> Amazon Pinpoint voice message pricing</a> and Amazon Pinpoint <a href='https://aws.amazon.com/pinpoint/pricing/#Long_code_phone_number' target='_blank'>dedicated long code pricing</a>",
                "alertType": "info",
                "partitions": [
                  "aws",
                  "aws-us-gov"
                ],
                "isDismissable": true,
                "id": "alertSMSVoice"
              },
              {
                "type": "pricing",
                "label": "Price for email messages",
                "subType": "singlePricePoint",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "mappingDefinitionName": "pinpoint",
                "meteredUnit": {
                  "allRegions": "Email Messages"
                },
                "id": "emailMessagesPrice"
              },
              {
                "type": "pricing",
                "label": "Price for push notifications",
                "subType": "singlePricePoint",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "mappingDefinitionName": "pinpoint",
                "meteredUnit": {
                  "allRegions": "Google Push Notification Messages per Messages"
                },
                "id": "pushNotificationsPrice"
              },
              {

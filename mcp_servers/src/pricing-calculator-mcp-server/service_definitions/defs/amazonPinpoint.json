                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "pinpoint",
                    "meteredUnit": "Email Messages"
                  }
                },
                "type": "input",
                "subType": "frequency",
                "label": "Number of emails",
                "options": [
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per week",
                    "id": "perWeek"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  },
                  {
                    "label": "billion per month",
                    "id": "billionPerMonth"
                  }
                ],
                "defaultFrequency": "perDay",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"

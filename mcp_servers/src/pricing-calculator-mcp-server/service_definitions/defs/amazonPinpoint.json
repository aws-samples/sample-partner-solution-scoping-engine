                    }
                  ],
                  "outputUnitLabel": "events",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "maxMin",
                  "id": "billableEvents",
                  "operation": "Maximum",
                  "displayInConfigSummary": false,
                  "operands": [
                    {
                      "variableUnitLabel": "events",
                      "variableId": "subtractFreeEvents",
                      "required": true
                    },
                    {
                      "constant": 0,
                      "constantUnitLabel": "min billable events"
                    }
                  ],
                  "outputUnitLabel": "billable events"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "eventCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "billable events",
                      "variableUnitLabel": "events per month",
                      "required": true,
                      "variableId": "billableEvents"
                    },
                    {
                      "variableLabel": "Price for events",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "eventPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency] (Events)",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "totalCampaignCost",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableLabel": "[currency] (MTAs)",
                      "variableUnitLabel": "[currency]",
                      "required": false,
                      "variableId": "MTACost"
                    },
                    {
                      "variableLabel": "[currency] (Events)",
                      "variableUnitLabel": "[currency]",
                      "required": false,
                      "variableId": "eventCost"
                    }
                  ],
                  "outputUnitLabel": "[currency] (Campaigns)",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "subtractFreeMTAs",
                    "billableMTAs",
                    "MTACost",
                    "subtractFreeEvents",
                    "billableEvents",
                    "eventCost",
                    "totalCampaignCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Pinpoint campaigns",
                  "decimalPlaces": 2,
                  "id": "totalCampaignCostDisplay",
                  "subTotalRefer": "totalCampaignCost"
                }
              ]
            }
          ]
        }
      ],
      "id": "pinpoint"
    }

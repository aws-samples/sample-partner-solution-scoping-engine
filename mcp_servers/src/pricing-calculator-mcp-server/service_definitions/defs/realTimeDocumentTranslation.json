{
  "version": "0.0.7",
  "serviceName": "Real-Time Document Translation",
  "serviceCode": "realTimeDocumentTranslation",
  "type": "AWSService",
  "subType": "subService",
  "regions": [],
  "searchKeywords": [
    "NLP",
    "Natural language processing",
    "language transalation",
    "Text analytics",
    "Language translation",
    "Amazon translate",
    "Translate"
  ],
  "serviceDescription": "Amazon Translate is a neural machine translation service that delivers fast, high-quality, and affordable language translation. Neural machine translation is a form of language translation automation that uses deep learning models to deliver more accurate and more natural sounding translation than traditional statistical and rule-based translation algorithms.",
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "translate",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/translate/[currency]/current/translate.json"
    },
    {
      "mappingDefinitionName": "translate-document-calc",
      "mappingDefinitionVersion": "PLC_2.0",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/translate/[currency]/current/translate-document-calc/metadata.json"
    }
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/translate/"
    }
  },
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "Amazon Translate",
      "description": "Amazon Translate delivers fast, high-quality, and affordable language translation. This is a neural machine translation service, which is a form of language translation automation that uses deep learning models to deliver more accurate and more natural sounding translation than traditional statistical and rule-based translation algorithms.",
      "id": "amazonTrans_t",
      "helpText": "",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/translate/pricing/"
        }
      },
      "cards": [
        {
          "title": "Real-Time Document Translation",
          "helpText": "Real-Time Document Translation allows customers to translate HTML and Text documents in real time.",
          "helpUrl": {
            "$LINK": {
              "type": "documentation",
              "path": "/translate/latest/dg/sync.html"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "The calculations below exclude free tier discounts.",
                "id": "freeTierIDSRT",
                "partitions": [
                  "aws"
                ]
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": "Number of characters including white spaces and punctuations (Real-Time Document Translation)",
                "id": "Tanslate_chars_RT_D",
                "options": [
                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  }
                ],
                "defaultFrequency": "millionPerMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1e+21
                },
                "placeholder": "Enter average number of characters to be translated per month",
                "description": "Average number of characters translated per month"
              },
              {
                "label": "Real-Time Document Translation",
                "id": "columnFormIPM",
                "type": "input",
                "subType": "columnFormIPM",
                "disableCalculation": true,
                "mappingDefinitionName": "translate-document-calc",
                "calculationId": {
                  "hourly": "monthly_ipm"
                },
                "pricingUnitModel": {
                  "riPaymentOptions": {
                    "hourly": "*"
                  }
                },
                "primaryKey": "FileType",
                "secondaryKey": [],
                "remap": {
                  "keyValue": {
                    "Basic": "Basic - Text, HTML",
                    "Office": "Office - Docx"
                  }
                },
                "row": [
                  {
                    "label": "Document Type",
                    "type": "dropDown",
                    "selectorId": "FileType",
                    "exportValueAs": "ft",
                    "defaultValue": "Basic"
                  }
                ]
              },
              {
                "type": "pricing",
                "label": "price for realtime document translate",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "translate",
                "meteredUnit": {
                  "allRegions": "TranslateDocument"
                },
                "id": "translateRealTimeDocPricing"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "freeTierIDSRT",
                    "Tanslate_chars_RT_D",
                    "columnFormIPM",
                    "ft",
                    "translateRealTimeDocPricing"
                  ],
                  "subTotalRefer": "",
                  "id": "unitCov"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Tanslate_chars_RT_D",
                      "variableLabel": "Number of characters including white spaces and punctuations (Real-Time Document Translation)",
                      "variableUnitLabel": "characters",
                      "required": true
                    },
                    {
                      "variableLabel": "Real-Time Document Translation",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "monthly_ipm",
                      "IPMSupported": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (Document Translation)",
                  "decimalPlaces": 2,
                  "id": "translate_final_cst"
                },
                {
                  "type": "display",
                  "id": "RTD_Translation_Disp",
                  "refer": [
                    "translate_final_cst"
                  ],
                  "subTotalRefer": "translate_final_cst",
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Real-Time Document Translation cost",
                  "decimalPlaces": 2
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws"
  ]
}
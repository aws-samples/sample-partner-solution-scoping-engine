  "layout": "simple",
  "templates": [
    {
      "title": "Asynchronous Inference Instances",
      "description": "",
      "id": "asyncInferenceInstances",
      "helpText": "Amazon SageMaker Asynchronous Inference is a near-real time inference option that queues incoming requests and processes them asynchronously. Use this option when you need to process large payloads as the data arrives or run models that have long inference processing times and do not have sub-second latency requirements. You are charged for the type of instance you choose.",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/sagemaker/pricing/"
        }
      },
      "cards": [
        {
          "title": "Asynchronous Inference Instances",
          "helpText": "Amazon SageMaker Asynchronous Inference is a near-real time inference option that queues incoming requests and processes them asynchronously. Use this option when you need to process large payloads as the data arrives or run models that have long inference processing times and do not have sub-second latency requirements. You are charged for the type of instance you choose.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/sagemaker/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "id": "modelsDeployed",
                "label": "Number of models deployed",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 10000000000000
                },
                "placeholder": "Enter the number of models deployed",
                "description": "Number of models deployed"
              },
              {
                "type": "input",
                "subType": "alert",
                "header": "",
                "content": "SageMaker Asynchronous Inference endpoints allow only a single model per endpoint.",
                "alertType": "info",
                "isDismissable": true,
                "id": "AsyncAl"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "modelsPerEndPoint",
                "label": "Number of models per endpoint",
                "defaultValue": 1,
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1
                },
                "placeholder": "Enter the number of models per endpoint"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "instancesPerEndPoint",
                "label": "Number of instances per endpoint",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 10000000000000
                },
                "placeholder": "Enter the number of instances per endpoint",
                "description": "Number of instances per endpoint"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "endpointHrsPerDay",
                "label": "Endpoint hour(s) per day",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0.01,
                  "maxValue": 24
                },
                "placeholder": "Enter the number of hours endpoint is active per day including cool down periods for autoscaling",
                "description": "Number of hours endpoint is active per day including cool down periods for autoscaling"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "EndPointDaysPerMonth",
                "label": "Endpoint day(s) per month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 31
                },
                "placeholder": "Enter the number of days endpoint is active per month",
                "description": "Number of days endpoint is active per month"
              },
              {
                "label": "SageMaker async Instances",
                "id": "columnFormIPM",
                "type": "input",
                "subType": "columnFormIPM",
                "disableCalculation": true,
                "mappingDefinitionName": "sagemaker-inference-async-calc",
                "calculationId": {
                  "hourly": "monthly_ipm"
                },
                "pricingUnitModel": {
                  "riPaymentOptions": {
                    "hourly": "*"
                  }
                },
                "primaryKey": {
                  "Instance Name": [
                    "Compute Type",
                    "V CPU",
                    "Memory",
                    "Clock Speed",
                    "GPU",
                    "Network Performance",
                    "Storage",
                    "GPU Memory"
                  ]
                },
                "secondaryKey": [],
                "row": [
                  {
                    "label": "Instance name",
                    "type": "autoSuggest",
                    "selectorId": "Instance Name",
                    "withTags": [
                      "Compute Type",
                      "V CPU",
                      "Memory",
                      "Clock Speed",
                      "GPU",
                      "Network Performance",
                      "Storage",
                      "GPU Memory"
                    ]
                  }
                ]
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "division",
                  "operands": [
                    {
                      "variableId": "modelsDeployed",
                      "variableLabel": "Number of models deployed",
                      "variableUnitLabel": "models",
                      "required": true
                    },
                    {
                      "variableId": "modelsPerEndPoint",
                      "variableLabel": "Number of models per endpoint",
                      "variableUnitLabel": "models per endpoint",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "endpoint(s)",
                  "decimalPlaces": 6,
                  "id": "asyncdiv0"
                },
                {
                  "type": "maths",
                  "subType": "rounding",
                  "method": "roundUp",
                  "factor": "1",
                  "operationLabel": "endpoints rounded up by 1",
                  "id": "modelsRounded",
                  "minValue": 0,
                  "operands": [
                    {
                      "variableId": "asyncdiv0",
                      "variableLabel": "endpoint(s)",
                      "variableUnitLabel": "models rounded up to nearest 1",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "endpoint(s) (rounded up)",
                  "decimalPlaces": 0
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "endpoint(s) (rounded up)",
                      "variableUnitLabel": "endpoint(s)",
                      "required": true,
                      "variableId": "modelsRounded"
                    },
                    {
                      "variableId": "instancesPerEndPoint",
                      "variableLabel": "Number of instances per endpoint",
                      "required": true,
                      "variableUnitLabel": "instances per endpoint"
                    },
                    {
                      "variableId": "endpointHrsPerDay",
                      "variableLabel": "Endpoint hour(s) per day",
                      "required": true,
                      "variableUnitLabel": "hours per day"
                    },
                    {
                      "variableId": "EndPointDaysPerMonth",
                      "variableLabel": "Endpoint day(s) per month",
                      "required": true,
                      "variableUnitLabel": "day per month"
                    }
                  ],
                  "outputUnitLabel": "instance hours per month",
                  "decimalPlaces": 2,
                  "id": "asynchrsMonth"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "instance hours per month",
                      "variableUnitLabel": "hours per month",
                      "required": true,
                      "variableId": "asynchrsMonth"
                    },
                    {
                      "variableLabel": "SageMaker async Instances",
                      "variableUnitLabel": "[currency] per hour instance cost",
                      "required": true,
                      "variableId": "monthly_ipm",
                      "IPMSupported": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (monthly On-Demand cost)",
                  "decimalPlaces": 2,
                  "id": "asynondemandCost"
                },
                {
                  "type": "display",
                  "refer": [
                    "modelsDeployed",
                    "AsyncAl",
                    "modelsPerEndPoint",
                    "instancesPerEndPoint",
                    "endpointHrsPerDay",
                    "EndPointDaysPerMonth",
                    "columnFormIPM",
                    "asyncdiv0",
                    "modelsRounded",
                    "asynchrsMonth",
                    "asynondemandCost"
                  ],
                  "required": true,
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Total cost for Asynchronous Inference",
                  "decimalPlaces": 2,
                  "id": "asyncTotCost",
                  "subTotalRefer": "asynondemandCost"
                }
              ]
            }
          ]
        },
        {

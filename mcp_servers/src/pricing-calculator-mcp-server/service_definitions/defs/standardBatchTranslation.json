{
  "version": "0.0.13",
  "serviceName": "Standard Batch Translation",
  "serviceCode": "standardBatchTranslation",
  "type": "AWSService",
  "subType": "subService",
  "regions": [
    "us-east-1",
    "eu-west-1",
    "us-west-2",
    "eu-central-1",
    "ap-northeast-2",
    "us-east-2",
    "eu-west-2",
    "us-iso-east-1"
  ],
  "searchKeywords": [
    "NLP",
    "Natural language processing",
    "language transalation",
    "Text analytics",
    "Language translation",
    "Amazon translate",
    "Translate"
  ],
  "serviceDescription": "Amazon Translate is a neural machine translation service that delivers fast, high-quality, and affordable language translation. Neural machine translation is a form of language translation automation that uses deep learning models to deliver more accurate and more natural sounding translation than traditional statistical and rule-based translation algorithms.",
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "translate",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/translate/[currency]/current/translate.json"
    }
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/translate/"
    }
  },
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "Standard Batch Translation",
      "description": "Amazon Translate delivers fast, high-quality, and affordable language translation. This is a neural machine translation service, which is a form of language translation automation that uses deep learning models to deliver more accurate and more natural sounding translation than traditional statistical and rule-based translation algorithms.<a href='https://aws.amazon.com/contact-us/'target='_blank'>For consistent usage greater than 1 billion characters per month, please contact us.</a>",
      "id": "amazonTranslate_batch",
      "helpText": "",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/translate/pricing/"
        }
      },
      "cards": [
        {
          "title": "Standard Batch Translation",
          "helpText": "Use Batch translation when you have large quantities of pre-existing files to translate.<a href='https://aws.amazon.com/contact-us/'target='_blank'> For consistent usage greater than 1 billion characters per month, please contact us.</a>",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/translate/pricing/",
              "overrides": {
                "aws": "https://docs.aws.amazon.com/translate/latest/dg/async.html"
              }
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "The calculations below exclude free tier discounts.",
                "id": "freeTierID",
                "partitions": [
                  "aws"
                ]
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Tanslate_chars_Batch",
                "label": "Number of characters including white spaces and punctuations (Standard Batch Translation)",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 100000000000000000000
                },
                "placeholder": "Enter average number of characters to be translated per month",
                "description": "Average number of characters translated per month"
              },
              {
                "type": "pricing",
                "label": "price for standard batch translate",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "translate",
                "meteredUnit": {
                  "allRegions": "TextTranslationJob"
                },
                "id": "translatebatchPricing"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "BatchTranslatecost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "Tanslate_chars_Batch",
                      "variableLabel": "Number of characters including white spaces and punctuations (Standard Batch Translation)",
                      "variableUnitLabel": "characters",
                      "required": true
                    },
                    {
                      "variableId": "translatebatchPricing",
                      "variableLabel": "price for standard batch translate",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (cost for Standard Batch Translation)",
                  "decimalPlaces": 6
                },
                {
                  "type": "display",
                  "id": "StandardBatch_Translation_Disp",
                  "refer": [
                    "freeTierID",
                    "Tanslate_chars_Batch",
                    "translatebatchPricing",
                    "BatchTranslatecost"
                  ],
                  "subTotalRefer": "BatchTranslatecost",
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Standard Batch Translation cost",
                  "decimalPlaces": 6
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws",
    "aws-iso"
  ]
}
{
  "version": "0.0.72",
  "serviceName": "Amazon Security Lake",
  "serviceCode": "amazonSecurityLake",
  "type": "AWSService",
  "regions": [],
  "serviceDescription": "Amazon Security Lake automatically centralizes security data from cloud, on-premises, and custom sources into a purpose-built data lake stored in your account. With Security Lake, you can get a more complete understanding of your security data across your entire organization. ",
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/security-lake/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "securitylake",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/securitylake/[currency]/current/securitylake.json"
    }
  ],
  "searchKeywords": [
    "security",
    "lake"
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "Amazon Security Lake",
      "description": "Quick estimate: Use the quick estimate for a fast route to a rough estimate. ",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/security-lake/"
        }
      },
      "id": "template_securitylake",
      "cards": [
        {
          "title": "Service Setting",
          "helpText": "Amazon Security Lake automatically centralizes security data from cloud, on-premises, and custom sources into a purpose-built data lake stored in your account. With Security Lake, you can get a more complete understanding of your security data across your entire organization.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/security-lake/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "securitylake",
                    "meteredUnit": "Security Lake CloudTrailEvents Paid per GB"
                  }
                },
                "type": "input",
                "subType": "fileSize",
                "label": "CloudTrail events",
                "dropDownSize": [
                  {
                    "label": "GB",
                    "id": "gb"
                  },
                  {
                    "label": "TB",
                    "id": "tb"
                  },
                  {
                    "label": "PB",
                    "id": "pb"
                  }
                ],
                "defaultOption": {
                  "size": "gb",
                  "frequency": "NA"
                },
                "outputSize": "gb",
                "outputSizeLabel": "GB",
                "outputFrequency": "NA",
                "outputFrequencyLabel": "NA",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 9.5367432e-06,
                  "maxValue": 100000000000
                },
                "placeholder": "",
                "description": "Enter amount of total CloudTrail events",
                "help": "",
                "id": "cloudTrailLogEvents"
              },
              {
                "type": "pricing",
                "label": "Price for cloudtrail events",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "securitylake",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "meteredUnit": {
                  "allRegions": "Security Lake CloudTrailEvents Paid per GB"
                },
                "id": "cloudTrailLogEventsPrice"
              },
              {
                "displayIf": {
                  "and": [
                    {
                      "exists": {
                        "type": "meteredUnit",
                        "mappingDefinitionName": "securitylake",
                        "meteredUnit": "Security Lake OtherLogs First 10TB"
                      }
                    },
                    {
                      "exists": {
                        "type": "meteredUnit",
                        "mappingDefinitionName": "securitylake",
                        "meteredUnit": "Security Lake OtherLogs Next 20TB"
                      }
                    },
                    {
                      "exists": {
                        "type": "meteredUnit",
                        "mappingDefinitionName": "securitylake",
                        "meteredUnit": "Security Lake OtherLogs another 20TB"
                      }
                    },
                    {
                      "exists": {
                        "type": "meteredUnit",
                        "mappingDefinitionName": "securitylake",
                        "meteredUnit": "Security Lake OtherLogs Over 50TB"
                      }
                    }
                  ]
                },
                "type": "input",
                "subType": "fileSize",
                "label": "Other AWS Logs",
                "dropDownSize": [
                  {
                    "label": "GB",
                    "id": "gb"
                  },
                  {
                    "label": "TB",
                    "id": "tb"
                  },
                  {
                    "label": "PB",
                    "id": "pb"
                  }
                ],
                "defaultOption": {
                  "size": "gb",
                  "frequency": "NA"
                },
                "outputSize": "gb",
                "outputSizeLabel": "GB",
                "outputFrequency": "NA",
                "outputFrequencyLabel": "NA",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 9.5367432e-06,
                  "maxValue": 100000000000
                },
                "placeholder": "",
                "description": "Enter amount of other AWS logs",
                "help": "",
                "id": "cloudTrailLogEventsOther"
              },
              {
                "type": "pricing",
                "subType": "tieredPricing",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "label": "tiered pricing other cloudtrail events",
                "id": "otherCloudEventsPrice",
                "mappingDefinitionName": "securitylake",
                "decimalPlaces": 4,
                "tiers": {
                  "allRegions": [
                    {
                      "startOfTier": 0,
                      "endOfTier": 10240,
                      "meteredUnit": "Security Lake OtherLogs First 10TB"
                    },
                    {
                      "startOfTier": 10241,
                      "endOfTier": 30720,
                      "meteredUnit": "Security Lake OtherLogs Next 20TB"
                    },
                    {
                      "startOfTier": 30721,
                      "endOfTier": 51200,
                      "meteredUnit": "Security Lake OtherLogs another 20TB"
                    },
                    {
                      "startOfTier": 51201,
                      "endOfTier": -1,
                      "meteredUnit": "Security Lake OtherLogs Over 50TB"
                    }
                  ]
                }
              },
              {
                "type": "pricing",
                "label": "Price for cloudtrail log",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "securitylake",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "meteredUnit": {
                  "allRegions": "Security Lake ManagementEvents Paid per GB"
                },
                "id": "cloudTrailLogPrice"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "cloudTrailLogEvents",
                    "cloudTrailLogEventsPrice",
                    "cloudTrailLogEventsOther",
                    "otherCloudEventsPrice",
                    "cloudTrailLogPrice"
                  ],
                  "subTotalRefer": "",
                  "id": "unitConvAnalytics"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "CloudTrail events",
                      "variableUnitLabel": "GB of CloudTrail events",
                      "required": true,
                      "variableId": "cloudTrailLogEvents"
                    },
                    {
                      "variableLabel": "Price for cloudtrail events",
                      "variableUnitLabel": "[currency] per GB",
                      "required": false,
                      "variableId": "cloudTrailLogEventsPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency] (cost for CloudTrail events ingested)",
                  "decimalPlaces": 2,
                  "variableName": "cloudtrail logs ingested",
                  "id": "cloudtrailLogsCalc"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Total CloudTrail events cost",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "cloudtrail logs ingested",
                  "id": "cloudtrailLog",
                  "refer": "cloudtrailLogsCalc"
                },
                {
                  "type": "maths",
                  "subType": "tieredPricingMath",
                  "tieredPricingReferLabel": "tiered pricing other cloudtrail events",
                  "inputReferLabel": "Other AWS Logs",
                  "outputUnitLabel": "[currency] (cost of other AWS logs)",
                  "inputUnitLabel": "GB of other AWS logs ingested",
                  "decimalPlaces": 4,
                  "id": "otherCloudTrailEvents",
                  "variableName": "cloudtrail other events",
                  "inputRefer": "cloudTrailLogEventsOther",
                  "tieredPricingRefer": "otherCloudEventsPrice"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Total cloudtrail other events cost",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "cloudtrail other events",
                  "id": "cloudtrailOther_Var",
                  "refer": "otherCloudTrailEvents"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableLabel": "CloudTrail events",
                      "variableUnitLabel": "GB of CloudTrail events",
                      "required": false,
                      "variableId": "cloudTrailLogEvents"
                    },
                    {
                      "variableLabel": "Other AWS Logs",
                      "variableUnitLabel": "GB of other AWS logs ingested",
                      "required": false,
                      "variableId": "cloudTrailLogEventsOther"
                    }
                  ],
                  "outputUnitLabel": "GB (Total GB of data normalization)",
                  "decimalPlaces": 2,
                  "variableName": "normalisation total size",
                  "id": "normalisationTotalSize"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "normalisation total size",
                      "variableUnitLabel": "GB",
                      "required": true,
                      "variableId": "normalisationTotalSize"
                    },
                    {
                      "variableLabel": "Price for cloudtrail log",
                      "variableUnitLabel": "[currency]",
                      "required": false,
                      "variableId": "cloudTrailLogPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency] (cost for data normalization cost)",
                  "decimalPlaces": 2,
                  "id": "normalizationCalc"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Total data normalization cost",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] (cost for data normalization cost)",
                  "id": "datanormalisation_var",
                  "refer": "normalizationCalc"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableLabel": "Total CloudTrail events cost",
                      "variableUnitLabel": "[currency] (CloudTrail events ingested)",
                      "required": false,
                      "variableId": "cloudtrailLog"
                    },
                    {
                      "variableLabel": "cloudtrail other events",
                      "variableUnitLabel": "[currency] (other AWS logs)",
                      "required": false,
                      "variableId": "otherCloudTrailEvents"
                    },
                    {
                      "variableLabel": "Total data normalization cost",
                      "variableUnitLabel": "[currency] (Data normalization cost)",
                      "required": false,
                      "variableId": "datanormalisation_var"
                    }
                  ],
                  "outputUnitLabel": "[currency] (Total cost)",
                  "decimalPlaces": 2,
                  "id": "finalSecurityLakeCalc"
                },
                {
                  "type": "display",
                  "refer": [
                    "cloudtrailLogsCalc",
                    "cloudtrailLog",
                    "otherCloudTrailEvents",
                    "cloudtrailOther_Var",
                    "normalisationTotalSize",
                    "normalizationCalc",
                    "datanormalisation_var",
                    "finalSecurityLakeCalc"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Security Lake pricing",
                  "decimalPlaces": 2,
                  "id": "securitylakeFinal",
                  "subTotalRefer": "finalSecurityLakeCalc"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws"
  ]
}
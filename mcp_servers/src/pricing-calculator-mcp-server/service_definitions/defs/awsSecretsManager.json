{
  "version": "0.0.26",
  "serviceName": {
    "aws": "AWS Secrets Manager",
    "aws-cn": "Amazon Secrets Manager"
  },
  "serviceCode": "awsSecretsManager",
  "type": "AWSService",
  "regions": [
    "us-gov-west-1",
    "us-gov-east-1",
    "af-south-1",
    "ap-east-1",
    "ap-south-1",
    "ap-northeast-2",
    "ap-southeast-1",
    "ap-southeast-2",
    "ap-southeast-3",
    "ap-northeast-1",
    "ca-central-1",
    "eu-central-1",
    "eu-west-1",
    "eu-west-2",
    "eu-south-1",
    "eu-west-3",
    "eu-north-1",
    "me-south-1",
    "me-central-1",
    "sa-east-1",
    "us-east-1",
    "us-east-2",
    "us-west-1",
    "us-west-2",
    "us-iso-east-1",
    "us-isob-east-1"
  ],
  "searchKeywords": [
    "Secrets",
    "Secrets Manager"
  ],
  "serviceDescription": {
    "aws": "AWS Secrets Manager enables you to rotate, manage, and retrieve secrets throughout their lifecycle, making it easier to maintain a secure environment that meets your security and compliance needs. With Secrets Manager, you pay based on the number of secrets stored and API calls made.",
    "aws-cn": "Amazon Secrets Manager enables you to rotate, manage, and retrieve secrets throughout their lifecycle, making it easier to maintain a secure environment that meets your security and compliance needs. With Secrets Manager, you pay based on the number of secrets stored and API calls made."
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "secretsmanager",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/secretsmanager/[currency]/current/secretsmanager.json"
    }
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/secrets-manager/"
    }
  },
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "id": "awssecretsmanager",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/secrets-manager/"
        }
      },
      "cards": [
        {
          "title": "Secrets configuration",
          "description": "",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/secrets-manager/pricing/"
            }
          },
          "cardType": "",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of secrets",
                "id": "NumberOfSecrets",
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "defaultValue": 1,
                "displayInConfigSummary": true,
                "placeholder": "Enter number of secrets"
              },
              {
                "type": "input",
                "subType": "durationInput",
                "id": "secretDuration",
                "label": "Average duration of each secret",
                "dropDownDuration": [
                  {
                    "label": "days",
                    "value": "day"
                  },
                  {
                    "label": "hours",
                    "value": "hr"
                  }
                ],
                "displayInConfigSummary": true,
                "outputDurationUnit": "day",
                "outputDurationLabel": "days",
                "defaultValue": 30,
                "validations": {
                  "required": false,
                  "allowDecimal": false,
                  "minValue": 0,
                  "maxValue": 30.42
                },
                "placeholder": "Enter the average duration for each secret",
                "description": "Validity timeframe of each secret. A secret valid for an entire month would be 730 hours or 30 days."
              },
              {
                "type": "pricing",
                "label": "price per secret",
                "id": "SM_secretPrice",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "secretsmanager",
                "meteredUnit": {
                  "allRegions": "Secret"
                }
              },
              {
                "type": "pricing",
                "label": "price per API",
                "id": "SM_APIPrice",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "secretsmanager",
                "meteredUnit": {
                  "allRegions": "API Request"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",
                  "label": "Unit conversions",
                  "id": "SM_unitConvert_1",
                  "decimalPlaces": 0,
                  "refer": [
                    "NumberOfSecrets",
                    "secretDuration",
                    "SM_secretPrice",
                    "SM_APIPrice"
                  ],
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "sm_secretdurationmonth",
                  "operation": "division",
                  "operands": [
                    {
                      "variableLabel": "Average duration of each secret",
                      "variableId": "secretDuration",
                      "variableUnitLabel": "days",
                      "required": true
                    },
                    {
                      "constantUnitLabel": "days per month",
                      "constant": 30
                    }
                  ],
                  "outputUnitLabel": "month",
                  "decimalPlaces": 0,
                  "allowDecimal": false
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of secrets",
                      "variableUnitLabel": "secrets per month",
                      "required": false,
                      "variableId": "NumberOfSecrets"
                    },
                    {
                      "variableLabel": "month",
                      "variableUnitLabel": "month",
                      "required": false,
                      "variableId": "sm_secretdurationmonth"
                    },
                    {
                      "variableLabel": "price per secret",
                      "variableId": "SM_secretPrice",
                      "variableUnitLabel": "[currency] per secret per month",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for secrets",
                  "decimalPlaces": 0,
                  "id": "secretPricePerMonth"
                },
                {
                  "type": "display",
                  "refer": [
                    "sm_secretdurationmonth",
                    "secretPricePerMonth"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Secrets cost",
                  "decimalPlaces": 2,
                  "id": "sm_secretsdisp",
                  "subTotalRefer": "secretPricePerMonth"
                }
              ]
            }
          ]
        },
        {
          "title": "API calls",
          "helpText": "",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/secrets-manager/pricing/"
            }
          },
          "expandable": false,
          "defaultExpansion": true,
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "frequency",
                "label": "Number of API calls",
                "id": "numberOfAPIs",
                "options": [
                  {
                    "label": "per hour",
                    "id": "perHour"
                  },
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  },
                  {
                    "label": "billion per month",
                    "id": "billionPerMonth"
                  }
                ],
                "defaultFrequency": "perMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 30000000000
                },
                "placeholder": "Enter number of API calls made",
                "description": "",
                "defaultValue": 1
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",
                  "label": "Unit conversions",
                  "id": "SM_unitConvert",
                  "decimalPlaces": 0,
                  "refer": [
                    "numberOfAPIs"
                  ],
                  "subTotalRefer": "secretPricePerMonth"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of API calls",
                      "variableUnitLabel": "API calls",
                      "required": true,
                      "decimalPlaces": 0,
                      "variableId": "numberOfAPIs"
                    },
                    {
                      "variableLabel": "price per API",
                      "variableUnitLabel": "[currency] per API call",
                      "required": true,
                      "variableId": "SM_APIPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2,
                  "id": "sm_APICost"
                },
                {
                  "type": "display",
                  "refer": [
                    "sm_APICost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "API cost",
                  "decimalPlaces": 2,
                  "id": "sm_SMDisp",
                  "subTotalRefer": "sm_APICost"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "slug": "SecretsManager",
  "partitions": [
    "aws",
    "aws-cn",
    "aws-iso",
    "aws-iso-b",
    "aws-us-gov"
  ]
}
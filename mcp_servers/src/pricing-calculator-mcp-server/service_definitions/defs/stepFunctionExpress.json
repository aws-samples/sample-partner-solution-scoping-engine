                  "outputUnitLabel": "total monthly charges",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "BilledMemoryRounded",
                    "RoundedBilledMemory",
                    "durationsRounded",
                    "Roundedduration",
                    "Avg_Duration_Per_Month",
                    "Avg_Billed_Memory_Per_Month",
                    "Monthly_duration_Charges_GB-s",
                    "Monthly_Request_Charge",
                    "Monthly_Request_Charge_1",
                    "Monthly_Duration_Charge",
                    "Monthly_Duration_Charge_1",
                    "Total_Monthly_Charges"

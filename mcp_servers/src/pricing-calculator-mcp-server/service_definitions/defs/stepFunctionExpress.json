                      "variableUnitLabel": "seconds of execution",
                      "required": true
                    },
                    {
                      "variableId": "BilledMemoryRounded",
                      "variableLabel": "MB of memory consumed by each workflow",
                      "variableUnitLabel": "MB of memory consumed by each workflow",

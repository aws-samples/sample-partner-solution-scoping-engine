                }
              },
              {
                "exists": {
                  "type": "meteredUnit",
                  "mappingDefinitionName": "states",
                  "meteredUnit": "Duration of Workflows from 3600000 to 18000000"
                }
              }
            ]
          },
          "title": "Express Workflows",
          "helpText": {
            "aws": "With AWS Step Functions Express Workflows, you pay only for what you use. You are charged based on the number of requests for your workflow and the duration, the time it takes for your workflow to execute.",
            "aws-cn": "With Amazon Step Functions Express Workflows, you pay only for what you use. You are charged based on the number of requests for your workflow and the duration, the time it takes for your workflow to execute."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/step-functions/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": {
                  "aws": "AWS Step Functions Express Workflows counts a request each time it starts executing a workflow, including tests from the console. You are charged for the total number of requests across all your workflows. Duration is calculated from the time your workflow begins executing until it completes or otherwise terminates, rounded up to the nearest 100 milliseconds, and the amount of memory used in the execution of your workflow, billed in 64-MB chunks.",
                  "aws-cn": "Amazon Step Functions Express Workflows counts a request each time it starts executing a workflow, including tests from the console. You are charged for the total number of requests across all your workflows. Duration is calculated from the time your workflow begins executing until it completes or otherwise terminates, rounded up to the nearest 100 milliseconds, and the amount of memory used in the execution of your workflow, billed in 64-MB chunks."
                },
                "id": "Express_workflow_0"
              },
              {
                "type": "input",
                "subType": "alert",
                "header": "Express Workflows pricing",
                "content": {
                  "aws": "Please refer to Example 3 on the AWS Step Functions <a href='https://aws.amazon.com/step-functions/pricing/'target='_blank'> pricing page</a> to understand Express workflows pricing breakdown.",
                  "aws-cn": "Please refer to Example 3 on the Amazon Step Functions <a href='https://www.amazonaws.cn/en/step-functions/pricing'target='_blank'> pricing page</a> to understand Express workflows pricing breakdown."
                },
                "alertType": "info",
                "isDismissable": true,
                "id": "awsStepExpressFunctionAlert"
              },
              {
                "type": "input",
                "subType": "frequency",
                "label": "Workflow requests",
                "id": "MonthlyWorkflowReqs",
                "defaultValue": "",
                "options": [
                  {
                    "label": "per hour",
                    "id": "perHour"
                  },
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 100000000000000000
                },
                "placeholder": "Enter number of workflow requests",
                "description": {
                  "aws": "AWS Step Functions Express Workflows counts a request each time it starts executing a workflow, including tests from the console.",
                  "aws-cn": "Amazon Step Functions Express Workflows counts a request each time it starts executing a workflow, including tests from the console."
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Average duration of workflow",
                "label": "Duration of each workflow",
                "displayInConfigSummary": true,
                "defaultValue": 500,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 100,
                  "maxValue": 300000
                },
                "description": "Duration is calculated from the time your workflow begins executing until it completes or otherwise terminates, rounded up to the nearest 100 milliseconds.",
                "placeholder": "Please enter duration in Milliseconds "
              },
              {
                "type": "input",
                "subType": "fileSize",
                "id": "stateMachineDefinitionSize",
                "label": "Memory consumed by each workflow",
                "dropDownSize": [
                  {
                    "label": "MB",
                    "id": "mb"
                  },
                  {
                    "label": "GB",
                    "id": "gb"
                  }
                ],
                "defaultOption": {
                  "size": "mb",
                  "frequency": "NA"
                },
                "outputSize": "mb",
                "outputSizeLabel": "MB",
                "outputFrequency": "NA",
                "outputFrequencyLabel": "NA",
                "defaultValue": 64,
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 3072
                },
                "placeholder": "Enter State Machine Definition Size",
                "description": "Memory consumption is based on the size of a workflow definition, the use of map or parallel states, and the execution (payload) data size.",
                "help": ""
              },
              {
                "type": "pricing",
                "id": "workflowRequestCost",
                "label": "Price for 1M worflow Requests",

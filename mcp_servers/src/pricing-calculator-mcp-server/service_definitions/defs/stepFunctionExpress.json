                  "tieredPricingReferLabel": "Tierd_Pricing_Express_Step_Function",
                  "inputUnitLabel": "GB-seconds",
                  "decimalPlaces": 2,
                  "id": "Monthly_Duration_Charge",
                  "outputUnitLabel": "[currency] for monthly duration charges"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Monthly duration charges",

                  "operands": [
                    {
                      "variableId": "MonthlyWorkflowReqs",
                      "variableLabel": "Workflow requests",
                      "variableUnitLabel": "workflow requests",
                      "required": true
                    },
                    {
                      "variableId": "workflowRequestCost",
                      "variableLabel": "Price for 1M worflow Requests",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for monthly request charges",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Monthly request charges",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] for monthly request charges",

                    {
                      "startOfTier": 3600001,
                      "endOfTier": 18000000,
                      "meteredUnit": "Duration of Workflows from 3600000 to 18000000"
                    },
                    {
                      "startOfTier": 18000001,
                      "endOfTier": -1,
                      "meteredUnit": "Duration of Workflows over 18000000"
                    }
                  ]
                }
              }
            ]

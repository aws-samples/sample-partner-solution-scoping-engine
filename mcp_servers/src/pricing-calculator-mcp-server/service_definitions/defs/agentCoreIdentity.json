        {
          "title": "Identity",
          "helpText": {
            "aws": "AgentCore Identity enables the AI agent to maintain context and memory across multiple interactions with users."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/bedrock/agentcore/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "alert",
                "header": "",
                "label": "info alert",
                "content": "AgentCore Identity is available at no additional charge to customers when they use it through either AgentCore Runtime or AgentCore Gateway",
                "alertType": "info",
                "isDismissable": true,
                "id": "info"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_agentsessions_per_month",
                "label": "Number of agent sessions per month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 100000000000000000
                },
                "description": "The total number of agent sessions expected to run per month"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Average_tool_invocations_per_session",
                "label": "Average number of tool invocations per session",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 10000
                },
                "description": "The average number of times agent calls a tool API (includes ListTools and InvokeTool) within a single session"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Average_tokens_per_tool",
                "label": "Average tokens requested per Tool use",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100000
                },
                "description": "average number of tokens consumed each time the AI agent invokes one of its configured tools"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Average_tokens_per_user",
                "label": "Average tokens per user",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 100000
                },
                "description": "the average number of tokens consumed for all interactions by a single user over a specified time period"
              },
              {
                "type": "pricing",
                "id": "Price_for_identity",
                "label": "Price for identity",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "cognito",
                "meteredUnit": {
                  "allRegions": "qjre4o-QjF62pK0Kosxy5el4_XMeMwnI1xYXEKL2KKo"
                }
              }
            ]
          },

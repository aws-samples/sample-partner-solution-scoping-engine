{
  "version": "0.0.6",
  "serviceName": "AWS Device Farm",
  "serviceCode": "awsDeviceFarm",
  "type": "AWSService",
  "excludeZeroSubTotals": true,
  "slug": "DeviceFarm",
  "regions": [
    "us-west-2"
  ],
  "serviceDescription": "AWS Device Farm is an application testing service that lets you improve the quality of your web and mobile apps by testing them across an extensive range of desktop browsers and real mobile devices; without having to provision and manage any testing infrastructure. The service enables you to run your tests concurrently on multiple desktop browsers or real devices to speed up the execution of your test suite, and generates videos and logs to help you quickly identify issues with your app.",
  "searchKeywords": [
    "application testing",
    "mobile devices",
    "desktop browsers",
    "device farm",
    "automated testing",
    "remote access",
    "iOS",
    "Android",
    "unlimited testing",
    "pay as you go",
    "device minutes",
    "device slots",
    "free device minutes",
    "browser instances"
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/device-farm/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "devicefarm",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/devicefarm/[currency]/current/devicefarm.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "description": "",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/device-farm/"
        }
      },
      "cards": [
        {
          "title": "Mobile Devices",
          "helpText": "Test your app in parallel against a massive collection of physical devices in the AWS Cloud. Use one of our built-in frameworks, to test your applications without having to write or maintain test scripts, or use one of our supported automation testing frameworks. Or, using Remote Access to gesture, swipe, and interact with devices in real time, directly from your web browser.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/device-farm/pricing/"
            }
          },
          "expandable": true,
          "defaultExpansion": true,
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "dropdown",
                "id": "DeviceOS",
                "label": "Device OS",
                "mappingDefinitionName": "devicefarm",
                "options": [
                  {
                    "label": "iOS",
                    "id": "ios"
                  },
                  {
                    "label": "Android",
                    "id": "android"
                  },
                  {
                    "label": " ",
                    "id": "none"
                  }
                ],
                "displayInConfigSummary": true,
                "defaultDropDownItem": "none",
                "description": "",
                "validations": {
                  "required": false
                }
              },
              {
                "type": "input",
                "subType": "dropdown",
                "id": "usageType",
                "label": "Usage type",
                "options": [
                  {
                    "label": "Pay as you go",
                    "id": "PayAsYouGo"
                  },
                  {
                    "label": "Unlimited testing",
                    "id": "unlimited"
                  },
                  {
                    "label": "Private devices",
                    "id": "privateDevice"
                  },
                  {
                    "label": " ",
                    "id": "none"
                  }
                ],
                "displayInConfigSummary": true,
                "defaultDropDownItem": "none",
                "description": "",
                "validations": {
                  "required": false
                }
              },
              {
                "displayIf": {
                  "==": [
                    {
                      "type": "component",
                      "id": "usageType"
                    },
                    "PayAsYouGo"
                  ]
                },
                "type": "input",
                "subType": "bodyText",
                "text": "Pay-as-you-go pricing is based on device minutes, which are determined by the number of devices you use and the duration of your automated tests and remote access sessions.AWS Device Farm comes with a one-time free trial of 1000 device minutes.The calculations below exclude first 1000 free minutes.",
                "id": "PayAsYouGoText"
              },
              {
                "displayIf": {
                  "==": [
                    {
                      "type": "component",
                      "id": "usageType"
                    },
                    "PayAsYouGo"
                  ]
                },
                "type": "input",
                "subType": "numericInput",
                "label": "Number of devices minutes per month",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 10000000000
                },
                "description": "Exclude first 1000 free charge minutes",
                "displayInConfigSummary": true,
                "placeholder": "Enter monthly device minutes (exclude first 1000 minutes)",
                "id": "deviceMinutes"
              },
              {
                "displayIf": {
                  "==": [
                    {
                      "type": "component",
                      "id": "usageType"
                    },
                    "unlimited"
                  ]
                },
                "type": "input",
                "subType": "bodyText",
                "text": "Unmetered plans allow unlimited testing and remote access priced at per monthly rate. Unmetered pricing is based on the number of device slots you purchase for each usage type (i.e. automated test or remote access) and device family (i.e. Android or iOS) priced per slot per month. Slots are not tied to a specific device make or model.",
                "id": "UnlimitedText"
              },
              {
                "displayIf": {
                  "==": [
                    {
                      "type": "component",
                      "id": "usageType"
                    },
                    "unlimited"
                  ]
                },
                "type": "input",
                "subType": "numericInput",
                "label": "Number of devices slots per month",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 10000000000
                },
                "description": "",
                "displayInConfigSummary": true,
                "placeholder": "Enter monthly device slots",
                "id": "deviceSlot"
              },
              {
                "displayIf": {
                  "==": [
                    {
                      "type": "component",
                      "id": "usageType"
                    },
                    "privateDevice"
                  ]
                },
                "type": "input",
                "subType": "alert",
                "header": "Private device",
                "content": "Starting at $200/month. <a href='mailto:aws-devicefarm-support@amazon.com'>Contact us</a> for a custom quote.",
                "alertType": "info",
                "partitions": [
                  "aws"
                ],
                "isDismissable": true,
                "id": "alertInfoPrivateDevice"
              },
              {
                "type": "pricing",
                "subType": "concatenate",
                "label": "os usage type combination",
                "id": "osUsageType",
                "operands": [
                  {
                    "variableId": "DeviceOS"
                  },
                  {
                    "variableId": "usageType"
                  }
                ]
              },
              {
                "type": "pricing",
                "subType": "replace",
                "id": "DeviceMUs",
                "label": "Device metered unit name",
                "originalId": "osUsageType",
                "replacements": [
                  {
                    "originalString": "iosPayAsYouGo",
                    "replaceString": "Pay as you go automated tests on iOS per Minutes"
                  },
                  {
                    "originalString": "androidPayAsYouGo",
                    "replaceString": "Pay as you go automated tests on Android per Minutes"
                  }
                ]
              },
              {
                "type": "pricing",
                "subType": "replace",
                "id": "DeviceSlotMUs",
                "label": "Device slot metered unit name",
                "originalId": "osUsageType",
                "replacements": [
                  {
                    "originalString": "iosunlimited",
                    "replaceString": "Unlimited Slot for automated tests on iOS per Device Slot-Month"
                  },
                  {
                    "originalString": "androidunlimited",
                    "replaceString": "Unlimited Slot for automated tests on Android per Device Slot-Month"
                  }
                ]
              },
              {
                "type": "pricing",
                "subType": "pricingComboV2",
                "label": "Price for device",
                "id": "DevicePrice",
                "mappingDefinitionName": "devicefarm",
                "decimalPlaces": 4,
                "refers": [
                  {
                    "variableLabel": "Device metered unit name",
                    "variableId": "DeviceMUs"
                  }
                ]
              },
              {
                "type": "pricing",
                "subType": "pricingComboV2",
                "label": "Price for device slot",
                "id": "DeviceSlotPrice",
                "mappingDefinitionName": "devicefarm",
                "decimalPlaces": 4,
                "refers": [
                  {
                    "variableLabel": "Device slot metered unit name",
                    "variableId": "DeviceSlotMUs"
                  }
                ]
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "DeviceOS",
                    "usageType",
                    "PayAsYouGoText",
                    "deviceMinutes",
                    "UnlimitedText",
                    "deviceSlot",
                    "alertInfoPrivateDevice",
                    "osUsageType",
                    "DeviceMUs",
                    "DeviceSlotMUs",
                    "DevicePrice",
                    "DeviceSlotPrice"
                  ],
                  "subTotalRefer": "",
                  "id": "unitConversion"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "variableName": "Pay as you go monthly cost",
                  "operands": [
                    {
                      "variableId": "deviceMinutes",
                      "variableLabel": "Number of devices minutes per month",
                      "variableUnitLabel": "minutes",
                      "required": true
                    },
                    {
                      "variableId": "DevicePrice",
                      "variableLabel": "Price for device",
                      "variableUnitLabel": "[currency] / device  minute",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency](Pay as you go monthly cost)",
                  "decimalPlaces": 2,
                  "id": "PayAsYouGoMonthlyCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "variableName": "Unlimited testing monthly cost",
                  "operands": [
                    {
                      "variableId": "deviceSlot",
                      "variableLabel": "Number of devices slots per month",
                      "variableUnitLabel": "slots",
                      "required": true
                    },
                    {
                      "variableId": "DeviceSlotPrice",
                      "variableLabel": "Price for device slot",
                      "variableUnitLabel": "[currency] per slot per month",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (Unlimited testing monthly cost)",
                  "decimalPlaces": 2,
                  "id": "UnlimitedMonthlyCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "addition",
                  "variableName": "Total Mobile Device cost",
                  "operands": [
                    {
                      "variableId": "PayAsYouGoMonthlyCost",
                      "variableLabel": "Pay as you go monthly cost",
                      "variableUnitLabel": "[currency] (Pay as you go)",
                      "required": false
                    },
                    {
                      "variableId": "UnlimitedMonthlyCost",
                      "variableLabel": "Unlimited testing monthly cost",
                      "variableUnitLabel": "[currency] (Unlimited testing)",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency](total monthly cost)",
                  "decimalPlaces": 2,
                  "id": "totalMobileDeviceCost"
                },
                {
                  "type": "display",
                  "refer": [
                    "PayAsYouGoMonthlyCost",
                    "UnlimitedMonthlyCost",
                    "totalMobileDeviceCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Mobile device total cost",
                  "decimalPlaces": 2,
                  "id": "totalMobileDeviceCostDisplay",
                  "subTotalRefer": "totalMobileDeviceCost"
                }
              ]
            }
          ]
        },
        {
          "title": "Desktop Browsers",
          "helpText": "Test on any of our desktop browser instances in parallel and pay just for the total duration it takes for your test to execute. Test duration is calculated in minutes, from the time your tests start executing on the browser instance until your test is terminated.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/device-farm/pricing/"
            }
          },
          "expandable": true,
          "defaultExpansion": true,
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "dropdown",
                "id": "browsers",
                "label": "Browser type",
                "mappingDefinitionName": "devicefarm",
                "options": [
                  {
                    "label": "Chrome",
                    "id": "automated testing minutes on Windows OS and Chrome per minutes"
                  },
                  {
                    "label": "Firefox",
                    "id": "automated testing minutes on Windows OS and Firefox per minutes"
                  },
                  {
                    "label": "Edge",
                    "id": "automated testing minutes on Windows OS and Edge per minutes"
                  },
                  {
                    "label": "IE",
                    "id": "automated testing minutes on Windows OS and IE per minutes"
                  }
                ],
                "displayInConfigSummary": true,
                "defaultDropDownItem": "Chrome",
                "description": "",
                "validations": {
                  "required": false
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of browser instance minutes per month (Pay as you go)",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 10000000000
                },
                "description": "",
                "displayInConfigSummary": true,
                "placeholder": "Enter monthly browser instances minutes",
                "id": "browserMinutes"
              },
              {
                "type": "pricing",
                "subType": "pricingComboV2",
                "label": "Price for browser instances",
                "id": "browserInstancePrice",
                "mappingDefinitionName": "devicefarm",
                "decimalPlaces": 4,
                "refers": [
                  {
                    "variableLabel": "Browser type",
                    "variableId": "browsers"
                  }
                ]
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "browsers",
                    "browserMinutes",
                    "browserInstancePrice"
                  ],
                  "subTotalRefer": "totalMobileDeviceCost",
                  "id": "unitConversionBrowser"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "variableName": "Browser instances pay as you go monthly cost-",
                  "operands": [
                    {
                      "variableId": "browserMinutes",
                      "variableLabel": "Number of browser instance minutes per month (Pay as you go)",
                      "variableUnitLabel": "minutes",
                      "required": true
                    },
                    {
                      "variableId": "browserInstancePrice",
                      "variableLabel": "Price for browser instances",
                      "variableUnitLabel": "[currency] / instance  minute",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (Pay as you go monthly cost)",
                  "decimalPlaces": 2,
                  "id": "browserInstancePayAsYouGoCost"
                },
                {
                  "type": "display",
                  "refer": [
                    "browserInstancePayAsYouGoCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Desktop browser instances total cost",
                  "decimalPlaces": 2,
                  "id": "totalDeskTopBrowserCost",
                  "subTotalRefer": "browserInstancePayAsYouGoCost"
                }
              ]
            }
          ]
        }
      ],
      "id": "template_0"
    }
  ],
  "partitions": [
    "aws"
  ]
}
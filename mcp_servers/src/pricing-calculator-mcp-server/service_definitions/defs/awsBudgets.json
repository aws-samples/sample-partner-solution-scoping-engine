                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 1000000000000000
                },
                "description": "Amazon Web Services Budgets Reports allow you to monitor the performance of your budget portfolio on a daily, weekly, or monthly basis by receiving an emailed report.",

                  "costType": "Monthly",
                  "label": "Total On demand Cost for Multimodal Embeddings",
                  "decimalPlaces": 2,
                  "id": "TotalOndemandMonthlyCost_ME_2",
                  "subTotalRefer": "TotalOndemandMonthlyCost_ME"
                }
              ]
            }
          ]

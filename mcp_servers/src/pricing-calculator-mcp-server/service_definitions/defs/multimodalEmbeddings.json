                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "thousand per month",
                    "id": "thousandPerMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  }
                ],
                "defaultFrequency": "millionPerMonth",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"

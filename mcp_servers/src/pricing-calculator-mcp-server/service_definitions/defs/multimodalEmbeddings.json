                  "outputUnitLabel": "[currency] per Month for input tokens",
                  "decimalPlaces": 4
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "TotalOndemandMonthlyCost_ME",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableId": "inputimageMonthlyCost_ME",
                      "variableLabel": "[currency] per Month for input images",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    },
                    {
                      "variableId": "inputtokenMonthlyCost_ME",
                      "variableLabel": "[currency] per Month for input tokens",
                      "variableUnitLabel": "[currency]",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency] per Month",
                  "decimalPlaces": 4

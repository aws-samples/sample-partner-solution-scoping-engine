                    {
                      "variableId": "noOfInputImages_1",
                      "variableLabel": "Number of Input Images",
                      "variableUnitLabel": "input images",
                      "required": true
                    },
                    {
                      "variableId": "inputimageprice_1",
                      "variableLabel": "Price for input images for multimodal embeddings",
                      "variableUnitLabel": "[currency] per month",

          "title": "IoT Events",
          "defaultExpansion": true,
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "Message evaluation are metered in 1KB increments, and each message can trigger up to 2 external actions. Each set of 2 additional actions is metered as a new message evaluation.",
                "id": "messageingTxt"
              },
              {
                "type": "input",
                "subType": "bodyText",
                "text": "AWS IoT Events can trigger actions to external AWS services when it detects a specified event or a state transition, such as invoking an AWS Lambda function to turn on a light when an occupancy sensor detects motion. There is no additional charge for triggering up to 2 such actions for each message evaluation. Incoming messages that trigger more than 2 actions are metered as additional message evaluations, in increments of 2 actions triggered. For example, the evaluation of a single message that triggers 2 actions will be treated as 1 message evaluation. The evaluation of a message that triggers 4 actions will be treated as 2 message evaluations.",
                "id": "actionTrigText"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "numberOfDevices",
                "label": "Number of devices",
                "description": "Enter the number of devices you will utilize.",
                "displayInConfigSummary": true,
                "defaultValue": 1,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 10000000000
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "numberOfMessages",
                "label": "Number of messages for a device including timer expiry messages",
                "description": "Enter the number of messages expected into AWS IoT events by the device or internally triggered by timer expiry in a month.",
                "displayInConfigSummary": true,
                "defaultValue": 1,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 30000000
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "numberOfModels",
                "label": "Number of event detector models per device",
                "description": "Enter number of event detector models per device.",
                "displayInConfigSummary": true,
                "defaultValue": 1,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 150
                }
              },
              {
                "type": "input",
                "subType": "fileSize",
                "label": "Average size of each message",
                "id": "dataPerMessage",
                "dropDownSize": [
                  {
                    "label": "Bytes",
                    "id": "bytes"
                  },
                  {
                    "label": "KB",
                    "id": "kb"
                  }
                ],
                "defaultOption": {
                  "size": "kb",
                  "frequency": "NA"
                },
                "outputSize": "kb",
                "defaultValue": 1,
                "outputSizeLabel": "KB",
                "outputFrequency": "NA",
                "outputFrequencyLabel": "NA",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 1e-06,
                  "maxValue": 10
                },
                "placeholder": "Enter amount",
                "description": "Messages are metered in 1 KB increments."
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "Number_of_actions_triggered_per_message",
                "label": "Number of actions triggered per message",
                "description": "Enter number of actions per message evaluation.",
                "displayInConfigSummary": true,
                "defaultValue": 1,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 10000000000000
                }
              },
              {

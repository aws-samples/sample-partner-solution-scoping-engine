                  {
                    "label": "Bytes",
                    "id": "bytes"
                  },
                  {
                    "label": "KB",
                    "id": "kb"
                  }
                ],
                "defaultOption": {
                  "size": "kb",
                  "frequency": "NA"
                },
                "outputSize": "kb",
                "defaultValue": 1,
                "outputSizeLabel": "KB",
                "outputFrequency": "NA",
                "outputFrequencyLabel": "NA",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,

    {
      "cards": [
        {
          "title": "Devices",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "id": "numberOfDevices",
                "label": "Number of devices (LoRaWAN)",
                "description": "Enter the number of devices you will utilize.",
                "displayInConfigSummary": true,
                "defaultValue": 1,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 10000000000
                }
              }
            ]
          }
        },
        {
          "title": "Messaging",
          "expandable": true,
          "defaultExpansion": true,
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": {
                  "aws": "To estimate your monthly costs, enter the number of messages you expect to transmit. You are charged for messages sent in both directions, from a device to AWS IoT Core and from AWS IoT Core to a device.<a href='https://aws.amazon.com/iot-core/pricing/additional-details/#LoRaWAN_Metering'target='_blank'> Learn more about LoRaWAN metering details</a>.",
                  "aws-cn": "To estimate your monthly costs, enter the number of messages you expect to transmit. You are charged for messages sent in both directions, from a device to Amazon IoT Core and from Amazon IoT Core to a device.<a href='https://www.amazonaws.cn/en/iot-core/pricing/'> Learn more about LoRaWAN metering details</a>."
                },
                "id": "messagingText1"
              },
              {
                "displayIf": {
                  "and": [
                    {
                      "exists": {
                        "type": "meteredUnit",
                        "mappingDefinitionName": "iot",
                        "meteredUnit": "LoRaWAN Messages Up to 1B"
                      }
                    },
                    {
                      "exists": {
                        "type": "meteredUnit",
                        "mappingDefinitionName": "iot",
                        "meteredUnit": "LoRaWAN Messages Next 4B"
                      }
                    },
                    {
                      "exists": {
                        "type": "meteredUnit",
                        "mappingDefinitionName": "iot",
                        "meteredUnit": "LoRaWAN Messages Over 5B"
                      }
                    }
                  ]
                },
                "type": "input",
                "subType": "numericInput",
                "id": "numberOfMessagesLoRaWAN",
                "label": "Number of messages for a device",
                "description": {
                  "aws": "Enter the number of messages transmitted between a device and AWS IoT Core in a month.",
                  "aws-cn": "Enter the number of messages transmitted between a device and Amazon IoT Core in a month."
                },
                "displayInConfigSummary": true,
                "defaultValue": 1,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1000000000000
                }
              },
              {
                "type": "pricing",
                "subType": "tieredPricing",
                "label": "Price for messages per month LoRaWAN",
                "id": "tieredMessagePricingLoRaWAN",
                "mappingDefinitionName": "iot",
                "backwardCompatibility": {
                  "hideCardWhenMissing": true
                },
                "tiers": {
                  "allRegions": [
                    {
                      "startOfTier": 0,
                      "endOfTier": 1000000000,
                      "meteredUnit": "LoRaWAN Messages Up to 1B"
                    },
                    {
                      "startOfTier": 1000000001,
                      "endOfTier": 5000000000,
                      "meteredUnit": "LoRaWAN Messages Next 4B"
                    },
                    {
                      "startOfTier": 5000000001,
                      "endOfTier": -1,
                      "meteredUnit": "LoRaWAN Messages Over 5B"
                    }
                  ]
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "id": "l_mes_UnitConv",
                  "refer": [
                    "messagingText1",
                    "numberOfMessagesLoRaWAN",
                    "tieredMessagePricingLoRaWAN"
                  ],
                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "messageLoraWANMultiple",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "numberOfMessagesLoRaWAN",
                      "variableLabel": "Number of messages for a device",
                      "variableUnitLabel": "messages per month",
                      "required": true
                    },
                    {
                      "variableId": "numberOfDevices",
                      "variableLabel": "Number of devices (LoRaWAN)",
                      "variableUnitLabel": "devices",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "total billable messages",
                  "decimalPlaces": 0
                },
                {
                  "type": "maths",
                  "subType": "tieredPricingMath",
                  "id": "tieredMsgLoRaWANMonthlyCost",
                  "tieredPricingRefer": "tieredMessagePricingLoRaWAN",
                  "tieredPricingReferLabel": "Price for messages per month LoRaWAN",
                  "inputRefer": "messageLoraWANMultiple",
                  "inputReferLabel": "total billable messages",
                  "outputUnitLabel": "[currency]",
                  "inputUnitLabel": "Messages",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "messageLoraWANMultiple",
                    "tieredMsgLoRaWANMonthlyCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "LoRaWAN Message cost",
                  "decimalPlaces": 2,
                  "id": "LoRaWANmessageTotalPrice",
                  "subTotalRefer": "tieredMsgLoRaWANMonthlyCost"
                }
              ]
            }
          ]
        },
        {
          "title": "Device Shadow",

{
  "version": "0.0.14",
  "serviceName": "LoRaWAN",
  "serviceCode": "awsIoTCoreLoRaWan",
  "type": "AWSService",
  "subType": "subService",
  "regions": [
    "us-east-1",
    "eu-west-1",
    "cn-north-1",
    "cn-northwest-1"
  ],
  "searchKeywords": [
    "iot",
    "device",
    "messages",
    "shadow",
    "registry",
    "rules",
    "device shadow",
    "rules engine",
    "basic ingest",
    "mqtt",
    "LoRaWAN"
  ],
  "serviceDescription": {
    "aws": "AWS IoT Core is a managed cloud service that lets connected devices easily and securely interact with cloud applications and other devices.",
    "aws-cn": "Amazon IoT Core is a managed cloud service that lets connected devices easily and securely interact with cloud applications and other devices.",
    "aws-us-gov": "AWS IoT Core is a managed cloud service that lets connected devices easily and securely interact with cloud applications and other devices."
  },
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/iot-core/",
      "overrides": {
        "aws-cn": "https://www.amazonaws.cn/en/iot-core/pricing/"
      }
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "iot",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/iot/[currency]/current/iot.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",

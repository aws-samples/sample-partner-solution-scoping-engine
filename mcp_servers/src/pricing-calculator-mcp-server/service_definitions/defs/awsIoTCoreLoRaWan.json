                    "meteredUnit": "RulesTriggered"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "id": "numberOfBasicIngestRules",
                "label": "Average number of rules triggered by a message",
                "description": "Enter the average number of rules triggered by a message.",
                "displayInConfigSummary": true,
                "defaultValue": 0,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 10000
                }
              },
              {
                "displayIf": {
                  "exists": {
                    "type": "meteredUnit",
                    "mappingDefinitionName": "iot",
                    "meteredUnit": "ActionsExecuted"
                  }
                },
                "type": "input",
                "subType": "numericInput",
                "id": "numberOfBasicIngestActions",
                "label": "Average number of actions executed per rule",
                "description": "Enter the average number of actions executed per rule by a device.",
                "displayInConfigSummary": true,
                "defaultValue": 1,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 10

                    },
                    {
                      "variableId": "numberOfMessagesLoRaWAN",
                      "variableLabel": "Number of messages for a device",
                      "variableUnitLabel": "message(s)",
                      "required": true
                    },
                    {
                      "variableId": "numberOfDevices",
                      "variableLabel": "Number of devices (LoRaWAN)",
                      "variableUnitLabel": "devices",

                  "id": "l_ds_UnitConv",
                  "refer": [
                    "numberOfShadowOperations",
                    "dataPerShadowOperation",
                    "shadowOperationPricing"
                  ],
                  "subTotalRefer": "tieredMsgLoRaWANMonthlyCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "opShadowRecordSizeDiv",
                  "operation": "division",
                  "outputUnitLabel": "record(s)",
                  "decimalPlaces": 0,
                  "operands": [
                    {
                      "variableId": "dataPerShadowOperation",
                      "variableLabel": "Average size of each record",
                      "variableUnitLabel": "KB per record",
                      "required": true
                    },
                    {
                      "constant": 1,
                      "constantUnitLabel": "KB record increment"
                    }
                  ]
                },
                {
                  "type": "maths",
                  "subType": "rounding",
                  "method": "roundUp",
                  "factor": 1,
                  "id": "operationShadowRounded",
                  "operationLabel": "RoundUp",
                  "outputUnitLabel": "billable operation(s)",
                  "operands": [
                    {
                      "variableId": "opShadowRecordSizeDiv",
                      "variableLabel": "record(s)",
                      "variableUnitLabel": "record(s)",
                      "required": true
                    }
                  ]
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "operationShadowMonthlyCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "numberOfShadowOperations",
                      "variableLabel": "Number of Shadow operations for a device",
                      "variableUnitLabel": "operations per month",
                      "required": true
                    },
                    {
                      "variableId": "operationShadowRounded",
                      "variableLabel": "billable operation(s)",
                      "variableUnitLabel": "billable operation(s)",
                      "required": true
                    },
                    {
                      "variableId": "shadowOperationPricing",
                      "variableLabel": "Price per operation",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    },
                    {
                      "variableId": "numberOfDevices",
                      "variableLabel": "Number of devices (LoRaWAN)",
                      "variableUnitLabel": "devices",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] per month",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "opShadowRecordSizeDiv",
                    "operationShadowRounded",
                    "operationShadowMonthlyCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Device Shadow operations cost",
                  "decimalPlaces": 2,
                  "id": "operationShadowTotalPrice",
                  "subTotalRefer": "operationShadowMonthlyCost"
                }
              ]
            }
          ]
        },
        {

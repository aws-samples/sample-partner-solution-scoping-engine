                  "operation": "multiplication",
                  "variableName": "Total Output 1 cost",
                  "operands": [
                    {
                      "variableId": "emlAddOn1_numberOfChannels",
                      "variableLabel": "Number of channels",
                      "variableUnitLabel": "channel(s)",
                      "required": true
                    },
                    {
                      "variableId": "emlAddOn1_totalActiveHours",
                      "variableLabel": "total active hours",
                      "variableUnitLabel": "active hours",
                      "required": true
                    },
                    {
                      "variableLabel": "Audio Cost",
                      "variableUnitLabel": "[currency] per month",
                      "required": true,
                      "variableId": "emlAddOn1_ipmPrice",
                      "IPMSupported": true
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2,
                  "id": "emlAddOn1_costMonthly"

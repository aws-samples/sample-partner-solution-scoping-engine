    {
      "title": "Elemental Media Live Add-On Functionality",
      "description": "",
      "id": "emlAddOnFunctions",
      "volumeDiscountEligibility": false,
      "helpText": "These rates are applied at the channel level, rather than by individual input or output. Advanced audio includes Additional Audio Encoders to support outputs for Dolby Digital (AC3), Dolby Digital Plus (EAC3), and Audio Normalization uses technology from DTS to enable monitoring and correction in accordance with the ITU-R BS.1770 standard and logging compliant with the CALM ACT (ATSC A/85).",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/medialive/",
          "overrides": {
            "aws-iso": "https://awshome.ic.gov/medialive/pricing/"
          }
        }
      },
      "cards": [
        {
          "title": "Add-On Functionality Configuration 1",
          "helpText": "These rates are applied at the channel level, rather than by individual input or output. Motion Graphics usage is billed based on the largest input or output resolution specified in the channel. Channels with SD only inputs and outputs will be billed at the HD rate. Advanced audio includes additional audio encoders to support outputs for Dolby Digital (AC3), Dolby Digital Plus (EAC3), and Dolby Atmos (EAC3 ATMOS). Audio Normalization uses technology from DTS to enable monitoring and correction in accordance with the ITU-R BS.1770 standard and logging compliant with the CALM ACT (ATSC A/85).",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/medialive/pricing/",
              "overrides": {
                "aws-iso-b": "https://awshome.scloud/medialive/"
              }
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "These rates are applied at the channel level, rather than by individual input or output.",
                "id": "emlAddOn1_Text"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of channels",
                "id": "emlAddOn1_numberOfChannels",
                "description": "Number of channels with matching Add-On functionality configuration",
                "defaultValue": 1,
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1000000000
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "displayIf": {
                  "==": [
                    {
                      "type": "component",
                      "id": "emlAddOn1_resType"
                    },
                    "On Demand"
                  ]
                },
                "label": "Active hours (On Demand)",
                "id": "emlAddOn1_activeOutputHrs",
                "placeholder": "Enter number of hours",
                "description": "Number of hours per month an add on is in a running state.",
                "defaultValue": 730,
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 730
                }
              },
              {
                "type": "input",
                "subType": "numericInput",
                "displayIf": {
                  "==": [
                    {
                      "type": "component",
                      "id": "emlAddOn1_resType"
                    },
                    "1 Year"
                  ]
                },
                "label": "Active hours (Reserved)",
                "id": "emlAddOn1_activeOutputHrsReserved",
                "placeholder": "Enter number of hours",
                "description": "Number of hours per month an add on is in a running state. 730 hours per month fixed for 1 Year terms.",
                "defaultValue": 730,
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 730,
                  "maxValue": 730
                }
              },
              {
                "label": "Elemental Media Live AddOn",
                "id": "columnFormIPM",
                "type": "input",
                "subType": "columnFormIPM",
                "disableCalculation": true,
                "mappingDefinitionName": "elementalmedialive-addon-calc",
                "calculationId": {
                  "hourly": "emlAddOn1_ipmPrice"
                },
                "primaryKey": "Output",
                "secondaryKey": [
                  "Pipeline",
                  "Reserve Type"
                ],
                "row": [
                  {
                    "label": "Pipeline",
                    "type": "dropDown",
                    "selectorId": "Pipeline",
                    "defaultValue": "Standard",
                    "exportValueAs": "emlAddOn1_pipe"
                  },
                  {
                    "label": "Add-On functionality",
                    "type": "dropDown",
                    "selectorId": "Output",
                    "defaultValue": "Advanced Audio",
                    "exportValueAs": "emlAddOn1_AddOnFunction",
                    "dependent": [
                      "Pipeline"
                    ]
                  },
                  {
                    "label": "Term",
                    "type": "dropDown",
                    "selectorId": "Reserve Type",
                    "defaultValue": "On Demand",
                    "exportValueAs": "emlAddOn1_resType",
                    "dependent": [
                      "Pipeline",
                      "Output"
                    ]
                  }
                ]
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "Audio Cost",
                  "id": "emlAddOn1_CostVariable",
                  "decimalPlaces": 2,
                  "IPMSupported": true,
                  "refer": [
                    "emlAddOn1_ipmPrice"
                  ],
                  "subTotalRefer": "emlAddOn1_ipmPrice"

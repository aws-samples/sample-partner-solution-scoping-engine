                    "emlAddOn1_resType",
                    "emlAddOn1_CostVariable",
                    "emlAddOn1_totalActiveHours",
                    "emlAddOn1_costMonthly"
                  ],
                  "required": true,
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Total cost for Add-On configuration 1",
                  "decimalPlaces": 2,
                  "id": "emlAddOn1_CostTotal",
                  "subTotalRefer": "emlAddOn1_costMonthly"
                }
              ]
            }

{
  "version": "0.0.82",
  "serviceName": "DynamoDB Accelerator (DAX) clusters",
  "serviceCode": "amazonDynamoDbDaxClusters",
  "type": "AWSService",
  "subType": "subService",
  "regions": [
    "us-east-1",
    "us-east-2",
    "us-west-1",
    "us-west-2",
    "ap-south-1",
    "ap-southeast-1",
    "ap-southeast-2",
    "ap-northeast-1",
    "eu-central-1",
    "eu-west-1",
    "eu-west-2",
    "eu-west-3",
    "sa-east-1",
    "cn-north-1",
    "cn-northwest-1"
  ],
  "searchKeywords": [
    "Database",
    "DDB",
    "NoSQL",
    "SQL",
    "Table",
    "nosql databases",
    "database schema",
    "database software",
    "cloud database",
    "document database",
    "key value store",
    "database as a service",
    "database scheme",
    "nosql hosting",
    "hosted nosql",
    "data store",
    "unstructured database",
    "Accelerator",
    "DAX"
  ],
  "serviceDescription": "Amazon DynamoDB is a key-value and document database that delivers single-digit millisecond performance at any scale. It's a fully managed, multiregion, multimaster, durable database with built-in security, backup and restore, and in-memory caching for internet-scale applications.",
  "linkUrl": {
    "aws": "https://aws.amazon.com/dynamodb/",
    "aws-cn": "https://www.amazonaws.cn/en/dynamodb"
  },
  "hasDataTransfer": true,
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "dax-instances-calc",
      "mappingDefinitionVersion": "PLC_2.0",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/dax/[currency]/current/dax-instances-calc/metadata.json"
    }
  ],
  "costType": [
    "Monthly",
    "Upfront"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "DAX clusters: On-demand DAX nodes",
      "helpText": "",
      "helpUrl": {
        "aws": "https://aws.amazon.com/dynamodb/pricing",
        "aws-cn": "https://www.amazonaws.cn/en/dynamodb/pricing/"
      },
      "id": "dynamoDBDaxNodes",
      "cards": [
        {
          "title": "DAX clusters: On-demand DAX nodes",
          "inputSection": {
            "components": [
              {
                "label": "DAX clusters: On-demand DAX nodes",
                "id": "columnFormIPM",
                "type": "input",
                "subType": "columnFormIPM",
                "mappingDefinitionName": "dax-instances-calc",
                "calculationId": {
                  "monthly": "monthly_ipm"
                },
                "pricingUnitModel": {
                  "riPaymentOptions": {
                    "hourly": "*"
                  }
                },
                "primaryKey": {
                  "Instance Type": [
                    "vCPU",
                    "Memory"
                  ]
                },
                "secondaryKey": [],
                "row": [
                  {
                    "label": "DAX nodes",
                    "type": "textInput",
                    "selectorId": "Number of nodes",
                    "description": "Enter number of DAX nodes",
                    "defaultValue": 3,
                    "validations": {
                      "allowDecimals": false,
                      "minValue": 1,
                      "maxValue": 1000000000000000,
                      "required": true
                    },
                    "exportValueAs": "count"
                  },
                  {
                    "label": "DAX instance type",
                    "type": "autoSuggest",
                    "selectorId": "Instance Type",
                    "defaultValue": "r5.large",
                    "withTags": [
                      "vCPU",
                      "Memory"
                    ]
                  }
                ]
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "DynamoDB DAX instances cost",
                  "id": "FinalCostdax",
                  "decimalPlaces": 2,
                  "IPMSupported": true,
                  "refer": [
                    "monthly_ipm"
                  ],
                  "subTotalRefer": "monthly_ipm"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws",
    "aws-cn"
  ]
}
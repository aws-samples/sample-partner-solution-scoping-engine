{
  "version": "0.0.7",
  "serviceName": {
    "aws": "AWS Glue DataBrew interactive sessions",
    "aws-cn": "Amazon Glue DataBrew interactive sessions"
  },
  "serviceCode": "awsGlueDataBrewInteractiveSessions",
  "type": "AWSService",
  "subType": "subService",
  "regions": [
    "ap-south-1",
    "ap-southeast-1",
    "ap-southeast-2",
    "ap-northeast-1",
    "eu-central-1",
    "eu-west-1",
    "eu-west-2",
    "eu-west-3",
    "eu-north-1",
    "us-east-1",
    "us-east-2",
    "us-west-1",
    "us-west-2",
    "cn-north-1",
    "cn-northwest-1"
  ],
  "searchKeywords": [],
  "serviceDescription": "",
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "glue",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/glue/[currency]/current/glue.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "DataBrew interactive sessions and jobs",
      "id": "glueDataBrew",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/glue/pricing/"
        }
      },
      "cards": [
        {
          "displayIf": {
            "and": [
              {
                "exists": {
                  "type": "meteredUnit",
                  "mappingDefinitionName": "glue",
                  "meteredUnit": "Data Brew Interactive session"
                }
              },
              {
                "exists": {
                  "type": "meteredUnit",
                  "mappingDefinitionName": "glue",
                  "meteredUnit": "Data Brew Job run"
                }
              }
            ]
          },
          "title": "DataBrew interactive sessions and jobs",
          "defaultExpansion": true,
          "expandable": true,
          "helpText": {
            "aws": "For AWS Glue DataBrew, interactive sessions are billed per session and DataBrew jobs are billed per minute. An interactive session is initiated when you open a DataBrew project. You are billed for the total number of the sessions used. Each interactive session is 30 minutes. The first 40 interactive sessions are free for first-time users of DataBrew. You are charged an hourly rate based, billed per minute, on the number of AWS Glue DataBrew nodes when you are running jobs to clean and normalize data. By default, AWS Glue DataBrew allocates 5 nodes to each job and a single DataBrew node provides 4 vCPU and 16 GB of memory. You are not charged for startup or shutdown time.",
            "aws-cn": "For Amazon Glue DataBrew, interactive sessions are billed per session and DataBrew jobs are billed per minute. An interactive session is initiated when you open a DataBrew project. You are billed for the total number of the sessions used. Each interactive session is 30 minutes. The first 40 interactive sessions are free for first-time users of DataBrew. You are charged an hourly rate based, billed per minute, on the number of Amazon Glue DataBrew nodes when you are running jobs to clean and normalize data. By default, Amazon Glue DataBrew allocates 5 nodes to each job and a single DataBrew node provides 4 vCPU and 16 GB of memory. You are not charged for startup or shutdown time.",
            "aws-us-gov": "For AWS Glue DataBrew, interactive sessions are billed per session and DataBrew jobs are billed per minute. An interactive session is initiated when you open a DataBrew project. You are billed for the total number of the sessions used. Each interactive session is 30 minutes. The first 40 interactive sessions are free for first-time users of DataBrew. You are charged an hourly rate based, billed per minute, on the number of AWS Glue DataBrew nodes when you are running jobs to clean and normalize data. By default, AWS Glue DataBrew allocates 5 nodes to each job and a single DataBrew node provides 4 vCPU and 16 GB of memory. You are not charged for startup or shutdown time."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/glue/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "headerText",
                "title": "DataBrew interactive sessions",
                "id": "awsGlue_DataBrewIS"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of interactive sessions for DataBrew",
                "id": "numberOfISessionsForDataBrew",
                "description": "Each interactive session is 30 minutes and you are billed by the total number of sessions used.",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 10000000000000
                },
                "defaultValue": 1,
                "displayInConfigSummary": true,
                "placeholder": "Enter number of sessions"
              },
              {
                "type": "input",
                "subType": "headerText",
                "title": "DataBrew jobs",
                "id": "awsGlue_DataBrewJobs"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of nodes consumed for DataBrew job",
                "id": "numberOfnodesForDataBrew",
                "description": "DataBrew allocates 5 nodes by default to each job and a single DataBrew node provides 4 vCPU and 16 GB of memory.",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 0,
                  "maxValue": 10000000000000
                },
                "defaultValue": 5,
                "displayInConfigSummary": true,
                "placeholder": "Enter number of nodes"
              },
              {
                "type": "input",
                "subType": "durationInput",
                "label": "Duration of DataBrew job",
                "description": "Minimum billing duration for each DataBrew job is 1-minute.",
                "id": "durationForDataBrewJob",
                "defaultValue": 10,
                "dropDownDuration": [
                  {
                    "label": "minutes",
                    "value": "min"
                  },
                  {
                    "label": "seconds",
                    "value": "sec"
                  },
                  {
                    "label": "hour",
                    "value": "hr"
                  }
                ],
                "outputDurationUnit": "hr",
                "outputDurationLabel": "hours",
                "decimalPlaces": 2,
                "validations": {
                  "required": false,
                  "minValue": 0,
                  "maxValue": 10000000000000,
                  "allowDecimal": false
                },
                "placeholder": "Enter duration"
              },
              {
                "type": "pricing",
                "label": "Price for DataBrew interactive session",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "glue",
                "meteredUnit": {
                  "allRegions": "Data Brew Interactive session"
                },
                "id": "awsGlue_DataBrewISPrice"
              },
              {
                "type": "pricing",
                "label": "Price for DataBrew job run",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "glue",
                "meteredUnit": {
                  "allRegions": "Data Brew Job run"
                },
                "id": "awsGlue_DatBrewJobPrice"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "awsGlue_DataBrewIS",
                    "numberOfISessionsForDataBrew",
                    "awsGlue_DataBrewJobs",
                    "numberOfnodesForDataBrew",
                    "durationForDataBrewJob",
                    "awsGlue_DataBrewISPrice",
                    "awsGlue_DatBrewJobPrice"
                  ],
                  "subTotalRefer": "",
                  "id": "durationForDataBrewJobConv"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of interactive sessions for DataBrew",
                      "variableUnitLabel": "Interactive Sessions",
                      "required": true,
                      "variableId": "numberOfISessionsForDataBrew"
                    },
                    {
                      "variableLabel": "Price for DataBrew interactive session",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "awsGlue_DataBrewISPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2,
                  "id": "awsGlue_DataBrewISMath"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "DataBrew interactive session cost (monthly)",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency]",
                  "id": "awsGlue_DataBrewISCost",
                  "refer": "awsGlue_DataBrewISMath"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of nodes consumed for DataBrew job",
                      "variableUnitLabel": "nodes",
                      "required": true,
                      "variableId": "numberOfnodesForDataBrew"
                    },
                    {
                      "variableLabel": "Duration of DataBrew job",
                      "variableUnitLabel": "hours",
                      "required": true,
                      "variableId": "durationForDataBrewJob"
                    },
                    {
                      "variableLabel": "Price for DataBrew job run",
                      "variableUnitLabel": "[currency] per node hour",
                      "required": true,
                      "variableId": "awsGlue_DatBrewJobPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2,
                  "id": "awsGlue_DataBrewJobMath"
                },
                {
                  "type": "maths",
                  "subType": "variable",
                  "label": "DataBrew job cost (monthly)",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency]",
                  "id": "awsGlue_DataBrewJobCost",
                  "refer": "awsGlue_DataBrewJobMath"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableLabel": "DataBrew interactive session cost (monthly)",
                      "variableUnitLabel": "[currency]",
                      "required": false,
                      "variableId": "awsGlue_DataBrewISCost"
                    },
                    {
                      "variableLabel": "DataBrew job cost (monthly)",
                      "variableUnitLabel": "[currency]",
                      "required": false,
                      "variableId": "awsGlue_DataBrewJobCost"
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "id": "awsGlue_DataBrewTotalCost"
                },
                {
                  "type": "display",
                  "refer": [
                    "awsGlue_DataBrewISMath",
                    "awsGlue_DataBrewISCost",
                    "awsGlue_DataBrewJobMath",
                    "awsGlue_DataBrewJobCost",
                    "awsGlue_DataBrewTotalCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "DataBrew total cost",
                  "decimalPlaces": 2,
                  "id": "awsGlue_DataBrewDisp",
                  "subTotalRefer": "awsGlue_DataBrewTotalCost"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "partitions": [
    "aws",
    "aws-cn",
    "aws-us-gov"
  ]
}
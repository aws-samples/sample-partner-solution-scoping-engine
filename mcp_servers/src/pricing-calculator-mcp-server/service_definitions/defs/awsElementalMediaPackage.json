{
  "version": "0.0.24",
  "serviceName": "AWS Elemental MediaPackage",
  "serviceCode": "awsElementalMediaPackage",
  "type": "AWSService",
  "regions": [
    "ap-south-1",
    "ap-northeast-2",
    "ap-southeast-1",
    "ap-southeast-2",
    "ap-northeast-1",
    "eu-central-1",
    "eu-west-1",
    "eu-west-2",
    "eu-west-3",
    "eu-north-1",
    "sa-east-1",
    "us-east-1",
    "us-east-2",
    "us-west-1",
    "us-west-2",
    "us-iso-east-1",
    "us-isob-east-1"
  ],
  "serviceDescription": "AWS Elemental MediaPackage reliably prepares and protects your video for delivery over the Internet. From a single video input, AWS Elemental MediaPackage creates video streams formatted to play on connected TVs, mobile phones, computers, tablets, and game consoles.",
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/mediapackage/"
    }
  },
  "searchKeywords": [
    "media",
    "video processing",
    "broadcast",
    "TV",
    "video streams",
    "channels"
  ],
  "hasDataTransfer": true,
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "elementalmediapackage",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/elementalmediapackage/[currency]/current/elementalmediapackage.json"
    },
    {
      "deniedPartitions": [
        "aws-iso"
      ],
      "mappingDefinitionName": "datatransfer-calc",
      "includeRegions": false,
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/datatransfer/[currency]/current/datatransfer-calc.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "title": "Elemental MediaPackage",
      "id": "mediaPackage",
      "description": "For live channels, you are charged based on the amount of video ingested into the channel (measured in GB) and the amount of content originated and packaged for the channel (measured in GB).",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/mediapackage/"
        }
      },
      "volumeDiscountEligibility": false,
      "cards": [
        {
          "title": "Live packaging service settings",
          "helpText": "You will be charged for each stream AWS Elemental MediaPackage ingests for your live channels, as it receives video from your live encoder. Ingest charges are based on the size and number of those streams, measured in GB. This means you will pay more if you have more input streams on your channel, or if those streams are higher bitrates.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/mediapackage/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "The calculations below do not include data transfer out costs. You will incur additional charges when you serve content from AWS Elemental MediaPackage outside of AWS. If the content output is delivered to a destination over the internet or via a CDN other than Amazon CloudFront, then internet data transfer charges apply. The GB originated amount in the calculations section can be used to estimate data transfer costs in the section below.",
                "partitions": [
                  "aws"
                ],
                "id": "Live_bodyText"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Number of inputs per channel",
                "defaultValue": 1,
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 2
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter amount",
                "description": "",
                "id": "empLive_numberOfInputsPerChannel"
              },
              {
                "type": "input",
                "subType": "durationInput",
                "label": "Total duration of live streams per month",
                "dropDownDuration": [
                  {
                    "label": "hours",
                    "value": "hr"
                  },
                  {
                    "label": "seconds",
                    "value": "sec"
                  },
                  {
                    "label": "minutes",
                    "value": "min"
                  }
                ],
                "outputDurationUnit": "hr",
                "outputDurationLabel": "hours",
                "validations": {
                  "required": false,
                  "allowDecimal": false,
                  "minValue": 0,
                  "maxValue": 1000000
                },
                "placeholder": "Enter amount",
                "description": "Enter the total duration of live streams per month (example: 730 hours for one 24/7 linear stream).",
                "displayInConfigSummary": true,
                "id": "empLive_durationPerMonth"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Ingest bitrate per input (Mbit per second)",
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1e+21
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter amount in Mbit/s",
                "description": "Ingestion bitrate per input in Mbit/s",
                "id": "empLive_ingestBitrate"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Average Number of viewers per hour",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1e+21
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter amount",
                "description": "",
                "id": "empLive_numberOfViewers"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Average bitrate per viewer (Mbit per second)",
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1e+21
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter bitrate in Mbit/s",
                "description": "Bitrate per viewer in Mbit/s",
                "id": "empLive_bitratePerViewer"
              },
              {
                "type": "input",
                "subType": "percentInput",
                "label": "Cache/hit ratio",
                "validations": {
                  "required": false,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 100
                },
                "displayInConfigSummary": true,
                "placeholder": "Enter cache/hit ratio as a pecentage",
                "description": "",
                "id": "empLive_cacheHitRatio"
              },
              {
                "type": "pricing",
                "label": "price for live ingest",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "elementalmediapackage",
                "meteredUnit": {
                  "allRegions": "Ingest"
                },
                "id": "empLive_ingestPrice"
              },
              {
                "type": "pricing",
                "label": "price for live origination and packaging",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "elementalmediapackage",
                "meteredUnit": {
                  "allRegions": "Origination and Packaging"
                },
                "id": "empLive_orgPackagePrice"
              }
            ]
          },
          "mathsSection": [

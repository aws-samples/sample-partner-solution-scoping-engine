                      "variableLabel": "[currency] (monthly live ingest charges)",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "empLive_GBCost"
                    },
                    {
                      "variableLabel": "[currency] (monthly origination and packaging charges)",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "empLive_orgPackageCost"

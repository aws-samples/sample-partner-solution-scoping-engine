                    {
                      "variableLabel": "Bitrate per input (Gbit per hour)",
                      "variableUnitLabel": "Gbit per hour",
                      "required": true,
                      "variableId": "empLive_GbitPerHr"
                    },
                    {
                      "constant": 8,
                      "constantUnitLabel": "bits per byte"

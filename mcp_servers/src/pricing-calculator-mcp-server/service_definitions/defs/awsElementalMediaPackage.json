                  "type": "display",
                  "refer": [
                    "empLive_bitRateGbps",
                    "empLive_GbitPerHr",
                    "empLive_GBPerHr",
                    "empLive_GBPerMonth",
                    "empLive_GBCost",
                    "empLive_summarizeLiveIngestCost",
                    "empLive_finalCacheHitRate",
                    "empLive_bitRatePerViewerGbps",
                    "empLive_GbitPerHrViewer",
                    "empLive_GBPerHrViewer",
                    "empLive_GBOriginated",
                    "empLive_orgPackageCost",
                    "empLive_summarizeLiveOrgPackCost",
                    "empLive_totalCost"

                    {
                      "constant": 60,
                      "constantUnitLabel": "seconds per minute"
                    },
                    {
                      "constant": 60,
                      "constantUnitLabel": "minutes per hour"
                    }
                  ],
                  "outputUnitLabel": "Total viewer bitrate (Gbit per hour)",
                  "decimalPlaces": 4,
                  "id": "empLive_GbitPerHrViewer"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "division",
                  "operands": [
                    {
                      "variableLabel": "Total viewer bitrate (Gbit per hour)",
                      "variableUnitLabel": "Gbit per hour",
                      "required": true,
                      "variableId": "empLive_GbitPerHrViewer"
                    },
                    {
                      "constant": 8,
                      "constantUnitLabel": "bits per byte"
                    }
                  ],
                  "outputUnitLabel": "Total viewer GB delivered per hour",
                  "decimalPlaces": 4,
                  "id": "empLive_GBPerHrViewer"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Total viewer GB delivered per hour",
                      "variableUnitLabel": "GB",
                      "required": true,
                      "variableId": "empLive_GBPerHrViewer"
                    },
                    {
                      "variableLabel": "Total duration of live streams per month",
                      "variableUnitLabel": "hour(s)",
                      "required": true,
                      "variableId": "empLive_durationPerMonth"

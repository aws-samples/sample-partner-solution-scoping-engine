                  "id": "empLive_GBPerHr"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "GB ingested per input (per hour)",
                      "variableUnitLabel": "GB",
                      "required": true,
                      "variableId": "empLive_GBPerHr"
                    },
                    {
                      "variableLabel": "Number of inputs per channel",
                      "variableUnitLabel": "input(s)",
                      "required": true,
                      "variableId": "empLive_numberOfInputsPerChannel"
                    },
                    {
                      "variableLabel": "Total duration of live streams per month",
                      "variableUnitLabel": "hour(s)",
                      "required": true,
                      "variableId": "empLive_durationPerMonth"
                    }
                  ],
                  "outputUnitLabel": "GB ingested per month",
                  "decimalPlaces": 2,
                  "id": "empLive_GBPerMonth"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "GB ingested per month",
                      "variableUnitLabel": "GB",
                      "required": true,
                      "variableId": "empLive_GBPerMonth"
                    },
                    {
                      "variableLabel": "price for live ingest",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "empLive_ingestPrice"
                    }
                  ],
                  "outputUnitLabel": "[currency] (monthly live ingest charges)",
                  "decimalPlaces": 2,
                  "id": "empLive_GBCost"
                },

                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "division",
                  "operands": [
                    {
                      "variableLabel": "Ingest bitrate per input (Mbit per second)",
                      "variableUnitLabel": "Mbit/s",
                      "required": true,
                      "variableId": "empLive_ingestBitrate"
                    },
                    {
                      "constant": 1024,
                      "constantUnitLabel": "Mbit per Gbit"
                    }

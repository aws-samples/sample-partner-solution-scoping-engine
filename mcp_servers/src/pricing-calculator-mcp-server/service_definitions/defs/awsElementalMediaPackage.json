                  "type": "maths",
                  "subType": "variable",
                  "label": "Live ingest charges (monthly)",
                  "displayInCalculationString": true,
                  "useCurrency": true,
                  "referLabel": "[currency] (monthly live ingest charges)",
                  "id": "empLive_summarizeLiveIngestCost",
                  "refer": "empLive_GBCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "subtraction",
                  "operands": [
                    {
                      "constant": 1,
                      "constantUnitLabel": ""
                    },
                    {
                      "variableLabel": "Cache/hit ratio",
                      "variableUnitLabel": "ratio",
                      "required": true,
                      "variableId": "empLive_cacheHitRatio"
                    }
                  ],
                  "outputUnitLabel": "Cache/hit rate",
                  "decimalPlaces": 0,
                  "id": "empLive_finalCacheHitRate"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "division",
                  "operands": [
                    {
                      "variableLabel": "Average bitrate per viewer (Mbit per second)",
                      "variableUnitLabel": "Mbit/s",
                      "required": true,
                      "variableId": "empLive_bitratePerViewer"

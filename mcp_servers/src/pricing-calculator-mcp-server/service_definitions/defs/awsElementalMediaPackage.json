                    {
                      "variableLabel": "Bitrate per input (Gbit per second)",
                      "variableUnitLabel": "Gbit/s",
                      "required": true,
                      "variableId": "empLive_bitRateGbps"
                    },
                    {
                      "constant": 60,
                      "constantUnitLabel": "seconds per minute"
                    },
                    {
                      "constant": 60,
                      "constantUnitLabel": "minutes per hour"
                    }
                  ],
                  "outputUnitLabel": "Bitrate per input (Gbit per hour)",
                  "decimalPlaces": 4,
                  "id": "empLive_GbitPerHr"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "division",

                    "gatewayLoadBalancer_MonthlyHoursCost"
                  ],
                  "id": "gatewayLoadBalancer_MonthlyHourTotal",
                  "subTotalRefer": "gatewayLoadBalancer_MonthlyHoursCost"
                }
              ]
            }
          ]

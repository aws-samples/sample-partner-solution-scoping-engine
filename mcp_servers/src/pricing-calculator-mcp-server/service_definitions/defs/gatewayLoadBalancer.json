                "outputFrequency": "hour",
                "outputFrequencyLabel": "hour",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 1000000000

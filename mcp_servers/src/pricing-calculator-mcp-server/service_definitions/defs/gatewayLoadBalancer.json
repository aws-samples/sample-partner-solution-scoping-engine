                  "subTotalRefer": ""
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of Availability Zones that Gateway Load Balancer is deployed to",
                      "variableUnitLabel": "availability zones",
                      "required": true,
                      "variableId": "numberOfGatewayAZs"
                    },
                    {
                      "variableLabel": "pricing for glb per hour",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "gatewayLoadBalancer_hourPrice"
                    },
                    {
                      "constant": 730,
                      "constantUnitLabel": "hours in a month"
                    }

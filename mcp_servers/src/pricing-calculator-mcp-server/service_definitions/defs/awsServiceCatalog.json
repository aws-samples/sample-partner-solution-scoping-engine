                "alertType": "info",
                "isDismissable": true,
                "id": "Info_sc"
              },
              {
                "type": "input",
                "subType": "frequency",
                "id": "Number_of_API_calls_per_month",
                "label": "Number of API calls",
                "options": [
                  {
                    "label": "per month",
                    "id": "perMonth"
                  },
                  {
                    "label": "thousand per month",
                    "id": "thousandPerMonth"
                  },
                  {
                    "label": "million per month",
                    "id": "millionPerMonth"
                  }
                ],
                "defaultFrequency": "perMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 1e+25
                },
                "placeholder": "Enter number of API calls",
                "description": ""
              },
              {
                "type": "pricing",
                "label": "price for service catalog",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "servicecatalog",

                "id": "dataTransfer"
              },
              {
                "type": "pricing",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "vpc",
                "meteredUnit": {
                  "allRegions": "Hourly charge for VPC Endpoints per Hrs"

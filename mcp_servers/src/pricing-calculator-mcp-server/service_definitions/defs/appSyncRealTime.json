{
  "version": "0.0.18",
  "serviceName": "AppSync GraphQL Real-Time",
  "serviceCode": "appSyncRealTime",
  "type": "AWSService",
  "subType": "subService",
  "regions": [
    "ap-east-1",
    "ap-south-1",
    "ap-northeast-3",
    "ap-northeast-2",
    "ap-southeast-1",
    "ap-southeast-2",
    "ap-northeast-1",
    "ca-central-1",
    "eu-central-1",
    "eu-west-1",
    "eu-west-2",
    "eu-south-1",
    "eu-west-3",
    "eu-north-1",
    "me-south-1",
    "sa-east-1",
    "us-east-1",
    "us-east-2",
    "us-west-1",
    "us-west-2",
    "cn-north-1",
    "cn-northwest-1"
  ],
  "searchKeywords": [
    "query"
  ],
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/appsync/",
      "overrides": {
        "aws-cn": "https://www.amazonaws.cn/en/appsync/pricing/"
      }
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "appsync",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/appsync/[currency]/current/appsync.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/appsync/"
        }
      },
      "cards": [
        {
          "title": "Subscription Operations",
          "helpText": {
            "aws": "AWS AppSync GraphQL Subscriptions enable your to send real-time updates to connected clients when data is updated via a GraphQL mutation.",
            "aws-cn": "Amazon AppSync GraphQL Subscriptions enable your to send real-time updates to connected clients when data is updated via a GraphQL mutation."
          },
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/appsync/pricing/"
            }
          },
          "bodyText": "",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "numericInput",
                "id": "realTimeActiveUsers",
                "label": "Number Of Subscribed Clients",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1e+22
                },
                "placeholder": "",
                "description": ""
              },
              {
                "type": "input",
                "subType": "frequency",
                "id": "applicationUsageDuration",
                "label": "Average Active Duration per Subscribed Clients",
                "options": [
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per week",
                    "id": "perWeek"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1000000000000
                },
                "placeholder": "",
                "description": ""
              },
              {
                "type": "input",
                "subType": "frequency",
                "id": "noOfMessageSent",
                "label": "Number of Inbound Messages (i.e. GraphQL Mutations)",
                "options": [
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per week",
                    "id": "perWeek"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1000000000000
                },
                "placeholder": "",
                "description": ""
              },
              {
                "type": "input",
                "subType": "frequency",
                "id": "noOfMessageRecieved",
                "label": "Number of Outbound Messages",
                "options": [
                  {
                    "label": "per day",
                    "id": "perDay"
                  },
                  {
                    "label": "per week",
                    "id": "perWeek"
                  },
                  {
                    "label": "per month",
                    "id": "perMonth"
                  }
                ],
                "defaultFrequency": "perMonth",
                "lookupValue": "",
                "outputFrequency": {
                  "label": "per month",
                  "id": "perMonth"
                },
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 1,
                  "maxValue": 1000000000000
                },
                "placeholder": "",
                "description": ""
              },
              {
                "type": "pricing",
                "id": "realtimequreymodification",
                "label": "Price for Real time query modification",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "appsync",
                "meteredUnit": {
                  "allRegions": "API Query and Data Modifications Operations"
                }
              },
              {
                "type": "pricing",
                "id": "realtimeConnection",
                "label": "Price for Real time Connectivity Charges",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "appsync",
                "meteredUnit": {
                  "allRegions": "RealTime Connection per Minutes"
                }
              },
              {
                "type": "pricing",
                "id": "realtimeUpdates",
                "label": "Price for Real time Update Charges",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "appsync",
                "meteredUnit": {
                  "allRegions": "RealTime Updates per Messages"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "refer": [
                    "realTimeActiveUsers",
                    "applicationUsageDuration",
                    "noOfMessageSent",
                    "noOfMessageRecieved",
                    "realtimequreymodification",
                    "realtimeConnection",
                    "realtimeUpdates"
                  ],
                  "subTotalRefer": "",
                  "id": "serviceSettingUnitConversion"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "dataModificationCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of Inbound Messages (i.e. GraphQL Mutations)",
                      "variableId": "noOfMessageSent",
                      "variableUnitLabel": "GraphQL mutations",
                      "required": true
                    },
                    {
                      "variableLabel": "Price for Real time query modification",
                      "variableId": "realtimequreymodification",
                      "variableUnitLabel": "[currency] per operations",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for inbound messages",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "realTimeUpdateCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number of Outbound Messages",
                      "variableId": "noOfMessageRecieved",
                      "variableUnitLabel": "outbound messages",
                      "required": true
                    },
                    {
                      "variableLabel": "Price for Real time Update Charges",
                      "variableId": "realtimeUpdates",
                      "variableUnitLabel": "[currency] per updates",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] for outbound messages",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "realTimeConnectivityCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Number Of Subscribed Clients",
                      "variableId": "realTimeActiveUsers",
                      "variableUnitLabel": "clients",
                      "required": false
                    },
                    {
                      "variableLabel": "Average Active Duration per Subscribed Clients",
                      "variableId": "applicationUsageDuration",
                      "variableUnitLabel": "minutes",
                      "required": false
                    },
                    {
                      "variableLabel": "Price for Real time Connectivity Charges",
                      "variableId": "realtimeConnection",
                      "variableUnitLabel": "[currency] per connection-minutes",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency] for Connectivity Charges",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "realTimeCharges",
                  "operation": "addition",
                  "operands": [
                    {
                      "variableLabel": "[currency] for inbound messages",
                      "variableId": "dataModificationCost",
                      "variableUnitLabel": "[currency] inbound messages",
                      "required": false
                    },
                    {
                      "variableLabel": "[currency] for outbound messages",
                      "variableId": "realTimeUpdateCost",
                      "variableUnitLabel": "[currency] outbound messages",
                      "required": false
                    },
                    {
                      "variableLabel": "[currency] for Connectivity Charges",
                      "variableId": "realTimeConnectivityCost",
                      "variableUnitLabel": "[currency] connectivity charges",
                      "required": false
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "dataModificationCost",
                    "realTimeUpdateCost",
                    "realTimeConnectivityCost",
                    "realTimeCharges"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Total AppSync GraphQL Real-Time Subscriptions cost",
                  "decimalPlaces": 2,
                  "id": "realTimeTotalPrice",
                  "subTotalRefer": "realTimeCharges"
                }
              ]
            }
          ]
        }
      ],
      "id": "apiquerydatamodification"
    }
  ],
  "partitions": [
    "aws",
    "aws-cn"
  ]
}
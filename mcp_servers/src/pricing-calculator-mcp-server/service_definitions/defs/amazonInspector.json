        {
          "title": "Amazon EC2 instance scanning:",
          "expandable": true,
          "defaultExpansion": true,
          "helpText": "Amazon Inspector is an automated and continual vulnerability scanning service that assesses Amazon Elastic Compute Cloud (EC2) instances and container images to improve the security and compliance of infrastructure workloads. Monthly costs are determined by a combination of two dimensions: Amazon EC2 instances being scanned, and the total number of container images initially scanned when pushed to Amazon Elastic Container Registry (ECR) and rescanned during a month.",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/inspector/pricing/"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "alert",
                "alertType": "info",
                "content": "Each EC2 instance is continually scanned for software vulnerabilities and unintended network exposure. Total monthly cost is based on the average* number of EC2 instances assessed within a month. For instances that are run intermittently, the price is prorated based on total time run within a month.",
                "id": "AverageDescription"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "label": "Average* No. of EC2 instances scanned per month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "placeholder": "Enter a number",
                "description": "*Average number of EC2 instances = (total hours of active, supported instances being scanned) / (number of hours in a month, i.e., 720 hours). For example, you have 3 supported instances that were active and being scanned for different amounts of time during a month: The first for 360 hours, the second for 350 hours, and the third for 10 hours, adding up to a total 720 hours of active, supported instances being scanned. Therefore, 720 hours total of instances being scanned that month / 720 hours in the month = 1 average EC2 instance",
                "id": "NumberOfEC2Instance"
              },
              {
                "type": "pricing",
                "label": "Price for EC2 instance scanning",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "inspectorv2",
                "meteredUnit": {
                  "allRegions": "e_8I2HCKlhP13Ov1SOMCgaqpNQZpDdceuT_nThe5NdI"
                },
                "id": "price_EC2Instance"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "calc_mul_ins_per_mon",
                  "operation": "multiplication",
                  "description": "(i.e., 720 instance-hours per month * 0.00174 [currency] per hour)",
                  "operands": [
                    {
                      "constant": 720,
                      "constantUnitLabel": "instance-hours per month"
                    },
                    {
                      "variableLabel": "Price for EC2 instance scanning",
                      "variableUnitLabel": "[currency] per hour",
                      "required": true,
                      "variableId": "price_EC2Instance"
                    }
                  ],
                  "outputUnitLabel": "[currency] per instance per month",
                  "decimalPlaces": 2
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "calc_mul_ec2_instance",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "Average* No. of EC2 instances scanned per month",
                      "variableUnitLabel": "Instances",
                      "required": true,
                      "variableId": "NumberOfEC2Instance"
                    },
                    {
                      "variableLabel": "[currency] per instance per month",
                      "variableUnitLabel": "[currency] per instance per month",
                      "required": true,
                      "variableId": "calc_mul_ins_per_mon"
                    }
                  ],
                  "outputUnitLabel": "[currency]",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "AverageDescription",
                    "NumberOfEC2Instance",
                    "price_EC2Instance",
                    "calc_mul_ins_per_mon",
                    "calc_mul_ec2_instance"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "EC2 Instance Price",
                  "decimalPlaces": 2,
                  "id": "EC2InstancePrice",
                  "subTotalRefer": "calc_mul_ec2_instance"
                }
              ]
            }
          ]
        },

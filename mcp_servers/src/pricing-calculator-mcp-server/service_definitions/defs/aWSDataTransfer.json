      }
    }
  },
  "serviceDescription": {
    "aws": "The cost of transferring data at AWS for services without unique transfer costs.",
    "aws-cn": "The cost of transferring data at Amazon for services without unique transfer costs.",
    "aws-us-gov": "The cost of transferring data at AWS for services without unique transfer costs."
  },
  "hasDataTransfer": true,
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "datatransfer-calc",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/datatransfer/[currency]/current/datatransfer-calc.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "templates": [
    {
      "description": "Data transfer is used for transfer between different services and the charges apply for data transfer into the region, out of the region and with in the region.",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/ec2/pricing/on-demand/#Data_Transfer",
          "overrides": {
            "aws-cn": "https://www.amazonaws.cn/en/ec2/pricing/"
          }
        }
      },
      "excludeRegion": [],
      "cards": [
        {
          "deniedPartitions": [
            "aws-iso",
            "aws-cn"
          ],
          "title": "Data Transfer 100GB Free Tier",
          "expandable": false,
          "defaultExpansion": false,
          "bodyText": "",
          "helpText": "",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/ec2/pricing/on-demand/#Data_Transfer"
            }
          },
          "cardType": "",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "alert",
                "header": "",
                "label": "info alert",
                "content": "Effective December 1, 2021, the first 100 gigabytes per month of data transfer out to the internet from all <a href='https://aws.amazon.com/about-aws/global-infrastructure/regions_az/' target='_blank'>AWS Regions</a> will be free (excludes China and GovCloud). We are working to update the calculator to reflect this expanded offering. In the meantime, please incorporate this change into your pricing calculator inputs below.",
                "alertType": "info",
                "isDismissable": true,
                "id": "destinationAlert"
              }
            ]
          }
        },
        {
          "deniedPartitions": [
            "aws-iso"
          ],
          "title": "Data Transfer",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/ec2/pricing/on-demand/#Data_Transfer",
              "overrides": {
                "aws-cn": "https://www.amazonaws.cn/en/ec2/pricing/"
              }
            }
          },
          "cardType": "dataTransferV2",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "dataTransferV2",
                "mappingDefinitionName": "datatransfer-calc",
                "label": "Data Transfer",
                "displayInConfigSummary": true,
                "title": "Enter the data you expect to transfer out of $[Region]",
                "summaryText": "Data Transfer",
                "dataTransferTypes": [
                  "INBOUND",
                  "INTRA_REGION",
                  "OUTBOUND"
                ],
                "validations": {
                  "required": false,
                  "minValue": 0,
                  "maxValue": 1000000000,
                  "allowDecimal": false
                },
                "dataTransferTypesConfig": {
                  "INBOUND": {
                    "title": "Inbound Data Transfer"
                  },
                  "INTRA_REGION": {
                    "title": "Intra-Region Data Transfer"
                  },
                  "OUTBOUND": {
                    "title": "Outbound Data Transfer"
                  }
                },
                "preferredUnit": "gb",
                "id": "dataTransfer"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "subType": "conversionDisplay",
                  "label": "Unit conversions",
                  "id": "_generated_0",
                  "refer": [
                    "dataTransfer"
                  ],
                  "subTotalRefer": ""
                },
                {
                  "label": "Data transfer cost",
                  "refer": "dataTransfer",
                  "referLabel": "Data Transfer",
                  "subType": "variable",
                  "type": "maths",
                  "displayInConfigSummary": true,
                  "id": "_generated_1"
                },
                {
                  "type": "display",
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "decimalPlaces": 2,
                  "label": "Data Transfer cost",
                  "displayInConfigSummary": true,
                  "id": "_generated_2",
                  "refer": [
                    "_generated_1"
                  ],
                  "subTotalRefer": "_generated_1"
                }
              ]
            }
          ]
        },
        {
          "deniedPartitions": [
            "aws",
            "aws-cn",
            "aws-us-gov"
          ],
          "title": "Data Transfer",
          "helpText": "Pricing is based on the total volume of data transferred between US ISO East and US ISO West regions",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/ec2/pricing/on-demand/#Data_Transfer"
            }
          },
          "bodyText": "",
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "Pricing is based on the total volume of data transferred between US ISO East and US ISO West regions",
                "id": "dataTransferISOText"
              },
              {
                "type": "input",
                "subType": "fileSize",
                "id": "dataTransferedInterRegion",
                "label": "InterRegion Data Transfer",
                "dropDownSize": [
                  {
                    "label": "GB",
                    "id": "gb"
                  },
                  {
                    "label": "TB",
                    "id": "tb"
                  }
                ],
                "defaultOption": {
                  "size": "gb",
                  "frequency": "month"
                },
                "dropDownFrequency": [
                  {
                    "label": "month",
                    "id": "month"
                  }
                ],
                "outputSize": "gb",
                "outputSizeLabel": "GB",
                "outputFrequency": "month",
                "outputFrequencyLabel": "month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0,
                  "maxValue": 1000000000
                },
                "placeholder": "Enter amount",
                "description": "Enter the data you expect to transfer"
              },
              {
                "type": "pricing",
                "label": "Price for data transfer inter region to US ISO WEST",
                "subType": "singlePricePoint",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "mappingDefinitionName": "datatransfer-calc",
                "meteredUnit": {
                  "allRegions": "DataTransfer InterRegion Outbound to US ISO WEST"
                },
                "id": "priceDataTransferInterRegionToWest"
              },
              {
                "type": "pricing",
                "label": "Price for data transfer inter region to US ISO East",
                "subType": "singlePricePoint",
                "backwardCompatibility": {
                  "hideCardWhenMissing": false
                },
                "mappingDefinitionName": "datatransfer-calc",
                "meteredUnit": {
                  "allRegions": "DataTransfer InterRegion Outbound to US ISO East"
                },
                "id": "priceDataTransferInterRegionToEast"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "id": "unitConvertShift",
                  "refer": [
                    "dataTransferISOText",
                    "dataTransferedInterRegion",
                    "priceDataTransferInterRegionToWest",
                    "priceDataTransferInterRegionToEast"
                  ],
                  "subTotalRefer": "_generated_1"
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "datatransfer-calc",
                      "meteredUnit": "DataTransfer InterRegion Outbound to US ISO WEST"
                    }
                  },
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "interRegionDataTransferCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "InterRegion Data Transfer",
                      "variableUnitLabel": "GB",
                      "required": true,
                      "variableId": "dataTransferedInterRegion"
                    },
                    {
                      "variableLabel": "Price for data transfer inter region to US ISO WEST",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "priceDataTransferInterRegionToWest"
                    }
                  ],
                  "outputUnitLabel": "[currency] for InterRegion data transfer",
                  "decimalPlaces": 2
                },
                {
                  "displayIf": {
                    "exists": {
                      "type": "meteredUnit",
                      "mappingDefinitionName": "datatransfer-calc",
                      "meteredUnit": "DataTransfer InterRegion Outbound to US ISO East"
                    }
                  },
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "interRegionDataTransferCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "InterRegion Data Transfer",
                      "variableUnitLabel": "GB",
                      "required": true,
                      "variableId": "dataTransferedInterRegion"
                    },
                    {
                      "variableLabel": "Price for data transfer inter region to US ISO East",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "priceDataTransferInterRegionToEast"
                    }
                  ],
                  "outputUnitLabel": "[currency] for InterRegion data transfer",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "interRegionDataTransferCost",
                    "interRegionDataTransferCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Data transfer price",
                  "decimalPlaces": 2,
                  "id": "interRegionDataTransferCostDisplay",
                  "subTotalRefer": "interRegionDataTransferCost"
                }
              ]
            }
          ]
        }
      ],
      "id": "awsDatatransfer"
    }
  ],
  "partitions": [
    "aws",
    "aws-cn",
    "aws-iso",
    "aws-us-gov"

{
  "version": "0.0.6",
  "serviceName": "Amazon FinSpace Dataset Browser",
  "serviceCode": "awsFinSpace",
  "slug": "FinSpace",
  "type": "AWSService",
  "excludeZeroSubTotals": false,
  "regions": [
    "us-east-1",
    "us-east-2",
    "us-west-2",
    "ca-central-1",
    "eu-west-1"
  ],
  "searchKeywords": [
    "data management",
    "analytics",
    "clusters",
    "users",
    "data",
    "storage",
    "financial"
  ],
  "serviceDescription": "Amazon FinSpace Dataset Browser provides a notebook for (FSI) customers such as hedge funds, asset management firms, insurance companies, and investment banks to store, catalog, prepare, and analyze data at petabyte scale. The calculator does not yet support the new Amazon FinSpace with Managed kdb Insights.",
  "linkUrl": {
    "$LINK": {
      "type": "pricing",
      "path": "/finspace/features/dataset-browser/"
    }
  },
  "mappingDefinitions": [
    {
      "mappingDefinitionName": "finspace",
      "mappingDefinitionURL": "pricing/2.0/meteredUnitMaps/finspace/[currency]/current/finspace.json"
    }
  ],
  "costType": [
    "Monthly"
  ],
  "layout": "simple",
  "templates": [
    {
      "description": "",
      "helpUrl": {
        "$LINK": {
          "type": "pricing",
          "path": "/finspace/features/dataset-browser/"
        }
      },
      "cards": [
        {
          "title": "Users",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/finspace/pricing/#Users"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "You are charged $150 per month for each registered user in FinSpace.",
                "id": "UserCardBodyText"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "numberOfUsers",
                "label": "Number of users",
                "displayInConfigSummary": true,
                "defaultValue": 1,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 0
                }
              },
              {
                "type": "pricing",
                "label": "Cost per User",
                "subType": "singlePricePoint",
                "mappingDefinitionName": "finspace",
                "meteredUnit": {
                  "allRegions": "UserEnabled"
                },
                "id": "CostperUser"
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "variableName": "User cost",
                  "operands": [
                    {
                      "variableLabel": "Number of users",
                      "variableUnitLabel": "users",
                      "required": true,
                      "variableId": "numberOfUsers"
                    },
                    {
                      "variableLabel": "Cost per User",
                      "variableUnitLabel": "[currency]",
                      "required": true,
                      "variableId": "CostperUser"
                    }
                  ],
                  "outputUnitLabel": "[currency] (User cost)",
                  "decimalPlaces": 2,
                  "id": "totalUserCost"
                },
                {
                  "type": "display",
                  "refer": [
                    "UserCardBodyText",
                    "numberOfUsers",
                    "CostperUser",
                    "totalUserCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "User cost",
                  "decimalPlaces": 2,
                  "id": "final_user_cost",
                  "subTotalRefer": "totalUserCost"
                }
              ]
            }
          ]
        },
        {
          "title": "Storage",
          "helpUrl": {
            "$LINK": {
              "type": "pricing",
              "path": "/finspace/pricing/#Storage"
            }
          },
          "inputSection": {
            "components": [
              {
                "type": "input",
                "subType": "bodyText",
                "text": "You are charged $0.14 per month for each GB of data you store in FinSpace.",
                "id": "StorageCardBodyText"
              },
              {
                "type": "input",
                "subType": "alert",
                "header": "",
                "label": "info alert",
                "content": "As part of the AWS Free Usage Tier, you get the first 150 GB of storage for free every month.",
                "alertType": "info",
                "isDismissable": true,
                "id": "FreeTierAlert"
              },
              {
                "type": "input",
                "subType": "fileSize",
                "label": "Size of data to be stored",
                "dropDownSize": [
                  {
                    "label": "MB",
                    "id": "mb"
                  },
                  {
                    "label": "GB",
                    "id": "gb"
                  },
                  {
                    "label": "TB",
                    "id": "tb"
                  }
                ],
                "dropDownFrequency": [
                  {
                    "label": "month",
                    "id": "month"
                  }
                ],
                "defaultOption": {
                  "size": "gb",
                  "frequency": "month"
                },
                "outputSize": "gb",
                "outputSizeLabel": "GB",
                "outputFrequency": "month",
                "outputFrequencyLabel": "month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": false,
                  "allowDecimals": true,
                  "minValue": 0
                },
                "placeholder": "Enter amount",
                "id": "datastored"
              },
              {
                "type": "pricing",
                "subType": "singlePricePoint",
                "id": "StoragePrice",
                "label": "Storage Price",
                "mappingDefinitionName": "finspace",
                "meteredUnit": {
                  "allRegions": "DataStored from 150 to Inf"
                }
              }
            ]
          },
          "mathsSection": [
            {
              "components": [
                {
                  "type": "display",
                  "label": "Unit conversions",
                  "subType": "conversionDisplay",
                  "id": "storageunitconversion",
                  "refer": [
                    "StorageCardBodyText",
                    "FreeTierAlert",
                    "datastored",
                    "StoragePrice"
                  ],
                  "subTotalRefer": "totalUserCost"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "FreeTierStorage",
                  "operation": "subtraction",
                  "operands": [
                    {
                      "variableId": "datastored",
                      "variableLabel": "Size of data to be stored",
                      "variableUnitLabel": "GB",
                      "required": true
                    },
                    {
                      "constant": 150,
                      "constantUnitLabel": "free GB per month"
                    }
                  ],
                  "outputUnitLabel": "billable GB",
                  "decimalPlaces": 0,
                  "minValue": 0
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "id": "FinalStorageCost",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableId": "FreeTierStorage",
                      "variableLabel": "billable GB",
                      "variableUnitLabel": "GB",
                      "required": false
                    },
                    {
                      "variableId": "StoragePrice",
                      "variableLabel": "Storage Price",
                      "variableUnitLabel": "[currency]",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "[currency] (Storage cost)",
                  "decimalPlaces": 2
                },
                {
                  "type": "display",
                  "refer": [
                    "FreeTierStorage",
                    "FinalStorageCost"
                  ],
                  "subType": "priceDisplay",
                  "costType": "Monthly",
                  "label": "Storage cost",
                  "decimalPlaces": 2,
                  "id": "total_storage_cost",
                  "subTotalRefer": "FinalStorageCost"
                }
              ]
            }
          ]
        },

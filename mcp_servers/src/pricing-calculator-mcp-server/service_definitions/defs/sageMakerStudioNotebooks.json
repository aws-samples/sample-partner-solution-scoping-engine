                "type": "input",
                "subType": "numericInput",
                "id": "DataScientistsPerMonth",
                "label": "Number of data scientist(s)",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 10000000000000
                },
                "placeholder": "Enter the number of data scientist(s) per month",
                "description": "Number of data scientist(s)"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "NotebooksPerMonth",
                "label": "Number of Studio Notebook instances per data scientist",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 10000000000000
                },
                "placeholder": "Enter the number of Studio Notebook instances per data scientist per month",
                "description": "Number of Studio Notebook instances"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "NotebookHrsPerDay",
                "label": "Studio Notebook hour(s) per day",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": true,
                  "minValue": 0.01,
                  "maxValue": 24
                },
                "placeholder": "Enter the number of hours Studio Notebooks are used per day",
                "description": "Number of hours Studio Notebooks are being used per day"
              },
              {
                "type": "input",
                "subType": "numericInput",
                "id": "NotebookDaysPerMonth",
                "label": "Studio Notebook day(s) per month",
                "displayInConfigSummary": true,
                "validations": {
                  "required": true,
                  "allowDecimals": false,
                  "minValue": 1,
                  "maxValue": 31
                },
                "placeholder": "Enter the number of days Studio Notebooks are used per month",
                "description": "Number of days Studio Notebooks are being used per month"
              },
              {
                "label": "SageMaker Studio Notebooks",

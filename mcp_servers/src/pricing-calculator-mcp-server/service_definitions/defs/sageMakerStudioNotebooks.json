                      "variableUnitLabel": "hours per day",
                      "required": true
                    },
                    {
                      "variableId": "NotebookDaysPerMonth",
                      "variableLabel": "Studio Notebook day(s) per month",
                      "variableUnitLabel": "days per month",
                      "required": true
                    }
                  ],
                  "outputUnitLabel": "SageMaker Studio Notebook hours per month",
                  "decimalPlaces": 6,
                  "id": "sageMakerStudioNotebooks_generated_1"
                },
                {
                  "type": "maths",
                  "subType": "basicMaths",
                  "operation": "multiplication",
                  "operands": [
                    {
                      "variableLabel": "SageMaker Studio Notebook hours per month",
                      "variableUnitLabel": "hours per month",
                      "required": true,
                      "variableId": "sageMakerStudioNotebooks_generated_1"
                    },
                    {
                      "variableLabel": "SageMaker Studio Notebooks",
                      "variableUnitLabel": "[currency] per hour instance cost",
                      "required": true,
                      "variableId": "monthly_ipm",
                      "IPMSupported": true
                    }

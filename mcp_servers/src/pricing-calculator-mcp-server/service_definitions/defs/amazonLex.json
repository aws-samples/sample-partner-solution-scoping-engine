  "type": "AWSService",
  "slug": "lex",
  "regions": [
    "us-east-1",
    "us-west-2",
    "af-south-1",
    "ap-northeast-2",
    "ap-southeast-1",
    "ap-southeast-2",
    "ap-northeast-1",
    "eu-west-2",
    "ca-central-1",
    "eu-central-1",
    "eu-west-1",
    "us-gov-west-1"
  ],
  "searchKeywords": [
    "bot",
    "chat",
    "chatbot",
    "conversation",
    "conversational interfaces",
    "response",
    "speech",
    "streaming conversation",
    "text",
    "transcripts",
    "virtual agent",

{
  "redundancy": {
    "weight": 0.35,
    "description": "High availability and fault tolerance through redundancy",
    "pillar": "reliability",
    "services": {
      "Multi_AZ": {
        "provides": "availability_zones",
        "coverage_factor": 0.35,
        "detection_patterns": [
          "Multi-AZ",
          "multi AZ",
          "multiple availability zones",
          "availability zone redundancy",
          "cross-AZ"
        ],
        "configuration_checks": [
          {
            "check": "multi_az_enabled",
            "description": "Resources deployed across multiple availability zones",
            "weight": 0.6
          },
          {
            "check": "az_distribution",
            "description": "Even distribution across availability zones",
            "weight": 0.4
          }
        ]
      },
      "ELB": {
        "provides": "load_balancing",
        "coverage_factor": 0.25,
        "detection_patterns": [
          "Elastic Load Balancing",
          "ELB",
          "Application Load Balancer",
          "ALB",
          "Network Load Balancer",
          "NLB",
          "load balancer"
        ],
        "configuration_checks": [
          {
            "check": "cross_zone_enabled",
            "description": "Cross-zone load balancing enabled",
            "weight": 0.4
          },
          {
            "check": "health_checks",
            "description": "Health checks configured for targets",
            "weight": 0.6
          }
        ]
      },
      "Route53": {
        "provides": "dns_failover",
        "coverage_factor": 0.2,
        "detection_patterns": [
          "Route 53",
          "Route53",
          "DNS failover",
          "health check routing",
          "failover routing"
        ],
        "configuration_checks": [
          {
            "check": "health_checks",
            "description": "Health checks configured for endpoints",
            "weight": 0.5
          },
          {
            "check": "failover_policy",
            "description": "Failover routing policy configured",
            "weight": 0.5
          }
        ]
      },
      "RDS_Multi_AZ": {
        "provides": "database_redundancy",
        "coverage_factor": 0.2,
        "detection_patterns": [
          "RDS Multi-AZ",
          "RDS multi AZ",
          "Aurora Multi-AZ",
          "database redundancy"
        ],
        "configuration_checks": [
          {
            "check": "multi_az_deployment",
            "description": "RDS deployed in Multi-AZ configuration",
            "weight": 0.7
          },
          {
            "check": "automated_backups",
            "description": "Automated backups enabled",
            "weight": 0.3
          }
        ]
      }
    }
  },

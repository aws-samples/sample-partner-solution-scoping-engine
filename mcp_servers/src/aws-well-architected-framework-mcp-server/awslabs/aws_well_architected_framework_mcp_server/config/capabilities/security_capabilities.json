{
  "encryption": {
    "weight": 0.25,
    "description": "Data encryption at rest and in transit",
    "pillar": "security",
    "services": {
      "KMS": {
        "provides": "key_management",
        "coverage_factor": 0.3,
        "detection_patterns": [
          "AWS KMS",
          "Key Management Service",
          "KMS key",
          "customer managed key",
          "CMK"
        ],
        "configuration_checks": [
          {
            "check": "key_rotation_enabled",
            "description": "Automatic key rotation is enabled",
            "weight": 0.3
          },
          {
            "check": "key_policy_defined",
            "description": "Key policy restricts access appropriately",
            "weight": 0.2
          }
        ]
      },
      "S3_encryption": {
        "provides": "storage_encryption",
        "coverage_factor": 0.2,
        "detection_patterns": [
          "S3 encryption",
          "bucket encryption",
          "SSE-S3",
          "SSE-KMS",
          "server-side encryption"
        ],
        "configuration_checks": [
          {
            "check": "default_encryption_enabled",
            "description": "Default encryption is enabled on S3 buckets",
            "weight": 0.4
          },
          {
            "check": "encryption_in_transit",
            "description": "HTTPS/TLS required for S3 access",
            "weight": 0.3
          }
        ]
      },
      "RDS_encryption": {
        "provides": "database_encryption",
        "coverage_factor": 0.2,
        "detection_patterns": [
          "RDS encryption",
          "encrypted RDS",
          "database encryption",
          "Aurora encryption"
        ],
        "configuration_checks": [
          {
            "check": "encryption_at_rest",
            "description": "RDS instance has encryption at rest enabled",
            "weight": 0.5
          },
          {
            "check": "ssl_tls_connections",
            "description": "SSL/TLS required for database connections",
            "weight": 0.3
          }
        ]
      },
      "DynamoDB_encryption": {
        "provides": "nosql_encryption",
        "coverage_factor": 0.15,
        "detection_patterns": [
          "DynamoDB encryption",
          "encrypted DynamoDB",
          "DynamoDB KMS"
        ],
        "configuration_checks": [
          {
            "check": "encryption_at_rest",
            "description": "DynamoDB table has encryption at rest enabled",
            "weight": 0.5
          }
        ]
      },
      "EBS_encryption": {
        "provides": "volume_encryption",
        "coverage_factor": 0.15,
        "detection_patterns": [
          "EBS encryption",
          "encrypted EBS",
          "encrypted volume"
        ],
        "configuration_checks": [
          {
            "check": "encryption_enabled",
            "description": "EBS volumes are encrypted",
            "weight": 0.5
          }
        ]
      }
    }
  },

    # Subtask 5.5: Implement pattern-specific recommendations
    def generate_pattern_specific_recommendations(
        self,
        detected_patterns: List[str],
        detected_services: List[str],
        capability_matrix: CapabilityMatrix
    ) -> List[EnhancedRecommendation]:
        """
        Generate pattern-specific recommendations.
        
        Creates recommendations tailored to:
        - Serverless architectures
        - Microservices architectures
        - Traditional web architectures
        - Other detected patterns
        
        Avoids recommending practices that conflict with detected patterns.
        
        Args:
            detected_patterns: List of detected architecture patterns
            detected_services: List of detected AWS services
            capability_matrix: Detected capabilities
            
        Returns:
            List of pattern-specific recommendations
        """
        self.logger.info(f"📋 Generating pattern-specific recommendations for {len(detected_patterns)} patterns...")
        
        recommendations = []
        
        for pattern in detected_patterns:
            pattern_lower = pattern.lower()
            
            # Get pattern-specific recommendations
            if pattern_lower in self.pattern_recommendations:
                pattern_config = self.pattern_recommendations[pattern_lower]
                specific_recs = pattern_config.get("specific_recommendations", [])
                
                for idx, rec_text in enumerate(specific_recs):
                    rec_id = f"rec-pattern-{pattern_lower}-{idx+1}"
                    
                    recommendation = EnhancedRecommendation(
                        id=rec_id,
                        title=f"{pattern.title()} Best Practice: {rec_text[:50]}...",
                        description=rec_text,
                        pillar=self._infer_pillar_from_recommendation(rec_text),
                        priority=RecommendationPriority.MEDIUM,
                        capability_addressed=self._infer_capability_from_recommendation(rec_text),
                        affected_services=self._get_affected_services_for_pattern_rec(
                            rec_text, detected_services
                        ),
                        implementation_steps=self._generate_pattern_specific_steps(rec_text),
                        implementation_effort=ImplementationEffort.MEDIUM,
                        estimated_time="3-6 hours",
                        estimated_score_improvement=5.0,
                        pattern_specific=True,
                        applicable_patterns=[pattern],
                        recommendation_type="pattern",
                        confidence=0.85
                    )
                    
                    recommendations.append(recommendation)
                    self.logger.debug(f"  ✅ Generated pattern recommendation: {recommendation.title}")
        
        self.logger.info(f"✅ Generated {len(recommendations)} pattern-specific recommendations")
        return recommendations
    
    def _infer_pillar_from_recommendation(self, rec_text: str) -> str:
        """Infer pillar from recommendation text."""
        rec_lower = rec_text.lower()
        
        if any(word in rec_lower for word in ["security", "encryption", "iam", "authentication"]):
            return "security"
        elif any(word in rec_lower for word in ["reliability", "redundancy", "failover", "backup"]):
            return "reliability"
        elif any(word in rec_lower for word in ["performance", "caching", "optimization"]):
            return "performance"
        elif any(word in rec_lower for word in ["cost", "savings", "budget"]):
            return "cost_optimization"
        elif any(word in rec_lower for word in ["operational", "monitoring", "automation", "cicd"]):
            return "operational_excellence"
        else:
            return "operational_excellence"
    
    def _infer_capability_from_recommendation(self, rec_text: str) -> str:
        """Infer capability from recommendation text."""
        rec_lower = rec_text.lower()
        
        if "tracing" in rec_lower or "x-ray" in rec_lower:
            return "performance_monitoring"
        elif "service mesh" in rec_lower:
            return "service_isolation"
        elif "api gateway" in rec_lower or "api management" in rec_lower:
            return "api_management"
        elif "circuit breaker" in rec_lower:
            return "fault_isolation"
        elif "auto scaling" in rec_lower or "scaling" in rec_lower:
            return "scaling"
        elif "monitoring" in rec_lower:
            return "operational_monitoring"
        else:
            return "general"
    
    def _get_affected_services_for_pattern_rec(
        self,
        rec_text: str,
        detected_services: List[str]
    ) -> List[str]:
        """Get affected services for a pattern recommendation."""
        affected = []
        rec_lower = rec_text.lower()
        
        # Map recommendation keywords to services
        service_keywords = {
            "lambda": ["Lambda"],
            "step functions": ["Step Functions"],
            "eventbridge": ["EventBridge"],
            "x-ray": ["X-Ray"],
            "api gateway": ["API Gateway"],
            "ecs": ["ECS"],
            "eks": ["EKS"],
            "load balancer": ["ELB", "ALB", "NLB"],
            "rds": ["RDS"],
            "elasticache": ["ElastiCache"]
        }
        
        for keyword, services in service_keywords.items():
            if keyword in rec_lower:
                for service in services:
                    for detected in detected_services:
                        if service.lower() in detected.lower():
                            affected.append(detected)
        
        return affected
    
    def _generate_pattern_specific_steps(self, rec_text: str) -> List[ImplementationStep]:
        """Generate implementation steps for pattern recommendation."""
        # Simple step generation based on recommendation text
        return [
            ImplementationStep(
                step_number=1,
                description=rec_text
            ),
            ImplementationStep(
                step_number=2,
                description="Review AWS documentation for implementation details"
            ),
            ImplementationStep(
                step_number=3,
                description="Test implementation in non-production environment"
            )
        ]
    
    # Main method: Generate all recommendations
    def generate_recommendations(
        self,
        capability_matrix: CapabilityMatrix,
        pillar_scores: Dict[str, PillarScore],
        detected_patterns: List[str],
        detected_services: List[str],
        service_configurations: Optional[Dict[str, Any]] = None
    ) -> RecommendationSet:
        """
        Generate comprehensive recommendations for architecture improvement.
        
        Main entry point that orchestrates all recommendation generation:
        1. Identifies capability gaps
        2. Generates capability-specific recommendations
        3. Adds pattern-specific recommendations
        4. Prioritizes and organizes recommendations
        
        Args:
            capability_matrix: Detected capabilities
            pillar_scores: Calculated pillar scores
            detected_patterns: List of detected architecture patterns
            detected_services: List of detected AWS services
            service_configurations: Optional service configuration details
            
        Returns:
            RecommendationSet with all generated recommendations
        """
        self.logger.info("🚀 Starting comprehensive recommendation generation...")
        
        if service_configurations is None:
            service_configurations = {}
        
        all_recommendations = []
        
        # Step 1: Identify capability gaps
        self.logger.info("Step 1: Identifying capability gaps...")
        gaps = self.identify_capability_gaps(capability_matrix, pillar_scores)
        self.logger.info(f"  Found {len(gaps)} capability gaps")
        
        # Step 2: Generate capability-specific recommendations
        self.logger.info("Step 2: Generating capability-specific recommendations...")
        for gap in gaps:
            try:
                recommendation = self.generate_capability_recommendation(
                    gap, detected_services, service_configurations
                )
                all_recommendations.append(recommendation)
            except Exception as e:
                self.logger.error(f"  ❌ Failed to generate recommendation for {gap.capability_name}: {e}")
        
        self.logger.info(f"  Generated {len(all_recommendations)} capability recommendations")
        
        # Step 3: Generate pattern-specific recommendations
        if detected_patterns:
            self.logger.info("Step 3: Generating pattern-specific recommendations...")
            pattern_recs = self.generate_pattern_specific_recommendations(
                detected_patterns, detected_services, capability_matrix
            )
            all_recommendations.extend(pattern_recs)
            self.logger.info(f"  Generated {len(pattern_recs)} pattern recommendations")
        
        # Step 4: Create recommendation set
        recommendation_set = RecommendationSet(
            recommendations=all_recommendations,
            generation_timestamp=datetime.utcnow().isoformat()
        )
        
        # Log summary
        self.logger.info("=" * 60)
        self.logger.info("📊 RECOMMENDATION GENERATION SUMMARY")
        self.logger.info("=" * 60)
        self.logger.info(f"Total Recommendations: {len(all_recommendations)}")
        self.logger.info(f"Capability-Specific: {len([r for r in all_recommendations if r.recommendation_type == 'capability'])}")
        self.logger.info(f"Pattern-Specific: {len([r for r in all_recommendations if r.recommendation_type == 'pattern'])}")
        self.logger.info(f"Critical Priority: {len(recommendation_set.get_critical_recommendations())}")
        self.logger.info(f"Total Estimated Improvement: +{recommendation_set.total_estimated_improvement:.1f} points")
        self.logger.info("=" * 60)
        
        # Log top recommendations
        self.logger.info("\n🎯 TOP 5 RECOMMENDATIONS BY PRIORITY:")
        sorted_recs = recommendation_set.sort_by_priority()
        for i, rec in enumerate(sorted_recs.recommendations[:5], 1):
            self.logger.info(
                f"  {i}. [{rec.priority.value.upper()}] {rec.title} "
                f"(+{rec.estimated_score_improvement:.1f} points, {rec.implementation_effort.value} effort)"
            )
        
        self.logger.info("\n💡 TOP 3 QUICK WINS:")
        quick_wins = recommendation_set.get_quick_wins(3)
        for i, rec in enumerate(quick_wins, 1):
            self.logger.info(
                f"  {i}. {rec.title} "
                f"(+{rec.estimated_score_improvement:.1f} points, {rec.implementation_effort.value} effort)"
            )
        
        self.logger.info("\n✅ Recommendation generation complete!")
        
        return recommendation_set


# Global enhanced recommendation engine instance
enhanced_recommendation_engine = EnhancedRecommendationEngine()

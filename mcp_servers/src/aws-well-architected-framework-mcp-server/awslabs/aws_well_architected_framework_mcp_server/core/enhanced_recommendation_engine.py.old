# Setup logging following MCP server patterns
try:
    backend_path = os.path.join(os.path.dirname(__file__), '..', '..', '..', '..', '..', '..', 'backend')
    if backend_path not in sys.path:
        sys.path.insert(0, backend_path)
    
    from utils.mcp_logger import setup_mcp_logging
    logger = setup_mcp_logging("wafr-recommendation-engine")
    logger.info("Enhanced recommendation engine logger initialized")
except ImportError as e:
    from logging.handlers import RotatingFileHandler
    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s [%(levelname)s] [%(name)s] - %(message)s',
        handlers=[
            logging.StreamHandler(sys.stdout),
            RotatingFileHandler("wafr-recommendation-engine.log", maxBytes=10*1024*1024, backupCount=5)
        ]
    )
    logger = logging.getLogger("wafr-recommendation-engine")
    logger.warning(f"Using fallback logging: {e}")


class EnhancedRecommendationEngine:
    """
    Enhanced recommendation engine for WAFR assessments.
    
    Generates capability-specific, actionable recommendations based on:
    - Capability gaps (missing or low-coverage capabilities)
    - Detected services and their configurations
    - Architecture patterns
    - Pillar scores and weaknesses
    
    Features:
    - Capability gap analysis
    - Service-specific implementation guidance
    - Priority and effort estimation
    - Pattern-aware recommendations
    - Score improvement estimates
    """
    
    def __init__(self):
        """Initialize the recommendation engine."""
        self.logger = logger
        self._load_recommendation_templates()
        self._load_service_guidance()
        self._load_pattern_recommendations()
    

    # Subtask 5.1: Implement capability gap analysis
    def identify_capability_gaps(
        self,
        capability_matrix: CapabilityMatrix,
        pillar_scores: Dict[str, PillarScore]
    ) -> List[CapabilityGap]:
        """
        Identify missing or poorly implemented capabilities.
        
        Analyzes the capability matrix to find:
        - Missing capabilities (0% coverage)
        - Partial capabilities (<60% coverage)
        - Prioritizes by pillar importance and business impact
        
        Args:
            capability_matrix: Detected capabilities
            pillar_scores: Calculated pillar scores
            
        Returns:
            List of capability gaps sorted by priority
        """
        self.logger.info("🔍 Identifying capability gaps...")
        
        gaps = []
        
        # Define target coverage levels by pillar importance
        target_coverage = {
            "security": 0.85,  # High target for security
            "reliability": 0.80,
            "performance": 0.70,
            "cost_optimization": 0.65,
            "operational_excellence": 0.70,
            "sustainability": 0.60
        }
        
        # Analyze each pillar
        for pillar_name, pillar_score in pillar_scores.items():
            capabilities = capability_matrix.get_capabilities_for_pillar(pillar_name)
            target = target_coverage.get(pillar_name, 0.70)
            
            # Check for missing capabilities (not detected at all)
            expected_capabilities = self._get_expected_capabilities_for_pillar(pillar_name)
            detected_capability_names = {c.name for c in capabilities}
            
            for expected_cap in expected_capabilities:
                if expected_cap not in detected_capability_names:
                    # Missing capability
                    impact = self._calculate_impact(pillar_name, expected_cap, 0.0)
                    gap = CapabilityGap(
                        capability_name=expected_cap,
                        pillar=pillar_name,
                        current_coverage=0.0,
                        target_coverage=target,
                        impact=impact,
                        missing_services=self._get_services_for_capability(expected_cap)
                    )
                    gaps.append(gap)
                    self.logger.debug(f"  ❌ Missing capability: {expected_cap} in {pillar_name}")
            
            # Check for partial capabilities (low coverage)
            for capability in capabilities:
                if capability.coverage < 0.60:  # Less than 60% coverage
                    impact = self._calculate_impact(pillar_name, capability.name, capability.coverage)
                    gap = CapabilityGap(
                        capability_name=capability.name,
                        pillar=pillar_name,
                        current_coverage=capability.coverage,
                        target_coverage=target,
                        impact=impact,
                        affected_services=capability.evidence,
                        missing_services=capability.missing_services
                    )
                    gaps.append(gap)
                    self.logger.debug(
                        f"  ⚠️  Partial capability: {capability.name} "
                        f"({capability.coverage:.0%} coverage) in {pillar_name}"
                    )
        
        # Sort by priority score (highest first)
        gaps.sort(key=lambda g: g.priority_score, reverse=True)
        
        self.logger.info(f"✅ Identified {len(gaps)} capability gaps")
        return gaps
    
    def _get_expected_capabilities_for_pillar(self, pillar: str) -> List[str]:
        """Get list of expected capabilities for a pillar."""
        expected = {
            "security": ["encryption", "identity_access", "network_security", 
                        "monitoring_detection", "data_protection"],
            "reliability": ["redundancy", "monitoring_alerting", "backup_recovery", "scaling"],
            "performance": ["caching", "compute_optimization", "database_optimization", 
                           "performance_monitoring"],
            "cost_optimization": ["cost_monitoring", "resource_optimization", 
                                 "lifecycle_management", "rightsizing"],
            "operational_excellence": ["iac_automation", "cicd_pipeline", 
                                      "operational_monitoring", "incident_response"],
            "sustainability": ["efficient_compute", "managed_services", "resource_efficiency"]
        }
        return expected.get(pillar, [])
    
    def _get_services_for_capability(self, capability_name: str) -> List[str]:
        """Get AWS services that provide a capability."""
        service_mapping = {
            "encryption": ["KMS", "S3 encryption", "RDS encryption", "DynamoDB encryption"],
            "identity_access": ["IAM", "Cognito", "Secrets Manager"],
            "network_security": ["VPC", "Security Groups", "WAF", "Shield"],
            "monitoring_detection": ["CloudTrail", "GuardDuty", "Security Hub", "Config"],
            "data_protection": ["Backup", "S3 versioning", "RDS snapshots"],
            "redundancy": ["Multi-AZ", "Auto Scaling", "Multiple regions"],
            "monitoring_alerting": ["CloudWatch", "CloudWatch Alarms", "SNS"],
            "backup_recovery": ["AWS Backup", "RDS snapshots", "S3 replication"],
            "scaling": ["Auto Scaling", "Lambda", "DynamoDB auto-scaling"],
            "caching": ["CloudFront", "ElastiCache", "API Gateway caching"],
            "compute_optimization": ["Lambda", "Fargate", "Compute Optimizer"],
            "database_optimization": ["RDS read replicas", "DynamoDB DAX", "Aurora"],
            "performance_monitoring": ["CloudWatch", "X-Ray", "Performance Insights"],
            "cost_monitoring": ["Cost Explorer", "Budgets", "Cost Anomaly Detection"],
            "resource_optimization": ["Trusted Advisor", "Compute Optimizer"],
            "lifecycle_management": ["S3 Lifecycle", "EBS Lifecycle Manager"],
            "iac_automation": ["CloudFormation", "CDK", "Terraform"],
            "cicd_pipeline": ["CodePipeline", "CodeBuild", "CodeDeploy"],
            "operational_monitoring": ["CloudWatch", "Systems Manager", "X-Ray"],
            "efficient_compute": ["Graviton", "Lambda", "Fargate"],
            "managed_services": ["RDS", "DynamoDB", "Lambda", "Fargate"]
        }
        return service_mapping.get(capability_name, [])
    
    def _calculate_impact(self, pillar: str, capability: str, current_coverage: float) -> str:
        """
        Calculate impact level of a capability gap.
        
        Args:
            pillar: Pillar name
            capability: Capability name
            current_coverage: Current coverage level (0.0-1.0)
            
        Returns:
            Impact level: 'critical', 'high', 'medium', or 'low'
        """
        # Security and reliability gaps are higher priority
        high_priority_pillars = {"security", "reliability"}
        
        # Critical security/reliability capabilities
        critical_capabilities = {
            "encryption", "identity_access", "network_security",
            "redundancy", "backup_recovery"
        }
        
        # Determine impact
        if pillar in high_priority_pillars and capability in critical_capabilities:
            if current_coverage == 0.0:
                return "critical"
            elif current_coverage < 0.40:
                return "high"
            else:
                return "medium"
        elif pillar in high_priority_pillars:
            if current_coverage == 0.0:
                return "high"
            elif current_coverage < 0.40:
                return "medium"
            else:
                return "low"
        else:
            if current_coverage == 0.0:
                return "medium"
            elif current_coverage < 0.40:
                return "low"
            else:
                return "low"
    
    # Subtask 5.2: Implement capability-specific recommendation generation
    def generate_capability_recommendation(
        self,
        gap: CapabilityGap,
        detected_services: List[str],
        service_configurations: Dict[str, Any]
    ) -> EnhancedRecommendation:
        """
        Generate a capability-specific recommendation for a gap.
        
        Creates detailed, actionable recommendations for:
        - Encryption gaps
        - Redundancy gaps
        - Monitoring gaps
        - All capability types
        
        Args:
            gap: Capability gap to address
            detected_services: List of detected AWS services
            service_configurations: Service configuration details
            
        Returns:
            Enhanced recommendation with implementation guidance
        """
        self.logger.debug(f"📝 Generating recommendation for {gap.capability_name} gap...")
        
        # Get template for this capability
        template = self.recommendation_templates.get(gap.capability_name, {})
        
        # Generate unique ID
        rec_id = f"rec-{gap.pillar}-{gap.capability_name}-{uuid.uuid4().hex[:8]}"
        
        # Determine priority (adjust template based on gap impact)
        priority = self._determine_priority(gap, template.get("priority_base"))
        
        # Generate implementation steps
        impl_steps = self._generate_implementation_steps(
            gap, detected_services, service_configurations
        )
        
        # Calculate score improvement estimate
        score_improvement = self._estimate_score_improvement(gap)
        
        # Get AWS documentation links
        doc_links = self._get_documentation_links(gap.capability_name, detected_services)
        
        # Get best practices
        best_practices = self._get_best_practices(gap.capability_name)
        
        # Create recommendation
        recommendation = EnhancedRecommendation(
            id=rec_id,
            title=template.get("title", f"Improve {gap.capability_name.replace('_', ' ').title()}"),
            description=template.get("description", f"Address {gap.capability_name} capability gap"),
            pillar=gap.pillar,
            priority=priority,
            capability_addressed=gap.capability_name,
            affected_services=gap.affected_services,
            missing_services=gap.missing_services,
            implementation_steps=impl_steps,
            implementation_effort=template.get("effort", ImplementationEffort.MEDIUM),
            estimated_time=template.get("estimated_time", "3-6 hours"),
            estimated_score_improvement=score_improvement,
            risk_reduction=template.get("risk_reduction", "Medium"),
            business_impact=self._get_business_impact(gap),
            aws_documentation_links=doc_links,
            best_practices=best_practices,
            recommendation_type="capability",
            confidence=0.9
        )
        
        self.logger.debug(f"  ✅ Generated recommendation: {recommendation.title}")
        return recommendation
    
    def _determine_priority(
        self,
        gap: CapabilityGap,
        base_priority: Optional[RecommendationPriority]
    ) -> RecommendationPriority:
        """Determine final priority based on gap impact."""
        if gap.impact == "critical":
            return RecommendationPriority.CRITICAL
        elif gap.impact == "high":
            return RecommendationPriority.HIGH
        elif gap.impact == "medium":
            return RecommendationPriority.MEDIUM
        else:
            return base_priority or RecommendationPriority.LOW
    
    # Subtask 5.3: Add service-specific implementation guidance
    def _generate_implementation_steps(
        self,
        gap: CapabilityGap,
        detected_services: List[str],
        service_configurations: Dict[str, Any]
    ) -> List[ImplementationStep]:
        """
        Generate service-specific implementation steps.
        
        Provides specific guidance for:
        - Lambda (cold starts, concurrency, timeouts)
        - RDS (Multi-AZ, encryption, backups)
        - API Gateway (throttling, caching, authorization)
        - S3 (encryption, versioning, lifecycle)
        - And other AWS services
        
        Args:
            gap: Capability gap
            detected_services: Detected AWS services
            service_configurations: Service configurations
            
        Returns:
            List of implementation steps with examples
        """
        steps = []
        step_num = 1
        
        # Get relevant services for this capability
        relevant_services = self._get_relevant_services_for_capability(
            gap.capability_name, detected_services
        )
        
        # Generate steps for each relevant service
        for service in relevant_services:
            service_steps = self._get_service_specific_steps(
                service, gap.capability_name, service_configurations.get(service, {})
            )
            
            for step_desc in service_steps:
                step = ImplementationStep(
                    step_number=step_num,
                    description=step_desc,
                    aws_service=service,
                    configuration_example=self._get_configuration_example(
                        service, gap.capability_name
                    ),
                    documentation_link=self._get_service_doc_link(service, gap.capability_name)
                )
                steps.append(step)
                step_num += 1
        
        # Add general steps if no service-specific steps
        if not steps:
            general_steps = self._get_general_steps_for_capability(gap.capability_name)
            for step_desc in general_steps:
                step = ImplementationStep(
                    step_number=step_num,
                    description=step_desc
                )
                steps.append(step)
                step_num += 1
        
        return steps
    
    def _get_relevant_services_for_capability(
        self,
        capability: str,
        detected_services: List[str]
    ) -> List[str]:
        """Get services relevant to a capability from detected services."""
        capability_services = self._get_services_for_capability(capability)
        
        # Match detected services with capability services
        relevant = []
        for detected in detected_services:
            for cap_service in capability_services:
                if cap_service.lower() in detected.lower() or detected.lower() in cap_service.lower():
                    relevant.append(detected)
                    break
        
        return relevant
    
    def _get_service_specific_steps(
        self,
        service: str,
        capability: str,
        config: Dict[str, Any]
    ) -> List[str]:
        """Get service-specific implementation steps."""
        # Map capability to guidance category
        capability_to_category = {
            "encryption": "encryption",
            "identity_access": "security",
            "network_security": "security",
            "monitoring_detection": "monitoring",
            "data_protection": "backup",
            "redundancy": "redundancy",
            "monitoring_alerting": "monitoring",
            "backup_recovery": "backup",
            "scaling": "scaling",
            "caching": "performance",
            "compute_optimization": "performance",
            "database_optimization": "performance",
            "performance_monitoring": "monitoring",
            "cost_monitoring": "cost",
            "resource_optimization": "cost",
            "lifecycle_management": "cost"
        }
        
        category = capability_to_category.get(capability, "general")
        
        # Get guidance for this service and category
        service_key = self._normalize_service_name(service)
        if service_key in self.service_guidance:
            return self.service_guidance[service_key].get(category, [])
        
        return []
    
    def _normalize_service_name(self, service: str) -> str:
        """Normalize service name for lookup."""
        # Extract core service name
        service_lower = service.lower()
        
        if "lambda" in service_lower:
            return "Lambda"
        elif "rds" in service_lower:
            return "RDS"
        elif "s3" in service_lower:
            return "S3"
        elif "api gateway" in service_lower or "apigateway" in service_lower:
            return "API Gateway"
        elif "dynamodb" in service_lower:
            return "DynamoDB"
        elif "ec2" in service_lower:
            return "EC2"
        elif "cloudfront" in service_lower:
            return "CloudFront"
        
        return service
    
    def _get_configuration_example(self, service: str, capability: str) -> Optional[Dict[str, Any]]:
        """Get configuration example for service and capability."""
        examples = {
            ("Lambda", "encryption"): {
                "Environment": {
                    "Variables": {
                        "DB_PASSWORD": "encrypted-value",
                        "KMS_KEY_ID": "arn:aws:kms:region:account:key/key-id"
                    }
                }
            },
            ("RDS", "encryption"): {
                "StorageEncrypted": True,
                "KmsKeyId": "arn:aws:kms:region:account:key/key-id"
            },
            ("RDS", "redundancy"): {
                "MultiAZ": True,
                "BackupRetentionPeriod": 7
            },
            ("S3", "encryption"): {
                "ServerSideEncryptionConfiguration": {
                    "Rules": [{
                        "ApplyServerSideEncryptionByDefault": {
                            "SSEAlgorithm": "aws:kms",
                            "KMSMasterKeyID": "arn:aws:kms:region:account:key/key-id"
                        }
                    }]
                }
            },
            ("API Gateway", "throttling"): {
                "ThrottleSettings": {
                    "RateLimit": 1000,
                    "BurstLimit": 2000
                }
            }
        }
        
        service_norm = self._normalize_service_name(service)
        return examples.get((service_norm, capability))
    
    def _get_service_doc_link(self, service: str, capability: str) -> Optional[str]:
        """Get AWS documentation link for service and capability."""
        base_url = "https://docs.aws.amazon.com"
        
        doc_links = {
            ("Lambda", "encryption"): f"{base_url}/lambda/latest/dg/configuration-envvars.html#configuration-envvars-encryption",
            ("Lambda", "monitoring"): f"{base_url}/lambda/latest/dg/lambda-monitoring.html",
            ("Lambda", "performance"): f"{base_url}/lambda/latest/dg/best-practices.html",
            ("RDS", "encryption"): f"{base_url}/AmazonRDS/latest/UserGuide/Overview.Encryption.html",
            ("RDS", "redundancy"): f"{base_url}/AmazonRDS/latest/UserGuide/Concepts.MultiAZ.html",
            ("RDS", "backup"): f"{base_url}/AmazonRDS/latest/UserGuide/USER_WorkingWithAutomatedBackups.html",
            ("S3", "encryption"): f"{base_url}/AmazonS3/latest/userguide/UsingEncryption.html",
            ("S3", "versioning"): f"{base_url}/AmazonS3/latest/userguide/Versioning.html",
            ("API Gateway", "security"): f"{base_url}/apigateway/latest/developerguide/security.html",
            ("API Gateway", "throttling"): f"{base_url}/apigateway/latest/developerguide/api-gateway-request-throttling.html",
            ("DynamoDB", "encryption"): f"{base_url}/amazondynamodb/latest/developerguide/EncryptionAtRest.html",
            ("DynamoDB", "backup"): f"{base_url}/amazondynamodb/latest/developerguide/BackupRestore.html"
        }
        
        service_norm = self._normalize_service_name(service)
        
        # Try specific capability first
        link = doc_links.get((service_norm, capability))
        if link:
            return link
        
        # Fall back to general service documentation
        general_links = {
            "Lambda": f"{base_url}/lambda/latest/dg/welcome.html",
            "RDS": f"{base_url}/AmazonRDS/latest/UserGuide/Welcome.html",
            "S3": f"{base_url}/AmazonS3/latest/userguide/Welcome.html",
            "API Gateway": f"{base_url}/apigateway/latest/developerguide/welcome.html",
            "DynamoDB": f"{base_url}/amazondynamodb/latest/developerguide/Introduction.html",
            "EC2": f"{base_url}/AWSEC2/latest/UserGuide/concepts.html",
            "CloudFront": f"{base_url}/AmazonCloudFront/latest/DeveloperGuide/Introduction.html"
        }
        
        return general_links.get(service_norm)
    

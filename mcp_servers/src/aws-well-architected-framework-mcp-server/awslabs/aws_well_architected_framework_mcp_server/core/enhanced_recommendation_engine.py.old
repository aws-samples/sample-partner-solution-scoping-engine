        ])
    
    # Subtask 5.4: Implement recommendation prioritization
    def _estimate_score_improvement(self, gap: CapabilityGap) -> float:
        """
        Estimate score improvement from addressing a gap.
        
        Calculates expected points gained based on:
        - Gap size (target - current coverage)
        - Capability weight
        - Pillar importance
        
        Args:
            gap: Capability gap
            
        Returns:
            Estimated score improvement in points
        """
        # Base improvement from closing the gap
        # Assume max 60 points available from capabilities per pillar
        max_capability_points = 60.0
        
        # Get capability weight (default to 0.20 if unknown)
        capability_weights = {
            "encryption": 0.25,
            "identity_access": 0.25,
            "network_security": 0.20,
            "monitoring_detection": 0.15,
            "data_protection": 0.15,
            "redundancy": 0.30,
            "monitoring_alerting": 0.25,
            "backup_recovery": 0.25,
            "scaling": 0.20,
            "caching": 0.30,
            "compute_optimization": 0.25,
            "database_optimization": 0.25,
            "performance_monitoring": 0.20
        }
        
        weight = capability_weights.get(gap.capability_name, 0.20)
        
        # Calculate improvement
        # If gap is fully closed, gain: max_points * weight * gap_size
        improvement = max_capability_points * weight * gap.gap_size
        
        # Adjust for confidence (assume 0.9 confidence in estimate)
        improvement *= 0.9
        
        return round(improvement, 1)
    
    def _get_business_impact(self, gap: CapabilityGap) -> str:
        """Get business impact description for a gap."""
        impact_descriptions = {
            "critical": "Critical business risk - immediate attention required",
            "high": "Significant business risk - high priority for remediation",
            "medium": "Moderate business risk - should be addressed in near term",
            "low": "Low business risk - can be addressed as resources allow"
        }
        
        return impact_descriptions.get(gap.impact, "Business impact to be assessed")
    
